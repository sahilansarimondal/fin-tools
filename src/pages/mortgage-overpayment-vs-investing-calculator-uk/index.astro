---
import PageLayout from '../../layouts/PageLayout.astro';
import MortgageVsIsaCalculator from '../../components/calculator/MortgageVsIsaCalculator.astro';
import HowItWorks from '../../components/ui/HowItWorks.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import type { FAQItem } from '../../utils/faq-data';

const toolFaqItems: FAQItem[] = [
  {
    question: 'Is it better to overpay a mortgage or invest in an ISA in the UK?',
    answerHtml: `<b>It depends on the spread between your mortgage interest rate and your expected investment return.</b> If your mortgage rate is 4.5% and you expect 7% long-term returns from a Stocks &amp; Shares ISA, investing the surplus typically produces a higher net worth over time — but it comes with market risk. Overpaying your mortgage guarantees a return equal to your mortgage interest rate, which is risk-free. For risk-averse borrowers, the psychological benefit of being debt-free early often outweighs the mathematical optimality of investing. Use this calculator to model your specific numbers and see which strategy wins for your situation.`,
    answerText: 'It depends on your mortgage rate vs expected ISA returns. Investing wins mathematically when returns exceed your mortgage rate, but overpaying offers guaranteed, risk-free returns.'
  },
  {
    question: 'How do lender early repayment charges affect a mortgage overpayment vs investing calculator UK?',
    answerHtml: `<b>Most UK fixed-rate mortgages limit penalty-free overpayments to 10% of the outstanding balance per year.</b> For example, on a £200,000 mortgage, you could typically overpay up to £20,000 per year without triggering Early Repayment Charges (ERCs). ERCs typically range from 1-5% of the amount overpaid, depending on how many years remain on your fixed rate. This calculator assumes unlimited overpayments for mathematical simplicity, but in practice you should check your mortgage terms and factor in any ERCs that would reduce the benefit of overpaying.`,
    answerText: 'Most UK fixed-rate mortgages cap penalty-free overpayments at 10% of the outstanding balance per year. ERCs typically range from 1-5% of the overpaid amount.'
  },
  {
    question: 'Does paying off a mortgage early beat compound interest from stock investing?',
    answerHtml: `<b>Paying off a mortgage early gives you a guaranteed, risk-free return equal to your mortgage interest rate.</b> If your mortgage rate is 4.5%, every pound you overpay "earns" 4.5% tax-free — a return no savings account can match. However, historical stock market returns (7-10% annually over long periods) have typically outpaced mortgage rates. The key difference is certainty: mortgage overpayment provides a guaranteed return, while equity investing carries market risk. Over a 15-25 year horizon, equities have historically won, but past performance doesn't guarantee future results. The optimal choice depends on your risk tolerance, tax situation, and time horizon.`,
    answerText: 'Mortgage overpayment guarantees a return equal to your mortgage rate (risk-free). Equities have historically returned more over 15-25 years, but with market risk.'
  },
  {
    question: 'What happens to my monthly payments after I overpay my mortgage?',
    answerHtml: `<b>When you overpay your mortgage, your monthly payment typically stays the same but your term is shortened.</b> Most UK lenders apply overpayments to reduce the outstanding balance, which means you pay less interest overall and clear the debt years earlier. Some lenders allow you to reduce your monthly payment instead — check with your lender which option they offer. This calculator assumes the standard approach: fixed monthly payment, shorter term. The freed-up cash (standard payment plus surplus) becomes available for investment once the mortgage is cleared, which is the "redirect effect" that makes Strategy B powerful.`,
    answerText: 'Overpayments typically shorten your term while keeping monthly payments the same. Once the mortgage is cleared, the full monthly budget (standard payment + surplus) can be redirected into ISA investments.'
  },
  {
    question: 'Should I overpay my mortgage if I have other high-interest debt?',
    answerHtml: `<b>No — always clear high-interest debt before overpaying your mortgage or investing.</b> Credit cards (18-25% APR), personal loans (6-12% APR), and store credit all charge significantly more interest than a mortgage (typically 3-6% APR). Every pound you overpay on a 4.5% mortgage while carrying 20% credit card debt is costing you 15.5% per year in net terms. The correct order is: (1) clear high-interest debt, (2) build a 3-6 month emergency fund, (3) then decide between mortgage overpayment and ISA investing. This calculator assumes you have no higher-interest debt.`,
    answerText: 'Always clear high-interest debt (credit cards, personal loans) before overpaying your mortgage or investing. The interest rate on other debt is almost always higher than your mortgage rate.'
  },
  {
    question: 'How does the UK ISA allowance affect my mortgage vs investing decision?',
    answerHtml: `<b>The UK ISA allowance is £20,000 per tax year (2024/25) and is use-it-or-lose-it.</b> If your monthly surplus exceeds approximately £1,667, you will hit the annual ISA limit and any excess must go into a taxable account — where capital gains and dividend tax apply. This changes the maths significantly: ISA investments are completely tax-free, while taxable accounts lose 10-20% of returns to tax over time. For most UK homeowners with a surplus under £1,667/month, the ISA wrapper makes investing more competitive against mortgage overpayment. If you max out your ISA each year, the tax-free advantage is substantial and favours investing even more strongly.`,
    answerText: 'The UK ISA allowance is £20,000/year. If your surplus is under £1,667/month, you can invest it all tax-free. ISAs are use-it-or-lose-it, so maxing your allowance before overpaying may be optimal.'
  },
  {
    question: 'What is the break-even mortgage rate for overpaying vs investing?',
    answerHtml: `<b>The break-even point is when your mortgage interest rate equals your expected after-tax ISA return.</b> If your mortgage rate is 4.5% and you expect 7% ISA returns, the spread is 2.5% in favour of investing. However, this ignores risk: the 4.5% mortgage saving is guaranteed, while the 7% return is not. A common rule of thumb: if your mortgage rate is more than 2% below your expected ISA return, investing usually wins over a 10+ year horizon. If the spread is less than 1%, overpaying is often preferred because the guaranteed return and psychological benefit outweigh the small expected advantage. Use this calculator with your exact numbers to find your personal break-even.`,
    answerText: 'The break-even is when your mortgage rate equals your expected ISA return. If your mortgage rate is 2%+ below expected ISA returns, investing usually wins over 10+ years. Below 1% spread, overpaying is often preferred.'
  }
];
---

<PageLayout
  title="Mortgage Overpayment vs Investing Calculator UK — ISA Tracker"
  description="Should you overpay your UK mortgage or invest in a Stocks &amp; Shares ISA? Use our dynamic calculator to compare guaranteed debt returns vs compound stock returns."
  canonical="https://truefinancetools.com/mortgage-overpayment-vs-investing-calculator-uk"
  ogImage="https://truefinancetools.com/og-mortgage-overpayment-vs-investing-calculator-uk.png"
  ogImageAlt="UK Mortgage Overpayment vs ISA Investing Calculator — Compare strategies"
  pageType="website"
  keywords="mortgage overpayment calculator UK, overpay mortgage or invest ISA, UK mortgage vs stocks and shares ISA, mortgage overpayment vs investing calculator uk, mortgage early repayment UK, ISA investing vs mortgage payoff"
>
  <StructuredData
    title="UK Mortgage Overpayment vs ISA Investing Calculator"
    description="Should you overpay your UK mortgage or invest in a Stocks &amp; Shares ISA? Compare guaranteed debt returns vs compound stock returns."
    url="https://truefinancetools.com/mortgage-overpayment-vs-investing-calculator-uk"
    features={[
      'Compare mortgage overpayment vs ISA investing strategies',
      'Interactive Chart.js visualisation of net worth over time',
      'Year-by-year projection table for both strategies',
      'UK-specific with GBP formatting and ISA tax-free wrapper modelling',
      'Early repayment charge awareness and overpayment limit guidance',
    ]}
    faqItems={toolFaqItems}
  />

  <!-- Hero Section -->
  <section class="border-b border-hairline bg-canvas py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h1 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl" style="letter-spacing: -0.02em;">
        UK Mortgage Overpayment vs ISA Investing Calculator
      </h1>
      <p class="text-lg text-body">Compare two strategies: overpay your mortgage early or invest your surplus in a tax-free Stocks &amp; Shares ISA.</p>
    </div>
  </section>

  <!-- What is Mortgage Overpayment vs ISA Investing? -->
  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink">What is Mortgage Overpayment vs ISA Investing?</h2>
      <div class="prose prose-gray max-w-none text-body">
        <p><strong>Mortgage overpayment vs ISA investing</strong> is the decision of whether to use surplus cash to reduce your mortgage debt faster or invest it in a tax-free Stocks &amp; Shares ISA for potentially higher long-term returns. For UK homeowners, this is one of the most consequential financial decisions because mortgage interest is not tax-deductible for residential borrowers, while ISA gains and income are completely tax-free — creating a level playing field where the comparison comes down to raw returns.</p>

        <h3 class="mb-3 text-lg font-semibold text-ink">The Overpayment vs Investing Formula</h3>
        <div class="rounded-lg bg-canvas-soft-2 p-4 font-mono text-sm text-ink">
Mortgage Overpayment Return = Mortgage Interest Rate (guaranteed, risk-free)<br />
ISA Investment Return = Expected Annual Return − Fund Fees (variable, market-dependent)<br /><br />
Break-even: When ISA Return &gt; Mortgage Rate → Investing wins<br />
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;When ISA Return &lt; Mortgage Rate → Overpaying wins<br />
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;When ISA Return = Mortgage Rate → Tie (but overpaying is risk-free)
        </div>

        <h3 class="mb-3 mt-6 text-lg font-semibold text-ink">Mortgage Overpayment vs ISA Investing</h3>
        <div class="overflow-x-auto rounded-lg border border-hairline">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="p-3 font-medium text-ink">Factor</th>
                <th class="p-3 font-medium text-ink">Mortgage Overpayment</th>
                <th class="p-3 font-medium text-ink">ISA Investing</th>
              </tr>
            </thead>
            <tbody class="font-mono text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Return Type</td>
                <td class="p-3 text-ink">Guaranteed (interest saved)</td>
                <td class="p-3 text-ink">Variable (market returns)</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Risk Level</td>
                <td class="p-3 text-success-deep">Zero risk</td>
                <td class="p-3 text-ink">Market risk</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Tax Treatment (UK)</td>
                <td class="p-3 text-ink">Not tax-deductible</td>
                <td class="p-3 text-success-deep">ISA gains are tax-free</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Liquidity</td>
                <td class="p-3 text-ink">Low (locked in property)</td>
                <td class="p-3 text-success-deep">High (accessible anytime)</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Psychological Benefit</td>
                <td class="p-3 text-success-deep">Debt-free earlier</td>
                <td class="p-3 text-ink">Growing wealth visible</td>
              </tr>
              <tr class="bg-success/5">
                <td class="p-3 text-body font-sans">Best When</td>
                <td class="p-3 font-semibold text-success-deep">Risk-averse / high mortgage rate</td>
                <td class="p-3 font-semibold text-link">Long horizon / low mortgage rate</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Who Should Choose Each Strategy?</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Risk-Averse Homeowners</h4>
            <p class="text-sm text-body">If the thought of market volatility keeps you up at night, overpaying your mortgage provides a guaranteed return equal to your mortgage interest rate. The psychological comfort of being debt-free earlier has a real wellbeing value that spreadsheets cannot capture.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Long-Term Investors (15+ Years)</h4>
            <p class="text-sm text-body">If your mortgage has more than 15 years remaining, the compounding power of a Stocks &amp; Shares ISA has more time to outpace the guaranteed mortgage savings. Historical equity returns (7-10% annually) have typically beaten mortgage rates over long horizons.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">FIRE Enthusiasts</h4>
            <p class="text-sm text-body">If you are optimising for maximum net worth at a specific FIRE date, this calculator shows you exactly which strategy builds more wealth. The redirect effect — investing freed-up mortgage payments after early payoff — can be the deciding factor.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Short Mortgage Term (&lt; 5 Years)</h4>
            <p class="text-sm text-body">If your mortgage has fewer than 5 years remaining, the ISA compounding advantage is minimal. Overpaying to clear the debt and then redirecting the full budget into investments for the remaining years often wins in this scenario.</p>
          </div>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Mortgage Overpayment vs ISA Investing Pros and Cons</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-success/30 bg-success/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-success-deep">Advantages of Overpaying</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Guaranteed return equal to your mortgage interest rate</li>
              <li>• Zero market risk — the saving is certain</li>
              <li>• Psychological benefit of being debt-free years earlier</li>
              <li>• Forced savings discipline — money goes to debt reduction</li>
              <li>• Reduced total interest paid over the mortgage term</li>
            </ul>
          </div>
          <div class="rounded-lg border border-error/30 bg-error/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-error">Trade-offs of Overpaying</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Lower expected long-term return than equity investing</li>
              <li>• Money is locked in the property — low liquidity</li>
              <li>• Opportunity cost if markets perform strongly</li>
              <li>• UK lenders may cap overpayments at 10% per year</li>
              <li>• No tax advantage — mortgage interest is not deductible</li>
            </ul>
          </div>
          <div class="rounded-lg border border-success/30 bg-success/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-success-deep">Advantages of ISA Investing</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Higher expected long-term return (historically 7-10%)</li>
              <li>• ISA wrapper makes all gains completely tax-free</li>
              <li>• Full liquidity — access your money anytime</li>
              <li>• Compound growth accelerates over long time horizons</li>
              <li>• Diversification across assets and geographies</li>
            </ul>
          </div>
          <div class="rounded-lg border border-error/30 bg-error/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-error">Trade-offs of ISA Investing</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Market risk — returns are not guaranteed</li>
              <li>• Requires discipline to stay invested during downturns</li>
              <li>• No guaranteed return — could underperform mortgage rate</li>
              <li>• Emotional stress during bear markets</li>
              <li>• Annual ISA allowance limits tax-free contributions</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calculator -->
  <MortgageVsIsaCalculator />

  <!-- How It Works -->
  <HowItWorks title="How the Mortgage Overpayment vs Investing Calculator Works">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">1. Enter Your Mortgage Details</h3>
      <p class="text-sm text-body">Input your current mortgage balance, remaining term, interest rate, monthly surplus, and expected ISA return to set up the comparison.</p>
    </div>
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">2. Compare Two Strategies</h3>
      <p class="text-sm text-body">Strategy A invests your surplus into a tax-free ISA from day one. Strategy B overpays the mortgage first, then redirects the full budget into an ISA once the mortgage is cleared.</p>
    </div>
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">3. See the Winner</h3>
      <p class="text-sm text-body">View the net worth comparison, interest saved, years shaved off your mortgage, and interactive chart showing both strategies over time.</p>
    </div>
  </HowItWorks>

  <!-- ERC Warning Callout -->
  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div class="rounded-lg border border-warning/30 bg-warning-soft p-6">
        <div class="mb-3 flex items-center gap-2">
          <svg class="h-5 w-5 text-warning" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
          </svg>
          <h3 class="text-lg font-semibold text-warning">UK Overpayment Limits &amp; Early Repayment Charges</h3>
        </div>
        <div class="prose prose-gray max-w-none text-body">
          <p class="mb-3">
            <strong>Most UK fixed-rate mortgages cap penalty-free overpayments at 10% of the outstanding balance per year.</strong> For example, on a £200,000 mortgage, you could typically overpay up to £20,000 per year without triggering Early Repayment Charges (ERCs).
          </p>
          <p class="mb-3">
            ERCs typically range from <strong>1-5% of the overpaid amount</strong>, depending on how many years remain on your fixed rate. On a £30,000 overpayment with a 3% ERC, you would pay £900 in charges — potentially wiping out the interest saving benefit.
          </p>
          <p>
            This calculator assumes unlimited overpayments for mathematical simplicity. <strong>Always check your mortgage terms</strong> and factor in any ERCs before implementing either strategy. If you are within a fixed-rate period, the 10% annual limit is a hard constraint on Strategy B.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {toolFaqItems.map((item) => (
          <details class="group rounded-lg border border-hairline bg-canvas p-4 shadow-sm">
            <summary class="cursor-pointer py-2 text-sm font-medium text-ink">{item.question}</summary>
            <p class="mt-3 text-sm text-body" set:html={item.answerHtml} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Complete Guide to Mortgage Overpayment vs ISA Investing -->
  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight text-ink">Complete Guide to Mortgage Overpayment vs ISA Investing</h2>
      <div class="prose prose-gray max-w-none text-body">
        <p>
          Our <strong>UK mortgage overpayment vs ISA investing calculator</strong> helps you make one of the most important financial decisions UK homeowners face. Whether you have a 2-year fixed rate coming to an end or a 25-year repayment mortgage, understanding the mathematical trade-off between debt reduction and wealth accumulation is essential for long-term financial planning.
        </p>
        <h3 class="mb-3 text-lg font-semibold text-ink">Why Choose This Calculator?</h3>
        <p>
          Unlike simple "interest saved" calculators, our tool models the full opportunity cost of each strategy. It accounts for the compounding power of redirecting freed-up mortgage payments into tax-free ISA investments after early payoff, giving you a complete picture of both pathways. The interactive chart and year-by-year table make it easy to visualise how each strategy performs over time, helping you make a confident, data-driven decision.
        </p>
        <p>
          The calculator is specifically designed for UK investors, using GBP formatting and the ISA tax-free wrapper as the investment vehicle. Whether you are a member of the FIRE community optimising your path to financial independence or a homeowner looking to clear your mortgage efficiently, this tool provides the clarity you need.
        </p>
        <h3 class="mb-3 text-lg font-semibold text-ink">Key Features of This Calculator</h3>
        <p>
          The tool features interactive sliders and input fields for all five key parameters, a real-time winner declaration, side-by-side KPI comparison cards, an interactive Chart.js line chart with dark mode support, and a collapsible year-by-year projection table. All calculations run entirely in your browser with no data sent to any server, ensuring complete privacy for your financial information.
        </p>
      </div>
    </div>
  </section>

  <!-- Explore Other Financial Tools -->
  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h2 class="mb-4 text-2xl font-semibold tracking-tight text-ink">Explore Other Financial Tools</h2>
      <p class="mb-8 text-body">Use our free calculators to plan your path to financial independence.</p>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/sequence-of-returns-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Sequence of Returns Risk</h3>
          <p class="text-xs text-body">Stress-test your portfolio against historical market crashes.</p>
        </a>
        <a href="/coast-fire-number" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Coast FIRE Number</h3>
          <p class="text-xs text-body">Find out how much you need saved today to retire on time.</p>
        </a>
        <a href="/perpetual-swr-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Perpetual SWR Calculator</h3>
          <p class="text-xs text-body">Calculate a safe withdrawal rate that lasts forever.</p>
        </a>
        <a href="/cash-cushion-optimizer" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Cash Cushion Optimizer</h3>
          <p class="text-xs text-body">Optimise your emergency fund vs equity allocation.</p>
        </a>
        <a href="/vpw-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">VPW Calculator</h3>
          <p class="text-xs text-body">Variable percentage withdrawal for mathematically guaranteed income.</p>
        </a>
        <a href="/fire-calculator" class="group rounded-lg border-2 border-ink bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">FIRE Calculator</h3>
          <p class="text-xs text-body">Calculate your FIRE number and years to financial independence.</p>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
