---
import PageLayout from '../../layouts/PageLayout.astro';
import FIRECalculatorBase from '../../components/calculator/FIRECalculatorBase.astro';
import HowItWorks from '../../components/ui/HowItWorks.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import type { FAQItem } from '../../utils/faq-data';

const fireFaqItems: FAQItem[] = [
  {
    question: 'What is FIRE and how does it work?',
    answerHtml: '<b>FIRE</b> stands for <b>Financial Independence, Retire Early</b>. It is a movement focused on saving aggressively—typically 50–70% of your income—so you can retire decades earlier than the traditional retirement age of 65.<br /><br />The core idea is simple: save enough money that your investment portfolio can cover your living expenses indefinitely. The most common rule is the <b>4% rule</b> (also called the 25x rule): save 25 times your annual expenses, then withdraw 4% per year in retirement. At that rate, historical data shows your portfolio has a very high probability of lasting 30+ years.',
    answerText: 'FIRE stands for Financial Independence, Retire Early. Save aggressively (50-70% of income) until your portfolio reaches 25x your annual expenses, then retire early and withdraw 4% per year. Your investments cover your living costs indefinitely.',
  },
  {
    question: 'How is the FIRE number calculated?',
    answerHtml: 'The standard FIRE formula is:<br /><br /><b>FIRE Number = Annual Expenses × 25</b><br /><br />This is based on the <b>4% rule</b> from the Trinity Study, which found that a portfolio of 60% stocks and 40% bonds has a high probability of lasting 30+ years if you withdraw 4% of the initial portfolio value each year (adjusted for inflation).<br /><br /><b>Example:</b> If you spend $50,000 per year:<br />• FIRE Number: $50,000 × 25 = <b>$1,250,000</b><br />• Annual withdrawal: $1,250,000 × 4% = <b>$50,000</b><br /><br />The multiplier varies by FIRE type: Lean FIRE uses 20x, Regular uses 25x, and Fat FIRE uses 30x. Coast FIRE and Barista FIRE use modified formulas that account for future growth or part-time income.',
    answerText: 'FIRE Number = Annual Expenses × 25 (the 4% rule). Example: $50K expenses × 25 = $1.25M needed. Withdraw 4% per year ($50K). Multiplier varies: 20x for Lean FIRE, 25x for Regular, 30x for Fat FIRE.',
  },
  {
    question: 'What are the different types of FIRE?',
    answerHtml: 'There are five main FIRE strategies, each with different savings targets and lifestyle trade-offs:<br /><br /><ul><li><b>Lean FIRE (20x expenses):</b> Minimalist approach. Retire on a tight budget. Best for digital nomads, minimalists, and low cost-of-living areas.</li><li><b>Regular FIRE (25x expenses):</b> The standard approach. Comfortable middle-class retirement with a 4% withdrawal rate.</li><li><b>Fat FIRE (30x expenses):</b> Luxury approach. Maintain your high-spending lifestyle with maximum safety margin.</li><li><b>Barista FIRE:</b> Hybrid approach. Save enough to cover most expenses, then work part-time to cover the rest. Dramatically lowers your target.</li><li><b>Coast FIRE:</b> Time-based approach. Save enough early that compound interest alone grows your portfolio to your target by retirement age.</li></ul>',
    answerText: 'Five main FIRE types: Lean FIRE (20x, minimalist), Regular FIRE (25x, standard), Fat FIRE (30x, luxury), Barista FIRE (part-time work + investments), and Coast FIRE (compound interest does the work). Each has different trade-offs between savings and lifestyle.',
  },
  {
    question: 'Which FIRE type is right for me?',
    answerHtml: 'The right FIRE type depends on your values, lifestyle, and financial situation:<br /><br /><ul><li>Choose <b>Lean FIRE</b> if you value time over money, are comfortable with minimalism, and want to retire as quickly as possible.</li><li>Choose <b>Regular FIRE</b> if you want a comfortable, standard retirement without lifestyle compromise.</li><li>Choose <b>Fat FIRE</b> if you are a high earner ($150K+) and want to maintain your lifestyle with maximum financial security.</li><li>Choose <b>Barista FIRE</b> if you enjoy working but on your own terms, and want to dramatically reduce your savings target with part-time income.</li><li>Choose <b>Coast FIRE</b> if you are young (20s-30s) and want to know when you can stop aggressive saving and pursue lower-stress work.</li></ul><br />Our FIRE calculator lets you compare all five strategies side by side. Toggle between them to see how each changes your target and timeline.',
    answerText: 'Choose Lean FIRE for speed, Regular for comfort, Fat for luxury, Barista for part-time flexibility, and Coast for compound-interest leverage. Use the calculator to compare all five side by side.',
  },
  {
    question: 'How does the 4% rule work in retirement?',
    answerHtml: 'The <b>4% rule</b> says you can withdraw 4% of your initial portfolio value in your first year of retirement, then adjust that amount for inflation each subsequent year. For a $1,000,000 portfolio:<br /><br /><ul><li>Year 1: Withdraw <b>$40,000</b></li><li>Year 2: Withdraw $40,000 × (1 + inflation rate), e.g., $41,200 at 3% inflation</li><li>Year 3: Withdraw $42,436 (continuing inflation adjustments)</li></ul><br />The rule comes from the <b>Trinity Study</b>, which analyzed historical market returns from 1926-1995 and found that a 60/40 stock/bond portfolio with a 4% withdrawal rate survived 30-year retirements in over 95% of historical scenarios.<br /><br />Important caveats: the 4% rule is a <b>guideline, not a guarantee</b>. If you plan to retire very early (40+ year retirement) or want more safety, use 3-3.5% instead. Our calculator lets you customize your withdrawal rate.',
    answerText: 'The 4% rule: withdraw 4% of your portfolio in year one, adjust for inflation annually. From the Trinity Study: 60/40 portfolio survived 30+ years in 95%+ of historical scenarios. For extra safety or longer retirements, use 3-3.5%.',
  },
  {
    question: 'How does inflation affect my FIRE plan?',
    answerHtml: 'Inflation is one of the biggest risks to any FIRE plan. Here is how it affects your numbers and how our calculator handles it:<br /><br /><ul><li><b>Portfolio growth:</b> The historical S&P 500 return is ~10% nominal, but ~7% after inflation. Our calculator uses inflation-adjusted returns so all projections are in today\'s dollars.</li><li><b>Expenses rise:</b> What costs $50,000 today will cost ~$67,000 in 10 years at 3% inflation. The calculator accounts for this automatically.</li><li><b>Withdrawal adjustments:</b> The 4% rule already includes inflation adjustments—you withdraw more each year to maintain purchasing power.</li><li><b>Safety buffer:</b> Using a 7% return assumption (not 10%) builds in a 3% inflation buffer. For extra safety, use our conservative scenario settings.</li></ul><br />The default settings in our FIRE calculator (7% returns, 3% inflation) are designed to give you realistic, inflation-adjusted projections.',
    answerText: 'Inflation erodes purchasing power over time. Our calculator accounts for this by using inflation-adjusted returns (7% = 10% historical minus 3% inflation). The 4% rule also adjusts withdrawals for inflation annually.',
  },
  {
    question: 'Can I use this FIRE calculator for Barista FIRE or Coast FIRE?',
    answerHtml: 'Yes! Our FIRE calculator supports five strategies:<br /><br /><ul><li><b>FIRE Type selector:</b> Toggle between Lean, Regular, Fat, Barista, and Coast FIRE modes. Each adjusts the calculation formula automatically.</li><li><b>Barista FIRE mode:</b> Adds a part-time income slider. Your target = (expenses − part-time income) × 25. The higher your part-time income, the less you need to save.</li><li><b>Coast FIRE mode:</b> Shows the lump sum needed today so your current savings grow to your full FIRE number by retirement age, with zero additional contributions.</li></ul><br />For dedicated versions with more detailed content, visit our <a href="/barista-fire-calculator">Barista FIRE Calculator</a> or <a href="/coast-fire-number">Coast FIRE Calculator</a> pages.',
    answerText: 'Yes. Use the FIRE Type selector to toggle between Lean, Regular, Fat, Barista (adds part-time income), and Coast (shows lump sum needed today) modes. Dedicated pages available for Barista and Coast FIRE.',
  },
  {
    question: 'What savings rate do I need to reach FIRE?',
    answerHtml: 'Your savings rate is the single biggest factor determining how long it takes to reach FIRE. Here is how different savings rates affect your timeline (assuming 7% returns, retirement at your FIRE number):<br /><br /><ul><li><b>10% savings rate</b> → ~49 years to FIRE</li><li><b>20% savings rate</b> → ~35 years to FIRE</li><li><b>30% savings rate</b> → ~27 years to FIRE</li><li><b>40% savings rate</b> → ~21 years to FIRE</li><li><b>50% savings rate</b> → ~16 years to FIRE</li><li><b>60% savings rate</b> → ~12 years to FIRE</li><li><b>70% savings rate</b> → ~9 years to FIRE</li></ul><br />The key insight: doubling your savings rate from 25% to 50% cuts your working career roughly in half. This is why FIRE enthusiasts focus on savings rate far more than investment returns. Our calculator lets you adjust your savings rate and see exactly how it changes your timeline.',
    answerText: 'Savings rate drives FIRE speed. 10% = ~49 years, 30% = ~27 years, 50% = ~16 years, 70% = ~9 years. Doubling your savings rate roughly halves your time to FIRE. Use the calculator to find your exact timeline.',
  },
];
---

<PageLayout
  title="FIRE Calculator — Best Free Retirement Calculator for Financial Independence"
  description="Free FIRE calculator for planning early retirement. Calculate your fire number with coast, barista, lean, and fat fire strategies. Interactive charts and instant results."
  canonical="https://truefinancetools.com/fire-calculator/"
  ogImage="https://truefinancetools.com/og-fire-calculator.png"
  ogImageAlt="FIRE Calculator — Calculate Your Path to Financial Independence"
  pageType="website"
  keywords="FIRE calculator, barista fire calculator, fire calculator retirement, fat fire calculator, best fire calculator, lean fire calculator, retirement calculator"
>
  <StructuredData
    title="FIRE Calculator — Best Free Retirement Calculator for Financial Independence"
    description="Use our free FIRE calculator to plan early retirement. Calculate your FIRE number with coast, barista, lean, and fat fire strategies. Interactive charts and instant results."
    url="https://truefinancetools.com/fire-calculator/"
    toolName="FIRE Calculator"
    toolDescription="Calculate your FIRE number with coast FIRE, barista FIRE, lean FIRE, and fat FIRE strategies to plan your financial independence and early retirement."
    faqItems={fireFaqItems}
    features={[
      'Five FIRE type comparison (Lean, Regular, Fat, Barista, Coast)',
      'Interactive projection charts',
      'PDF export and shareable links',
      'Scenario comparison across all FIRE types',
      'Part-time income and Coast FIRE modeling'
    ]}
  />

  <section class="border-b border-hairline bg-canvas py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h1 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl" style="letter-spacing: -0.02em;">
        FIRE Calculator
      </h1>
      <p class="text-lg text-body">Plan your path to financial independence. Compare Lean, Regular, Fat, Barista, and Coast FIRE.</p>
    </div>
  </section>

  <script is:inline>
    (function() {
      var params = new URLSearchParams(window.location.search);
      if (params.get('fireType') === 'barista') {
        var link = document.createElement('link');
        link.rel = 'canonical';
        link.href = 'https://truefinancetools.com/barista-fire-calculator';
        document.head.appendChild(link);
      }
    })();
  </script>

  <FIRECalculatorBase />

  <HowItWorks title="How the FIRE Calculator Works">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">1. Enter Your Details</h3>
      <p class="text-sm text-body">Input your age, income, savings, and expenses to get started.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">2. See Your Results</h3>
      <p class="text-sm text-body">Get instant calculations with interactive charts showing your path to FIRE.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">3. Plan & Export</h3>
      <p class="text-sm text-body">Compare scenarios, export your plan as PDF, or share with friends.</p>
    </div>
  </HowItWorks>

  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        What is FIRE?
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <p class="mb-4">
          <strong>FIRE</strong> stands for <strong>Financial Independence, Retire Early</strong>. It is a lifestyle movement where you save aggressively—often 50–70% of your income—so you can retire decades earlier than the traditional retirement age of 65. The core principle is simple: build a portfolio large enough that your investments generate enough income to cover your living expenses indefinitely.
        </p>

        <p class="mb-4">
          The most common rule is the <strong>4% rule</strong> (also called the 25x rule): save 25 times your annual expenses, then withdraw 4% of your portfolio each year. Historical data shows that a diversified portfolio can sustain 30+ years of retirement at that withdrawal rate. Our <strong>FIRE calculator</strong> uses this proven methodology to help you plan your path to financial freedom.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">The FIRE Formula</h3>
        <div class="rounded-lg bg-canvas-soft-2 p-4 font-mono text-sm text-ink">
          FIRE Number = Annual Expenses × 25
        </div>

        <p class="mb-4 mt-4">
          For example, if you spend $50,000 per year: $50,000 × 25 = <strong>$1,250,000</strong>. At a 4% withdrawal rate, your portfolio generates $50,000 in your first year of retirement, adjusted for inflation each year after. The multiplier varies by FIRE type: Lean FIRE uses 20x, Regular uses 25x, and Fat FIRE uses 30x.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">FIRE Strategies Side by Side</h3>
        <div class="overflow-x-auto rounded-lg border border-hairline">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="p-3 font-medium text-ink">Strategy</th>
                <th class="p-3 font-medium text-ink">Multiplier</th>
                <th class="p-3 font-medium text-ink">Target ($50K expenses)</th>
                <th class="p-3 font-medium text-ink">Work Required</th>
              </tr>
            </thead>
            <tbody class="font-mono text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Lean FIRE</td>
                <td class="p-3 text-ink">20x</td>
                <td class="p-3 text-ink">$1,000,000</td>
                <td class="p-3 text-ink">None</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Regular FIRE</td>
                <td class="p-3 text-ink">25x</td>
                <td class="p-3 font-semibold text-ink">$1,250,000</td>
                <td class="p-3 text-ink">None</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Fat FIRE</td>
                <td class="p-3 text-ink">30x</td>
                <td class="p-3 text-ink">$1,500,000</td>
                <td class="p-3 text-ink">None</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Barista FIRE</td>
                <td class="p-3 text-ink">(Expenses − PT Income) × 25</td>
                <td class="p-3 text-ink">$750,000</td>
                <td class="p-3 text-ink">Part-time</td>
              </tr>
              <tr class="bg-success/5">
                <td class="p-3 text-body font-sans">Coast FIRE</td>
                <td class="p-3 text-ink">Future value discounted</td>
                <td class="p-3 font-semibold text-success-deep">$276,000</td>
                <td class="p-3 text-ink">Optional</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Who Should Choose FIRE?</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Early Retirees</h4>
            <p class="text-sm text-body">Anyone who wants to stop working in their 40s, 50s, or earlier. FIRE gives you the framework to calculate exactly how much you need and how long it will take.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">High-Income Professionals</h4>
            <p class="text-sm text-body">Doctors, lawyers, engineers, and other high earners who can save 50%+ of their income. Your high savings rate accelerates your timeline dramatically.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Young Professionals</h4>
            <p class="text-sm text-body">People in their 20s and 30s who start early. Compound interest works hardest for you. Even modest savings today grow into significant retirement funds.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Lifestyle Designers</h4>
            <p class="text-sm text-body">Those who want freedom over their time—whether to travel, start a business, spend time with family, or pursue passion projects without financial pressure.</p>
          </div>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">FIRE Pros and Cons</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-success/30 bg-success/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-success-deep">Advantages</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Freedom to retire decades early</li>
              <li>• Control over your time and lifestyle</li>
              <li>• Financial security and peace of mind</li>
              <li>• Ability to pursue passion projects</li>
              <li>• Multiple strategy options for different goals</li>
              <li>• Compound interest works for you, not against you</li>
            </ul>
          </div>
          <div class="rounded-lg border border-error/30 bg-error/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-error">Trade-offs</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Requires high savings rate during working years</li>
              <li>• Market downturns affect portfolio sustainability</li>
              <li>• Inflation erodes purchasing power over time</li>
              <li>• Healthcare costs before Medicare eligibility</li>
              <li>• Sequence-of-returns risk in early retirement</li>
              <li>• May require lifestyle flexibility in lean years</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Frequently Asked Questions About FIRE
      </h2>

      <div class="space-y-4">
        {fireFaqItems.map((item) => (
          <details class="group rounded-lg border border-hairline bg-canvas p-4 shadow-sm">
            <summary class="cursor-pointer py-2 text-sm font-medium text-ink">{item.question}</summary>
            <p class="mt-3 text-sm text-body" set:html={item.answerHtml} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Complete Guide to Using Our FIRE Calculator
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <p class="mb-4">
          Our <strong>FIRE calculator</strong> is the most comprehensive free tool available for planning early retirement. Whether you are exploring <strong>Lean FIRE</strong> with minimal expenses, <strong>Regular FIRE</strong> for comfortable living, <strong>Fat FIRE</strong> for luxury retirement, <strong>Barista FIRE</strong> with part-time work, or <strong>Coast FIRE</strong> to let compound interest work for you, this calculator provides accurate, instant projections tailored to your financial goals.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">Why Use Our FIRE Calculator?</h3>

        <p class="mb-4">
          Unlike other <strong>fire calculator retirement</strong> tools that require email signups or hide features behind paywalls, our calculator is 100% free and private. All calculations happen in your browser—no data is stored on our servers. Adjust your savings rate, expected returns, or retirement age and see results update instantly with beautiful interactive charts. Toggle between all five FIRE types to compare strategies side by side.
        </p>

        <p class="mb-4">
          The scenario comparison feature lets you test multiple strategies simultaneously, helping you make informed decisions about your financial future. Whether you see how a higher savings rate accelerates your timeline, compare the impact of part-time income in Barista FIRE, or calculate the Coast FIRE threshold where compound interest takes over, this tool gives you the clarity you need.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">Key Features of This FIRE Calculator</h3>

        <p class="mb-4">
          Export your personalized FIRE plan as a PDF to review offline, share your projection with your partner via a unique link, or save your progress for future reference. The interactive chart shows your portfolio growth trajectory, your FIRE target line, and how different strategies compare. Theme-aware Chart.js rendering automatically adapts to dark mode for comfortable viewing at any time of day.
        </p>

        <p class="mb-4">
          Whether you are just discovering the FIRE movement or are a seasoned early retiree optimizing your withdrawal strategy, our calculator provides the accurate projections you need. Start planning your path to financial independence today—no signup required, completely free, and results in seconds.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h2 class="mb-4 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Explore Other FIRE Strategies
      </h2>
      <p class="mb-8 text-body">Compare different approaches to find the right one for your lifestyle.</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/lean-fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Lean FIRE Calculator</h3>
          <p class="text-xs text-body">Minimalist approach with the 20x rule for early retirement.</p>
        </a>
        <a href="/fat-fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Fat FIRE Calculator</h3>
          <p class="text-xs text-body">For those who want a luxury retirement lifestyle.</p>
        </a>
        <a href="/barista-fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Barista FIRE Calculator</h3>
          <p class="text-xs text-body">Work part-time, let investments cover the rest.</p>
        </a>
        <a href="/coast-fire-number" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Coast FIRE Number</h3>
