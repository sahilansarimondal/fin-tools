---
import PageLayout from '../../layouts/PageLayout.astro';
import FIRECalculatorBase from '../../components/calculator/FIRECalculatorBase.astro';
import HowItWorks from '../../components/ui/HowItWorks.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import { faqItems } from '../../utils/faq-data';
---

<PageLayout
  title="FIRE Calculator — Best Free Retirement Calculator for Financial Independence"
  description="Use our free FIRE calculator to plan early retirement. Calculate your FIRE number with coast, barista, lean, and fat fire strategies. Interactive charts and instant results."
  canonical="https://truefinancetools.com/fire-calculator/"
  ogImage="https://truefinancetools.com/og-fire-calculator.png"
  ogImageAlt="FIRE Calculator - Calculate Your Path to Financial Independence"
  pageType="article"
  keywords="FIRE calculator, barista fire calculator, fire calculator retirement, fat fire calculator, best fire calculator, lean fire calculator, retirement calculator"
>
    <StructuredData
      title="FIRE Calculator — Best Free Retirement Calculator for Financial Independence"
      description="Use our free FIRE calculator to plan early retirement. Calculate your FIRE number with coast, barista, lean, and fat fire strategies. Interactive charts and instant results."
      url="https://truefinancetools.com/fire-calculator/"
      toolName="FIRE Calculator"
      toolDescription="Calculate your FIRE number with coast FIRE, barista FIRE, lean FIRE, and fat FIRE strategies to plan your financial independence and early retirement."
    />

    <script is:inline>
      (function() {
        var params = new URLSearchParams(window.location.search);
        if (params.get('fireType') === 'barista') {
          var link = document.createElement('link');
          link.rel = 'canonical';
          link.href = 'https://truefinancetools.com/barista-fire-calculator';
          document.head.appendChild(link);
        }
      })();
    </script>

    <FIRECalculatorBase />

    <HowItWorks title="How the FIRE Calculator Works">
      <div class="text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="mb-2 text-sm font-semibold text-ink">1. Enter Your Details</h3>
        <p class="text-sm text-body">Input your age, income, savings, and expenses to get started.</p>
      </div>

      <div class="text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
        </div>
        <h3 class="mb-2 text-sm font-semibold text-ink">2. See Your Results</h3>
        <p class="text-sm text-body">Get instant calculations with interactive charts showing your path to FIRE.</p>
      </div>

      <div class="text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
          <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </div>
        <h3 class="mb-2 text-sm font-semibold text-ink">3. Plan & Export</h3>
        <p class="text-sm text-body">Compare scenarios, export your plan as PDF, or share with friends.</p>
      </div>
    </HowItWorks>

    <section class="border-t border-hairline bg-canvas-soft py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
          Understanding FIRE Types
        </h2>

        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-lg border border-hairline bg-canvas p-6 shadow-sm">
            <h3 class="mb-2 text-lg font-semibold text-ink">Lean FIRE</h3>
            <p class="mb-3 text-sm text-body">Minimalist approach with lower expenses. Requires 20x annual expenses saved.</p>
            <p class="text-xs text-mute">Best for: Minimalists, digital nomads, low cost-of-living areas.</p>
          </div>

          <div class="rounded-lg border-2 border-ink bg-canvas p-6 shadow-sm">
            <h3 class="mb-2 text-lg font-semibold text-ink">Regular FIRE</h3>
            <p class="mb-3 text-sm text-body">Comfortable middle-class lifestyle. Requires 25x annual expenses saved.</p>
            <p class="text-xs text-mute">Best for: Most people seeking financial independence.</p>
          </div>

          <div class="rounded-lg border border-hairline bg-canvas p-6 shadow-sm">
            <h3 class="mb-2 text-lg font-semibold text-ink">Fat FIRE</h3>
            <p class="mb-3 text-sm text-body">Luxury lifestyle with higher expenses. Requires 30x annual expenses saved.</p>
            <p class="text-xs text-mute">Best for: High earners who want to maintain their lifestyle.</p>
          </div>

          <div class="rounded-lg border border-hairline bg-canvas p-6 shadow-sm">
            <h3 class="mb-2 text-lg font-semibold text-ink">Coast FIRE</h3>
            <p class="mb-3 text-sm text-body">Save enough early, then let compound interest do the work.</p>
            <p class="text-xs text-mute">Best for: Those who want to work optional jobs after hitting Coast number.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-t border-hairline bg-canvas py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
          Frequently Asked Questions
        </h2>

        <div class="space-y-4">
          {faqItems.map((item) => (
            <details class="group rounded-lg border border-hairline bg-canvas p-4 shadow-sm">
              <summary class="cursor-pointer py-2 text-sm font-medium text-ink">{item.question}</summary>
              <p class="mt-3 text-sm text-body" set:html={item.answerText} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="border-t border-hairline bg-canvas py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <h2 class="mb-6 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
          Complete Guide to Using Our FIRE Calculator
        </h2>
        
        <div class="prose prose-gray max-w-none text-body">
          <p class="mb-4">
            Our <strong>FIRE calculator</strong> is the most comprehensive free tool available for planning early retirement. Whether you're exploring <strong>Lean FIRE</strong> with minimal expenses, <strong>Regular FIRE</strong> for comfortable living, <strong>Fat FIRE</strong> for luxury retirement, or <strong>Coast FIRE</strong> to let compound interest work for you, this calculator provides accurate, instant projections tailored to your financial goals.
          </p>

          <h3 class="mb-3 text-lg font-semibold text-ink">Understanding Different FIRE Strategies</h3>
          
          <p class="mb-4">
            <strong>Lean FIRE Calculator:</strong> Perfect for minimalists and digital nomads who plan to live on $25,000-$40,000 annually. Our lean fire calculator shows you exactly how much you need to save—typically 20x your annual expenses—using conservative withdrawal rates for added security.
          </p>

          <p class="mb-4">
            <strong>Barista FIRE Calculator:</strong> A hybrid approach where you save enough to cover most expenses, then work part-time for benefits and extra income. Our barista fire calculator helps you determine the exact amount needed based on your projected part-time income and expenses.
          </p>

          <p class="mb-4">
            <strong>Fat FIRE Calculator:</strong> For high earners who want to maintain their current lifestyle in retirement. Our fat fire calculator uses 30x annual expenses as the target, ensuring you have enough for luxury travel, premium healthcare, and comfortable living.
          </p>

          <p class="mb-4">
            <strong>Coast FIRE Strategy:</strong> Calculates when you've saved enough that compound interest alone will grow your portfolio to your retirement number. This strategy shows the exact age you can stop aggressive saving and pursue passion projects or lower-stress work.
          </p>

          <h3 class="mb-3 text-lg font-semibold text-ink">Key Features of Our Best FIRE Calculator</h3>
          
          <p class="mb-4">
            Unlike other <strong>fire calculator retirement</strong> tools that require email signups or hide features behind paywalls, our calculator is 100% free and private. All calculations happen in your browser—no data is stored on our servers. Adjust your savings rate, expected returns, or retirement age and see results update instantly with beautiful interactive charts.
          </p>

          <p class="mb-4">
            Export your personalized FIRE plan as a PDF to review offline, share your projection with your partner via a unique link, or save your progress for future reference. The scenario comparison feature lets you test multiple strategies side by side, helping you make informed decisions about your financial future.
          </p>

          <p class="mb-4">
            Whether you're just discovering the FIRE movement or are a seasoned early retiree optimizing your withdrawal strategy, our calculator provides the accurate projections you need. Start planning your path to financial independence today—no signup required, completely free, and results in seconds.
          </p>
        </div>
      </div>
    </section>
</PageLayout>
