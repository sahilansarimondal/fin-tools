---
import PageLayout from '../../layouts/PageLayout.astro';
import UkRedundancyTaxCalculator from '../../components/calculator/UkRedundancyTaxCalculator.astro';
import HowItWorks from '../../components/ui/HowItWorks.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import type { FAQItem } from '../../utils/faq-data';

const toolFaqItems: FAQItem[] = [
  {
    question: 'Do you pay National Insurance on redundancy pay over £30,000?',
    answerHtml: '<b>No.</b> Qualifying redundancy pay is exempt from employee National Insurance at any amount. Even if your redundancy payment exceeds £30,000, the entire qualifying portion (including the excess over £30k) is free from employee NI. However, your employer must pay <b>15% Class 1A NI</b> on the portion exceeding £30,000 as an employer cost. Non-qualifying payments like PILON and holiday pay are subject to standard employee NI at your marginal rate.',
    answerText: 'No. Qualifying redundancy pay is exempt from employee NI at any amount. Employers pay 15% Class 1A NI on the excess over £30,000. Non-qualifying payments like PILON are subject to standard NI.',
  },
  {
    question: 'How can I reduce the tax on my redundancy package?',
    answerHtml: 'There are several legitimate ways to reduce your tax burden:<br /><br /><ul><li><b>Maximise the £30,000 exemption</b> — Negotiate to structure your package so as much as possible qualifies as genuine redundancy pay rather than taxable earnings.</li><li><b>Time your redundancy</b> — If possible, arrange for your termination to fall at the start of a new tax year (6 April) when your personal allowance resets.</li><li><b>Delay bonus payments</b> — Negotiate to push non-qualifying payments into the next tax year if your employer allows it.</li><li><b>Pension contributions</b> — Consider making additional pension contributions from the taxable portion to reduce your overall tax liability.</li><li><b>Salary sacrifice before redundancy</b> — Use salary sacrifice arrangements (e.g., pension, cycle to work, electric car schemes) before your termination date.</li></ul>Always consult a qualified tax adviser before making decisions about your redundancy package.',
    answerText: 'Legitimate ways to reduce redundancy tax: maximise the £30,000 exempt portion, time redundancy for a new tax year, delay bonus payments, make pension contributions from taxable income, and use salary sacrifice before termination. Consult a qualified tax adviser.',
  },
  {
    question: 'Is statutory redundancy pay always tax-free?',
    answerHtml: '<b>Yes.</b> Statutory redundancy pay is tax-free up to £30,000. This is the legal minimum paid by employers to eligible employees with 2+ years of service. The current statutory redundancy pay rate is:<br /><br /><ul><li><b>1.5 weeks\' pay</b> for each full year of service where you were aged 41 or over</li><li><b>1 week\'s pay</b> for each full year of service where you were aged 22–40</li><li><b>0.5 weeks\' pay</b> for each full year of service where you were aged under 22</li></ul>Statutory redundancy pay is capped at £643 per week (2026/27 rate) and a maximum of 20 years\' service counts. Only the portion exceeding £30,000 becomes taxable as income.',
    answerText: 'Yes, statutory redundancy pay is tax-free up to £30,000. It is calculated based on age and length of service, capped at £643 per week and 20 years. Only amounts over £30,000 total are taxable.',
  },
  {
    question: 'What happens if I get redundancy pay and start a new job in the same tax year?',
    answerHtml: 'Your redundancy pay is stacked on top of <b>all other earnings</b> in the same tax year. If you start a new job in the same year, both your new salary and redundancy pay contribute to your total taxable income. This combined income determines your tax bands, which can push you into a higher rate.<br /><br /><b>Example:</b> If you earn £40,000 in your old job, receive a £40,000 redundancy package (£30k exempt + £10k taxable), and earn £20,000 in a new job — your total taxable income is £40,000 + £10,000 + £20,000 = <b>£70,000</b>. This puts you in Higher Rate (40%) territory for some of your income.<br /><br />Planning your redundancy date relative to the tax year (6 April to 5 April) can help minimise this impact.',
    answerText: 'Your redundancy pay is stacked on top of all earnings in the tax year. If you start a new job, both salaries plus taxable redundancy determine your tax bands. Timing your redundancy relative to the tax year can minimise the impact.',
  },
  {
    question: 'Is Payment in Lieu of Notice (PILON) tax-free?',
    answerHtml: '<b>No.</b> Payment in Lieu of Notice (PILON) is treated as <b>taxable earnings</b>, not as a redundancy payment. It does <b>not</b> qualify for the £30,000 tax-free exemption.<br /><br />PILON represents the salary you would have earned during your notice period if you had worked it. HMRC treats it as normal earnings, which means:<br /><br /><ul><li>Subject to <b>income tax</b> at your marginal rate</li><li>Subject to <b>employee National Insurance</b> at 8% or 2%</li><li>Subject to <b>employer National Insurance</b> at 15%</li></ul>If your employer has a contractual PILON clause, any payment made under it is always taxable. Without a contractual clause, your employer may be able to make a PILON payment as an ex-gratia payment, which could qualify for the £30,000 exemption.',
    answerText: 'No. PILON is treated as taxable earnings, not redundancy. It does not qualify for the £30,000 exemption and is subject to income tax and both employer and employee National Insurance at standard rates.',
  },
  {
    question: 'Do voluntary redundancy payments get the same tax treatment?',
    answerHtml: '<b>Yes.</b> Whether your redundancy is compulsory or voluntary, the same £30,000 tax-free exemption applies to the qualifying portion. The key requirement is that the payment must be <b>genuinely connected to the termination of employment</b> and not a reward for past services.<br /><br />HMRC looks at the substance of the payment, not just the label. If you volunteer for redundancy and receive an enhanced package, any amount up to £30,000 of the qualifying portion is tax-free. The excess over £30,000 is taxable as employment income.<br /><br /><b>Important:</b> If your employer offers a "voluntary severance" scheme that is open to all employees and not specifically targeted at reducing headcount, HMRC may treat the payments differently. Always get the terms of your voluntary redundancy agreement reviewed by a tax professional.',
    answerText: 'Yes. Voluntary redundancy receives the same £30,000 tax-free exemption as compulsory redundancy. The payment must be genuinely connected to employment termination, not a reward for past services.',
  },
  {
    question: 'What counts as "qualifying" redundancy pay?',
    answerHtml: 'Qualifying redundancy pay includes payments that are genuinely connected to the termination of your employment. These are:<br /><br /><ul><li><b>Statutory redundancy pay</b> — The legal minimum based on age and service</li><li><b>Contractual redundancy pay</b> — Any enhanced redundancy payment agreed in your employment contract or company policy</li><li><b>Ex-gratia payments</b> — Extra payments made specifically because of your redundancy, not for services rendered</li></ul>It does <b>not</b> include:<br /><br /><ul><li><b>Notice pay (PILON)</b> — Payment in lieu of notice is always taxable</li><li><b>Accrued holiday pay</b> — Payment for untaken annual leave</li><li><b>Bonuses and commissions</b> — Any performance-related pay</li><li><b>Benefits in kind</b> — Car, health insurance, or other benefits</li></ul>The distinction is critical because only qualifying redundancy pay benefits from the £30,000 tax-free exemption.',
    answerText: 'Qualifying redundancy pay includes statutory redundancy, contractual redundancy, and genuine ex-gratia termination payments. It does NOT include PILON, holiday pay, bonuses, commissions, or benefits in kind.',
  },
  {
    question: 'How is redundancy tax calculated under HMRC rules?',
    answerHtml: 'HMRC uses a <b>marginal tax rate</b> system for redundancy payments. Here is the step-by-step calculation:<br /><br /><ol><li><b>Separate qualifying vs. non-qualifying:</b> Gross package minus non-qualifying pay (PILON, holiday pay, bonuses) = qualifying redundancy.</li><li><b>Apply £30,000 exemption:</b> The first £30,000 of qualifying redundancy is tax-free. Everything above is taxable excess.</li><li><b>Stack on existing income:</b> Your taxable excess + non-qualifying compensation is added on top of your existing year-to-date income.</li><li><b>Apply marginal rates:</b> The tax is the difference between tax on (existing income + redundancy taxable) and tax on (existing income alone).</li><li><b>No employee NI on qualifying:</b> Only non-qualifying payments attract employee National Insurance at 8% (up to £50,270) or 2% (above).</li></ol>Use our <strong>UK redundancy tax calculator</strong> above to instantly see your exact breakdown.',
    answerText: 'HMRC stacks redundancy taxable amounts on top of existing income and applies marginal tax rates. The first £30,000 of qualifying redundancy is tax-free. Employee NI only applies to non-qualifying payments. Our calculator shows the exact breakdown.',
  },
];
---

<PageLayout
  title="UK Redundancy Tax Calculator: Tax on Pay Over £30k"
  description="Calculate your net take-home pay after redundancy in the UK. Find out exactly how much tax you will pay on termination packages over £30,000 under HMRC rules."
  canonical="https://truefinancetools.com/uk-redundancy-tax-calculator"
  ogImage="https://truefinancetools.com/og-uk-redundancy-tax-calculator.png"
  ogImageAlt="UK Redundancy Tax Calculator — Calculate net take-home pay after redundancy"
  pageType="website"
  keywords="redundancy tax calculator uk, redundancy pay over 30k tax calculator, tax on redundancy pay uk calculator, severance pay tax calculator uk, voluntary redundancy tax calculator, hmrc redundancy tax, uk tax calculator"
>
  <StructuredData
    title="UK Redundancy Tax Calculator"
    description="Calculate your net take-home pay after redundancy in the UK. Find out exactly how much tax you will pay on termination packages over £30,000 under HMRC rules."
    url="https://truefinancetools.com/uk-redundancy-tax-calculator"
    toolName="UK Redundancy Tax Calculator"
    toolDescription="Calculate your net take-home pay after redundancy in the UK with the £30,000 tax-free exemption, marginal income tax rates, and employee NI free qualifying redundancy."
    faqItems={toolFaqItems}
    features={[
      'UK HMRC 2026/27 tax band calculations',
      'England, Wales, NI & Scotland tax regions',
      '£30,000 tax-free exemption calculator',
      'Employee National Insurance breakdown',
      'Marginal tax rate analysis',
      'Instant net take-home pay estimate',
    ]}
  />

  <!-- Hero -->
  <section class="border-b border-hairline bg-canvas py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h1 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl" style="letter-spacing: -0.02em;">
        UK Redundancy Pay Tax Calculator (Over £30k)
      </h1>
      <p class="text-lg text-body">Find out exactly how much tax and NI you will pay on your redundancy package. Free HMRC-compliant calculator for 2026/27.</p>
    </div>
  </section>

  <!-- Calculator Component -->
  <UkRedundancyTaxCalculator />

  <!-- How It Works -->
  <HowItWorks title="How the UK Redundancy Tax Calculator Works">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">1. Enter Your Package Details</h3>
      <p class="text-sm text-body">Input your total gross redundancy package, non-qualifying compensation (PILON, holiday pay), and your year-to-date taxable income.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">2. Choose Your Tax Region</h3>
      <p class="text-sm text-body">Select England, Wales &amp; Northern Ireland or Scotland to apply the correct HMRC 2026/27 tax bands and rates.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">3. See Your Net Take-Home Pay</h3>
      <p class="text-sm text-body">Instantly view your estimated take-home pay, income tax, NI deductions, and a detailed itemised tax breakdown.</p>
    </div>
  </HowItWorks>

  <!-- How Tax on Redundancy Pay Over £30k is Calculated -->
  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        How Tax on Redundancy Pay Over £30k is Calculated
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <p class="mb-4">
          <strong>HMRC applies a £30,000 tax-free exemption</strong> to genuine redundancy payments. Any qualifying redundancy pay above £30,000 is added to your other taxable income for the year and taxed at your marginal income tax rate. Non-qualifying payments such as Payment in Lieu of Notice (PILON), accrued holiday pay, bonuses, and commissions do not qualify for any exemption and are fully taxable as employment income.
        </p>

        <p class="mb-4">
          The calculation uses a <strong>marginal rate stacking</strong> approach. Your total additional taxable income from the redundancy (taxable excess + non-qualifying compensation) is stacked on top of your existing year-to-date income. The calculator then computes the difference between what you would pay in tax without the redundancy versus with the redundancy included. This gives you the exact marginal tax attributable to your package.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">The Redundancy Tax Formula</h3>
        <div class="rounded-lg bg-canvas-soft-2 p-4 font-mono text-sm text-ink">
          Net Take-Home = Total Package − Income Tax on Package − Employee NI
        </div>

        <p class="mb-4 mt-4">
          Where <strong>Income Tax</strong> is calculated using the HMRC stacking method with your region's tax bands, and <strong>Employee NI</strong> is only applied to the non-qualifying portion of your package (qualifying redundancy is always NI-free). Our calculator handles all of this automatically, supporting both England/Wales/NI and Scotland tax regions.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">£30,000 Exemption vs No Exemption</h3>
        <div class="overflow-x-auto rounded-lg border border-hairline">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="p-3 font-medium text-ink">Scenario</th>
                <th class="p-3 font-medium text-ink">With £30k Exemption</th>
                <th class="p-3 font-medium text-ink">Without Exemption</th>
              </tr>
            </thead>
            <tbody class="font-mono text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Redundancy Package</td>
                <td class="p-3 text-success-deep">£50,000</td>
                <td class="p-3 text-body font-sans">£50,000</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Tax-Free Amount</td>
                <td class="p-3 text-success-deep">£30,000</td>
                <td class="p-3 text-body font-sans">£0</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Taxable Amount</td>
                <td class="p-3 text-body font-sans">£20,000</td>
                <td class="p-3 text-error">£50,000</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Income Tax (est.)</td>
                <td class="p-3 text-success-deep">~£4,000</td>
                <td class="p-3 text-error">~£14,972</td>
              </tr>
              <tr class="bg-success/5">
                <td class="p-3 font-sans font-semibold text-ink">Net Take-Home</td>
                <td class="p-3 font-semibold text-success-deep">~£45,600</td>
                <td class="p-3 font-semibold text-body">~£34,628</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Who Should Use This Calculator?</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Employees Facing Redundancy</h4>
            <p class="text-sm text-body">Understand exactly how much tax you will pay on your termination package before you sign anything. Ensure you are not overpaying HMRC.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">HR &amp; Payroll Professionals</h4>
            <p class="text-sm text-body">Quickly estimate tax and NI deductions for employee redundancy packages. Use the breakdown to explain payouts clearly to staff.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Financial Advisers &amp; Tax Accountants</h4>
            <p class="text-sm text-body">Model different package scenarios for clients. Compare England vs Scotland tax treatments and optimise take-home pay.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Job Seekers &amp; Career Changers</h4>
            <p class="text-sm text-body">Plan your finances around a potential redundancy. See how starting a new job in the same tax year affects your overall tax bill.</p>
          </div>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Redundancy Tax Pros and Cons</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-success/30 bg-success/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-success-deep">Advantages</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• £30,000 tax-free — one of the most generous exemptions in UK tax law</li>
              <li>• Qualifying redundancy is always free from employee NI</li>
              <li>• Statutory redundancy is always tax-free under the £30k limit</li>
              <li>• Pension contributions can reduce tax on the taxable portion</li>
              <li>• Timeable to minimise overall tax impact across tax years</li>
            </ul>
          </div>
          <div class="rounded-lg border border-error/30 bg-error/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-error">Trade-offs</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Marginal rates can push you into Higher or Additional Rate bands</li>
              <li>• PILON, holiday pay, and bonuses are fully taxable</li>
              <li>• New job in the same year stacks income and increases tax</li>
              <li>• Employer pays 15% Class 1A NI on excess over £30k</li>
              <li>• Scotland's 5-band system means higher rates on lower income</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Frequently Asked Questions About UK Redundancy Tax
      </h2>

      <div class="space-y-4">
        {toolFaqItems.map((item) => (
          <details class="group rounded-lg border border-hairline bg-canvas p-4 shadow-sm">
            <summary class="cursor-pointer py-2 text-sm font-medium text-ink">{item.question}</summary>
            <p class="mt-3 text-sm text-body" set:html={item.answerHtml} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Complete Guide to UK Redundancy Tax Planning -->
  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Complete Guide to UK Redundancy Tax Planning
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <p class="mb-4">
          Our <strong>UK redundancy tax calculator</strong> helps you understand exactly how much of your termination package you will actually take home after tax and National Insurance. Whether you are facing compulsory redundancy, considering voluntary severance, or working in HR who needs to model payouts for staff, this tool provides instant clarity under current HMRC 2026/2027 rules.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">Why Choose This Redundancy Tax Calculator?</h3>

        <p class="mb-4">
          Unlike generic salary calculators that treat all payments the same, this tool correctly separates <strong>qualifying redundancy</strong> from <strong>non-qualifying compensation</strong>. This distinction is critical because the £30,000 tax-free exemption only applies to genuine redundancy pay. Payments like PILON, accrued holiday pay, and bonuses are fully taxable as employment income — lumping them all together in a standard calculator would give you the wrong result.
        </p>

        <p class="mb-4">
          The calculator supports both <strong>England/Wales/NI</strong> and <strong>Scotland</strong> tax regions with their respective 2026/27 band structures. It uses HMRC's marginal rate stacking methodology, computing the tax on your existing year-to-date income with and without the redundancy to isolate the exact tax attributable to your package. You get an itemised breakdown showing exactly how much is tax-free, how much is taxable, and what your net take-home pay will be.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">Key Features of This Redundancy Tax Calculator</h3>

        <p class="mb-4">
          The calculator provides <strong>instant results</strong> as you adjust any input. Enter your total gross package, the amount of non-qualifying compensation, your year-to-date taxable income, and select your tax region. You will see your estimated net take-home pay, total income tax deducted, total employee NI (which is always £0 on qualifying redundancy), and a full itemised breakdown table with marginal tax rates applied to each band.
        </p>

        <p class="mb-4">
          For more UK financial planning, explore our <a href="/sipp-drawdown-tax-calculator" class="text-link hover:underline">SIPP Drawdown Tax Calculator</a> to model pension withdrawal taxes in retirement, or our <a href="/plan-5-student-loan-repayment-calculator" class="text-link hover:underline">Plan 5 Student Loan Repayment Calculator</a> to understand your student loan obligations. If your redundancy package pushes your income above £60,000, use our <a href="/hicbc-calculator" class="text-link hover:underline">HICBC Calculator</a> for optimizing your child benefit charge thresholds. Redundancy planning is also a good time to review your overall financial strategy — our <a href="/fire-calculator" class="text-link hover:underline">FIRE Calculator</a> can help you project how your severance package affects your long-term independence goals.
        </p>
      </div>
    </div>
  </section>

  <!-- Explore Other UK Tax Tools -->
  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h2 class="mb-4 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Explore Other UK Tax Tools
      </h2>
      <p class="mb-8 text-body">Free calculators for UK financial planning, tax efficiency, and retirement strategies.</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/uk-redundancy-tax-calculator" class="group rounded-lg border-2 border-ink bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">UK Redundancy Tax Guide</h3>
          <p class="text-xs text-body">Master the UK redundancy tax rules with our complete guide to the £30,000 exemption and marginal rates.</p>
        </a>
        <a href="/hicbc-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">HICBC Calculator</h3>
          <p class="text-xs text-body">Calculate your High Income Child Benefit Charge and find the optimal pension contribution to eliminate it.</p>
        </a>
        <a href="/sipp-drawdown-tax-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">SIPP Drawdown Tax (UK)</h3>
