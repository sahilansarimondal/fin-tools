---
import PageLayout from '../../layouts/PageLayout.astro';
import PensionTaperCalculator from '../../components/calculator/PensionTaperCalculator.astro';
import HowItWorks from '../../components/ui/HowItWorks.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import type { FAQItem } from '../../utils/faq-data';

const toolFaqItems: FAQItem[] = [
  {
    question: 'At what income does the UK pension taper start?',
    answerHtml: 'The pension taper is triggered when your <b>Threshold Income</b> exceeds <b>£200,000</b>. However, the actual reduction to your annual allowance only begins when your <b>Adjusted Income</b> exceeds <b>£260,000</b>. If your Threshold Income is above £200,000 but your Adjusted Income is below £260,000, you still retain the full £60,000 annual allowance.',
    answerText: 'The taper triggers at £200,000 Threshold Income, but the actual reduction starts at £260,000 Adjusted Income.',
  },
  {
    question: 'Are employer pension contributions included in Adjusted Income?',
    answerHtml: '<b>Yes</b>, employer pension contributions are always included in your Adjusted Income for the purpose of the tapered annual allowance calculation. This means generous employer contributions can push you over the £260,000 Adjusted Income limit and reduce your annual allowance.',
    answerText: 'Yes, employer pension contributions are always included in Adjusted Income.',
  },
  {
    question: 'What is the minimum tapered annual allowance?',
    answerHtml: 'The minimum tapered annual allowance is <b>£10,000</b>. This applies when your Adjusted Income reaches <b>£360,000</b> or above. At this point, further increases in income do not reduce the allowance any further — it is floored at £10,000.',
    answerText: 'The minimum tapered annual allowance is £10,000, which applies when Adjusted Income reaches £360,000 or above.',
  },
  {
    question: 'How does salary sacrifice affect the pension taper?',
    answerHtml: 'Salary sacrifice can help you avoid or reduce the impact of the pension taper. When you sacrifice salary, your <b>taxable income is reduced</b>, which lowers your Threshold Income. If this brings your Threshold Income below £200,000, the taper does not apply at all. Even if the taper still applies, the lower income means a smaller reduction to your annual allowance. Salary sacrifice is one of the most effective planning tools for high earners affected by the taper.',
    answerText: 'Salary sacrifice reduces your taxable income and Threshold Income, potentially avoiding the taper entirely or reducing its impact.',
  },
  {
    question: 'Can I carry forward unused annual allowance from previous years?',
    answerHtml: '<b>Yes</b>, you can carry forward up to <b>3 years</b> of unused annual allowance. This means if you did not use your full £60,000 allowance in the previous 3 tax years, you may be able to carry the unused amount forward to the current year. This can help offset a reduced tapered allowance. However, you must have been a member of a UK registered pension scheme in each of those carry-forward years.',
    answerText: 'Yes, you can carry forward up to 3 years of unused annual allowance from previous tax years.',
  },
  {
    question: 'What happens if I exceed my tapered annual allowance?',
    answerHtml: 'If your total pension contributions exceed your tapered annual allowance, you will face an <b>Annual Allowance Tax Charge</b>. This is charged at your marginal income tax rate (40% or 45% for high earners) on the excess amount. For example, if your tapered allowance is £40,000 and you contribute £50,000, you would owe tax on the £10,000 excess at your marginal rate. The tax charge is payable through your Self Assessment tax return.',
    answerText: 'Exceeding your tapered annual allowance triggers a tax charge at your marginal income tax rate on the excess.',
  },
  {
    question: 'How is Relief at Source different from Net Pay for taper purposes?',
    answerHtml: 'The contribution method affects how your income is calculated for the taper:<br /><br /><b>Relief at Source:</b> Your Threshold Income is reduced by the gross employee contribution (net contribution &times; 1.25), but your Adjusted Income includes both the gross employee contribution and employer contributions.<br /><br /><b>Net Pay / Salary Sacrifice:</b> Your salary is already reduced by the contribution, so your Threshold Income is lower to start with. Adjusted Income includes only employer contributions.<br /><br />Salary sacrifice is generally more advantageous for taper planning because it reduces both Threshold and Adjusted Income.',
    answerText: 'Relief at Source deducts gross employee contributions from Threshold Income but adds them back for Adjusted Income. Net Pay/Salary Sacrifice reduces salary upfront, lowering both measures.',
  },
];
---

<PageLayout
  title="UK Pension Taper Calculator — Tapered Annual Allowance (2024/25)"
  description="Calculate your Tapered Annual Allowance for your UK pension. Instantly work out your Threshold Income, Adjusted Income, and remaining tax-free allowance."
  canonical="https://truefinancetools.com/uk-pension-taper-calculator"
  ogImage="https://truefinancetools.com/og-uk-pension-taper-calculator.png"
  ogImageAlt="UK Pension Taper Calculator — Tapered Annual Allowance"
  pageType="website"
  keywords="pension taper calculator, tapered annual allowance UK, threshold income calculator, adjusted income pension, HMRC pension taper, high earner pension allowance"
>
  <StructuredData
    title="UK Pension Taper Calculator — Tapered Annual Allowance"
    description="Calculate your Tapered Annual Allowance for your UK pension. Instantly work out your Threshold Income, Adjusted Income, and remaining tax-free allowance."
    url="https://truefinancetools.com/uk-pension-taper-calculator"
    toolName="UK Pension Taper Calculator"
    toolDescription="Interactive UK calculator for high earners to determine their Tapered Annual Allowance based on HMRC rules."
    faqItems={toolFaqItems}
    features={[
      'Threshold Income and Adjusted Income calculation',
      'Tapered Annual Allowance determination with £10,000 floor',
      'Relief at Source vs Net Pay / Salary Sacrifice comparison',
      'HMRC-compliant 2024/25 tax year limits',
      'Real-time plain English explanation of results',
      'Annual Allowance tax charge warning',
    ]}
  />

  <!-- Hero -->
  <section class="border-b border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h1 class="mb-4 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        UK Pension Taper Calculator
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-body">
        Calculate your Tapered Annual Allowance based on HMRC rules. Find out if the pension taper affects you and how much tax-free allowance you have left.
      </p>
    </div>
  </section>

  <!-- Calculator Component -->
  <PensionTaperCalculator />

  <!-- How It Works -->
  <HowItWorks title="How the Pension Taper Calculator Works">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 9h3.75M15 12h3.75M15 15h3.75M4.5 19.5h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5zm6-10.125a1.875 1.875 0 11-3.75 0 1.875 1.875 0 013.75 0zm1.294 6.336a6.721 6.721 0 01-3.17.789 6.721 6.721 0 01-3.168-.789 3.376 3.376 0 016.338 0z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">1. Enter Your Income</h3>
      <p class="text-sm text-body">Input your salary, bonuses, other taxable income, and pension contributions.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">2. Calculate the Taper</h3>
      <p class="text-sm text-body">The calculator determines your Threshold Income, Adjusted Income, and tapered annual allowance.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">3. Review Your Allowance</h3>
      <p class="text-sm text-body">See your remaining tax-free allowance and any potential tax charges in plain English.</p>
    </div>
  </HowItWorks>

  <!-- What is the Tapered Annual Allowance? -->
  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        What is the Tapered Annual Allowance?
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <p class="mb-4">
          The <strong>Tapered Annual Allowance</strong> is an HMRC rule that reduces the amount of tax-free pension contributions
          you can make each year if you are a high earner. Introduced in 2016, it was designed to limit the tax relief available
          to the highest-income earners. For the <strong>2024/25 tax year</strong>, the standard annual allowance of <strong>£60,000</strong>
          is reduced by <strong>£1 for every £2 of Adjusted Income above £260,000</strong>, down to a minimum of <strong>£10,000</strong>.
        </p>

        <p class="mb-4">
          The taper only applies if your <strong>Threshold Income</strong> exceeds £200,000. This means you must first pass the
          Threshold Income test before HMRC looks at your Adjusted Income to determine the actual reduction. If your Threshold Income
          is below £200,000, the taper does not apply regardless of your Adjusted Income.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">The Taper Formula</h3>
        <pre class="overflow-x-auto rounded-lg bg-canvas-soft-2 p-4 font-mono text-sm text-ink">Tapered Allowance = MAX(£10,000, £60,000 − (Adjusted Income − £260,000) × 0.5)

Where:
  Threshold Income &gt; £200,000 (triggers the test)
  Adjusted Income &gt; £260,000 (triggers the reduction)
  Minimum allowance = £10,000</pre>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Comparison: Standard vs Tapered Allowance</h3>
        <div class="overflow-x-auto rounded-lg border border-hairline">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="p-3 font-medium text-ink">Scenario</th>
                <th class="p-3 font-medium text-ink">Threshold Income</th>
                <th class="p-3 font-medium text-ink">Adjusted Income</th>
                <th class="p-3 font-medium text-ink">Annual Allowance</th>
              </tr>
            </thead>
            <tbody class="text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="p-3 font-sans text-body">Standard</td>
                <td class="p-3 font-sans text-body">£180,000</td>
                <td class="p-3 font-sans text-body">£230,000</td>
                <td class="p-3 font-semibold text-success-deep">£60,000</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 font-sans text-body">Taper triggered, no reduction</td>
                <td class="p-3 font-sans text-body">£220,000</td>
                <td class="p-3 font-sans text-body">£250,000</td>
                <td class="p-3 font-semibold text-success-deep">£60,000</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 font-sans text-body">Partial taper</td>
                <td class="p-3 font-sans text-body">£250,000</td>
                <td class="p-3 font-sans text-body">£300,000</td>
                <td class="p-3 font-semibold text-warning">£40,000</td>
              </tr>
              <tr class="bg-error/5">
                <td class="p-3 font-sans font-semibold text-ink">Maximum taper</td>
                <td class="p-3 font-sans text-body">£350,000</td>
                <td class="p-3 font-sans text-body">£400,000</td>
                <td class="p-3 font-semibold text-error">£10,000</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Who Should Use This Calculator?</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">High Earners</h4>
            <p class="text-sm text-body">If your total income exceeds £200,000, you need to know whether the taper affects your pension allowance. This calculator provides instant clarity.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Generous Employer Contributions</h4>
            <p class="text-sm text-body">Large employer pension contributions can push you over the Adjusted Income threshold even if your salary is below £260,000. Check your combined position.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Salary Sacrifice Users</h4>
            <p class="text-sm text-body">Understand how salary sacrifice affects both your Threshold and Adjusted Income, and whether switching methods could reduce or eliminate the taper impact.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Multiple Income Sources</h4>
            <p class="text-sm text-body">If you have dividends, rental income, or savings interest on top of your salary, the combined income could push you into taper territory.</p>
          </div>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Tapered Annual Allowance Pros and Cons</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-success/30 bg-success/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-success-deep">Key Points</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Protects tax relief for lower and middle earners</li>
              <li>• Only affects the highest-income earners</li>
              <li>• Minimum allowance of £10,000 still available</li>
              <li>• Carry forward rules can offset the reduction</li>
              <li>• Salary sacrifice can help manage the impact</li>
            </ul>
          </div>
          <div class="rounded-lg border border-error/30 bg-error/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-error">Challenges</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Complex dual-income test (Threshold + Adjusted)</li>
              <li>• Employer contributions count against your allowance</li>
              <li>• Can reduce allowance from £60K to £10K quickly</li>
              <li>• Tax charge at marginal rate on excess contributions</li>
              <li>• Requires careful year-round planning</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Frequently Asked Questions About the Pension Taper
      </h2>

      <div class="space-y-4">
        {toolFaqItems.map((item) => (
          <details class="group rounded-lg border border-hairline bg-canvas p-4 shadow-sm">
            <summary class="cursor-pointer py-2 text-sm font-medium text-ink">{item.question}</summary>
            <p class="mt-3 text-sm text-body" set:html={item.answerHtml} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Complete Guide -->
  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Complete Guide to the Tapered Annual Allowance
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <h3 class="mb-3 text-lg font-semibold text-ink">How the Tapered Annual Allowance Works</h3>

        <p class="mb-4">
          The Tapered Annual Allowance operates on a two-step testing process. First, HMRC checks your <strong>Threshold Income</strong> —
          broadly your total taxable income minus your gross personal pension contributions. If this exceeds £200,000, the taper
          is triggered and HMRC moves to the second test: your <strong>Adjusted Income</strong>, which is your total taxable income
          plus your employer's pension contributions and your gross employee contributions.
        </p>

        <p class="mb-4">
          If your Adjusted Income exceeds £260,000, your annual allowance is reduced by £1 for every £2 of excess, down to a
          minimum of £10,000. This means a high earner with £360,000 Adjusted Income would have their allowance reduced to the
          minimum £10,000. The key takeaway: the taper can reduce your tax-free pension contribution limit by up to £50,000 per
          year.
        </p>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Threshold Income vs Adjusted Income</h3>

        <p class="mb-4">
          Understanding the difference between these two measures is critical for pension taper planning:
        </p>

        <div class="overflow-x-auto rounded-lg border border-hairline">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="p-3 font-medium text-ink">Component</th>
                <th class="p-3 font-medium text-ink">Threshold Income</th>
                <th class="p-3 font-medium text-ink">Adjusted Income</th>
              </tr>
            </thead>
            <tbody class="text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="p-3 font-sans text-body">Employment income</td>
                <td class="p-3 font-sans text-body">Included</td>
                <td class="p-3 font-sans text-body">Included</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 font-sans text-body">Dividends &amp; rental income</td>
                <td class="p-3 font-sans text-body">Included</td>
                <td class="p-3 font-sans text-body">Included</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 font-sans text-body">Employee pension contributions</td>
                <td class="p-3 font-sans text-body">Deducted</td>
                <td class="p-3 font-sans text-body">Added back</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 font-sans text-body">Employer pension contributions</td>
                <td class="p-3 font-sans text-body">Excluded</td>
                <td class="p-3 font-sans text-body">Included</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">The Impact of Salary Sacrifice</h3>

        <p class="mb-4">
          Salary sacrifice can be a powerful tool for managing the pension taper. When you sacrifice salary, your taxable income
          decreases, which lowers your Threshold Income. If this brings your Threshold Income below £200,000, the taper does not
          apply at all — even if your Adjusted Income remains high. If the taper still applies, the lower taxable income means a
          smaller reduction to your annual allowance. For high earners affected by the taper, switching from Relief at Source to
          salary sacrifice can be one of the most effective planning strategies available.
        </p>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Carrying Forward Unused Allowances</h3>

        <p class="mb-4">
          If you are affected by the taper, you may still be able to make larger pension contributions by using the
          <strong>carry forward</strong> rule. This allows you to carry forward unused annual allowance from the previous
          three tax years. For example, if your tapered allowance for the current year is £30,000, but you have £50,000 of
          unused allowance from the previous three years, you could contribute up to £80,000 in total without triggering a
          tax charge. However, you must have been a member of a UK registered pension scheme in each of the carry-forward years.
        </p>
      </div>
    </div>
  </section>

  <!-- Explore Other UK Tax & Pension Tools -->
  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h2 class="mb-4 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Explore Other UK Tax &amp; Pension Tools
      </h2>
      <p class="mb-8 text-body">Free calculators for UK financial planning, pension optimisation, and tax efficiency.</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/uk-pension-taper-calculator" class="group rounded-lg border-2 border-ink bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">UK Pension Taper Calculator</h3>
          <p class="text-xs text-body">Calculate your Tapered Annual Allowance for high earners. Work out Threshold Income, Adjusted Income, and remaining allowance.</p>
        </a>
        <a href="/salary-sacrifice-pension-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Salary Sacrifice Pension</h3>
          <p class="text-xs text-body">Compare standard vs salary sacrifice pension contributions. See your NI savings and employer pass-on boost.</p>
        </a>
        <a href="/lisa-vs-workplace-pension-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">LISA vs Workplace Pension (UK)</h3>
          <p class="text-xs text-body">Compare a Lifetime ISA against a workplace pension for retirement savings, including salary sacrifice modelling.</p>
        </a>
        <a href="/sipp-drawdown-tax-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">SIPP Drawdown Tax (UK)</h3>
          <p class="text-xs text-body">Model your SIPP drawdown strategy with UK tax bands and 25% tax-free cash.</p>
        </a>
        <a href="/uk-redundancy-tax-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">UK Redundancy Tax</h3>
          <p class="text-xs text-body">Calculate your net take-home pay after redundancy with the £30,000 tax-free exemption and HMRC marginal rates.</p>
        </a>
        <a href="/mortgage-overpayment-vs-investing-calculator-uk" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Mortgage vs ISA (UK)</h3>
          <p class="text-xs text-body">Compare overpaying your mortgage against investing in a stocks &amp; shares ISA.</p>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
