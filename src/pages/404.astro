---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout
  title="Page Not Found"
  description="The page you're looking for doesn't exist. Head back to True Finance Tools to calculate your FIRE number."
  canonical="https://truefinancetools.com/404"
  pageType="website"
>
  <Header />

  <main>
    <section class="relative overflow-hidden border-b border-hairline bg-canvas py-20 sm:py-28">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-gradient-start)_0%,_transparent_50%)] opacity-10"></div>

      <div class="relative mx-auto max-w-4xl px-4 text-center sm:px-6">
        <p class="mb-4 font-mono text-6xl font-semibold tracking-tight text-hairline-strong sm:text-8xl">
          404
        </p>

        <h1 class="mb-4 text-2xl font-semibold tracking-tight text-ink sm:text-3xl" style="letter-spacing: -0.03em;">
          Page Not Found
        </h1>

        <p class="mx-auto mb-8 max-w-md text-body">
          The page you're looking for doesn't exist or has been moved. Let's get you back on track.
        </p>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3 text-base font-medium text-canvas transition-opacity hover:opacity-90"
          >
            Back to Home
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>

          <a
            href="/fire-calculator"
            class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-6 py-3 text-base font-medium text-ink transition-colors hover:bg-canvas-soft-2"
          >
            Open Calculator
          </a>
        </div>
      </div>
    </section>

    <section class="bg-canvas py-16">
      <div class="mx-auto max-w-4xl px-4 sm:px-6">
        <div class="mb-12 text-center">
          <p class="mb-2 font-mono text-xs uppercase tracking-wider text-mute">Quick Links</p>
          <h2 class="text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
            Popular Pages
          </h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <a href="/fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">FIRE Calculator</h3>
            <p class="text-sm text-body">Calculate your FIRE number and plan your path to financial independence.</p>
          </a>

          <a href="/learn/what-is-fire" class="group rounded-lg border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">What is FIRE?</h3>
            <p class="text-sm text-body">Learn the basics of Financial Independence, Retire Early.</p>
          </a>

          <a href="/learn/fire-number" class="group rounded-lg border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Your FIRE Number</h3>
            <p class="text-sm text-body">Calculate exactly how much you need to retire early.</p>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
