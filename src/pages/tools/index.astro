    <!-- Risk & Sequence Analysis (3 tools) -->
    <section class="border-b border-hairline bg-canvas py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">Risk &amp; Sequence Analysis</p>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <a href="/sequence-of-returns-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
