---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout
    title="Financial Planning Tools — 30+ Free Calculators for FIRE, Retirement & Investing"
  description="Browse 30+ free financial calculators for FIRE planning, retirement withdrawal strategies, portfolio optimization, tax efficiency, and investment analysis. No signup required."
  canonical="https://truefinancetools.com/tools"
  ogImage="https://truefinancetools.com/og.png"
  ogImageAlt="True Finance Tools — Free Financial Planning Calculators"
  pageType="website"
  keywords="financial tools, FIRE calculator, lean fire, fat fire, coast fire, barista fire, net worth calculator, portfolio rebalancing, free calculators, retirement planning tools, VPW, guardrails withdrawal, bond tent, bucket strategy, tax gain harvesting, HSA shoebox, SEPP calculator, UK mortgage vs ISA, SIPP drawdown"
>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="border-b border-hairline bg-canvas py-16 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">Free Calculators</p>
        <h1 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl" style="letter-spacing: -0.02em;">
          Financial Planning Tools
        </h1>
        <p class="mb-6 text-lg text-body">
          Free, private calculators to help you plan your path to financial independence. No signup required.
        </p>
        <span class="inline-flex items-center gap-2 rounded-full bg-canvas-soft-2 px-4 py-2 font-mono text-xs font-medium text-mute">
          36+ Free Calculators
        </span>
      </div>
    </section>

    <!-- FIRE Strategies (8 tools) -->
    <section class="border-b border-hairline bg-canvas py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">FIRE Strategies</p>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <a href="/fire-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">FIRE Calculator</h2>
            <p class="mb-3 text-xs text-body">Calculate your FIRE number with the 25x rule. Compare lean, fat, coast, and barista strategies.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/lean-fire-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Lean FIRE</h2>
            <p class="mb-3 text-xs text-body">Minimalist retirement with lower expenses. 20x annual spending.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/fat-fire-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="m16.5 7.5 2.25 2.25-4.878 4.878M14.25 9.75l-2.25 2.25-4.878-4.878M18.75 12l-2.25 2.25L11.625 19.125 6.75 14.25M2.25 12l2.25 2.25L11.625 4.875 16.5 9.75M12 2.25l2.25 2.25L12 6.75 9.75 4.5 12 2.25z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Fat FIRE</h2>
            <p class="mb-3 text-xs text-body">Luxury retirement lifestyle. 30x annual spending.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/barista-fire-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Barista FIRE</h2>
            <p class="mb-3 text-xs text-body">Work part-time, let investments cover the rest.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/coast-fire-number" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Coast FIRE Number</h2>
            <p class="mb-3 text-xs text-body">Find how much you need saved today to reach FIRE through compound interest alone.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/coast-fire-by-age-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Coast FIRE by Age</h2>
            <p class="mb-3 text-xs text-body">See your Coast FIRE milestone at every age with an interactive glide path.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/coast-fire-shift-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Coast FIRE Shift</h2>
            <p class="mb-3 text-xs text-body">Find the exact age you can shift to part-time while investments compound.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/geographic-arbitrage-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Geo Arbitrage</h2>
            <p class="mb-3 text-xs text-body">Compare retirement costs between countries using purchasing power parity.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Withdrawal & Distribution Strategies (5 tools) -->
    <section class="border-b border-hairline bg-canvas-soft py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">Withdrawal &amp; Distribution Strategies</p>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <a href="/die-with-zero-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Die with Zero</h2>
            <p class="mb-3 text-xs text-body">Optimize your decumulation plan to use every dollar before the end.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
