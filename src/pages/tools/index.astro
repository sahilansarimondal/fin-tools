---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout
  title="Free Financial Planning Tools"
  description="Browse free calculators for FIRE planning, net worth tracking, and portfolio management. No signup required."
  canonical="https://truefinancetools.com/tools"
  ogImage="https://truefinancetools.com/og.png"
  ogImageAlt="True Finance Tools - Free Financial Planning Calculators"
  pageType="website"
  keywords="financial tools, FIRE calculator, net worth calculator, portfolio rebalancing, free calculators, retirement planning tools"
>
  <Header />

  <main>
    <section class="border-b border-hairline bg-canvas py-16 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">Free Calculators</p>
        <h1 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl" style="letter-spacing: -0.02em;">
          Financial Planning Tools
        </h1>
        <p class="text-lg text-body">
          Free, private calculators to help you plan your path to financial independence. No signup required.
        </p>
      </div>
    </section>

    <section class="border-b border-hairline bg-canvas-soft py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <a href="/fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">FIRE Calculator</h2>
            <p class="mb-4 text-sm text-body">Calculate your FIRE number, compare strategies, and plan your path to early retirement.</p>
            <span class="inline-flex items-center gap-1.5 text-sm font-medium text-link">
              Open Calculator
              <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <div class="rounded-lg border border-hairline bg-canvas p-6 opacity-60">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-mute">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3" />
              </svg>
            </div>
            <div class="mb-2 flex items-center gap-2">
              <h2 class="text-sm font-semibold text-ink">Net Worth Calculator</h2>
              <span class="rounded-full bg-canvas-soft-2 px-2 py-0.5 text-xs font-medium text-mute">Coming Soon</span>
            </div>
            <p class="text-sm text-body">Track your assets and liabilities to calculate and monitor your total net worth over time.</p>
          </div>

          <div class="rounded-lg border border-hairline bg-canvas p-6 opacity-60">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-mute">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.589-1.202L18.75 4.97zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.589-1.202L5.25 4.97z" />
              </svg>
            </div>
            <div class="mb-2 flex items-center gap-2">
              <h2 class="text-sm font-semibold text-ink">Portfolio Rebalancing Tool</h2>
              <span class="rounded-full bg-canvas-soft-2 px-2 py-0.5 text-xs font-medium text-mute">Coming Soon</span>
            </div>
            <p class="text-sm text-body">Optimize your asset allocation and get rebalancing recommendations for your investment portfolio.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-hairline bg-canvas py-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <div class="prose prose-gray max-w-none text-body">
          <p class="mb-4">
            Our growing collection of <strong>free financial calculators</strong> helps you make smarter decisions about money, retirement, and investing. Every tool runs entirely in your browser&mdash;no data is stored on our servers, and no signup is required.
          </p>
          <p class="mb-4">
            Start with our <a href="/fire-calculator" class="text-link transition-colors hover:text-link-deep">FIRE calculator</a> to determine your financial independence number, or explore our <a href="/learn/what-is-fire" class="text-link transition-colors hover:text-link-deep">learn articles</a> to understand the strategies behind early retirement. We're constantly building new tools&mdash;check back soon for net worth tracking and portfolio rebalancing.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-canvas py-16">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
        <h2 class="mb-4 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
          Ready to Start Planning?
        </h2>
        <p class="mb-8 text-body">Calculate your FIRE number in seconds. It's free, private, and no signup required.</p>

        <a
          href="/fire-calculator"
          class="inline-flex items-center gap-2 rounded-full bg-ink px-8 py-3 text-base font-medium text-canvas transition-opacity hover:opacity-90"
        >
          Open Calculator
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
