---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
---

<BaseLayout
  title="Free Financial Planning Tools"
  description="Browse free calculators for FIRE planning, net worth tracking, and portfolio management. No signup required."
  canonical="https://truefinancetools.com/tools"
  ogImage="https://truefinancetools.com/og.png"
  ogImageAlt="True Finance Tools - Free Financial Planning Calculators"
  pageType="website"
  keywords="financial tools, FIRE calculator, lean fire, fat fire, coast fire, barista fire, net worth calculator, portfolio rebalancing, free calculators, retirement planning tools"
>
  <Header />

  <main>
    <section class="border-b border-hairline bg-canvas py-16 sm:py-20">
      <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">Free Calculators</p>
        <h1 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl" style="letter-spacing: -0.02em;">
          Financial Planning Tools
        </h1>
        <p class="text-lg text-body">
          Free, private calculators to help you plan your path to financial independence. No signup required.
        </p>
      </div>
    </section>

    <!-- FIRE Strategy Calculators -->
    <section class="border-b border-hairline bg-canvas py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">FIRE Strategy Calculators</p>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          <a href="/lean-fire-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M2.25 6L9 12.75l4.286-4.286a11.948 11.948 0 014.306 6.43l.776 2.898m0 0l3.182-5.511m-3.182 5.51l-5.511-3.181" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Lean FIRE</h2>
            <p class="mb-3 text-xs text-body">Minimalist retirement with lower expenses. 20x annual spending.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/fat-fire-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="m16.5 7.5 2.25 2.25-4.878 4.878M14.25 9.75l-2.25 2.25-4.878-4.878M18.75 12l-2.25 2.25L11.625 19.125 6.75 14.25M2.25 12l2.25 2.25L11.625 4.875 16.5 9.75M12 2.25l2.25 2.25L12 6.75 9.75 4.5 12 2.25z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Fat FIRE</h2>
            <p class="mb-3 text-xs text-body">Luxury retirement lifestyle. 30x annual spending.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>

          <a href="/barista-fire-calculator" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 00.75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 00-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0112 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 01-.673-.38m0 0A2.18 2.18 0 013 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 013.413-.387m7.5 0V5.25A2.25 2.25 0 0013.5 3h-3a2.25 2.25 0 00-2.25 2.25v.894m7.5 0a48.667 48.667 0 00-7.5 0M12 12.75h.008v.008H12v-.008z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Barista FIRE</h2>
            <p class="mb-3 text-xs text-body">Work part-time, let investments cover the rest.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Specialized Tools -->
    <section class="border-b border-hairline bg-canvas-soft py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">Specialized Tools</p>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          <a href="/coast-fire-number" class="group rounded-xl border border-hairline bg-canvas p-6 shadow-sm transition-all hover:shadow-md">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-ink">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <h2 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Coast FIRE Number</h2>
            <p class="mb-3 text-xs text-body">Find your Coast FIRE number by age — see how much you need saved today.</p>
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-link">
              Calculate
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Coming Soon -->
    <section class="border-b border-hairline bg-canvas py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <p class="mb-4 font-mono text-xs uppercase tracking-wider text-mute">Coming Soon</p>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-xl border border-hairline bg-canvas p-6 opacity-60">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-mute">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="mb-2 flex items-center gap-2">
              <h2 class="text-sm font-semibold text-ink">Net Worth Calculator</h2>
              <span class="rounded-full bg-canvas-soft-2 px-2 py-0.5 text-xs font-medium text-mute">Coming Soon</span>
            </div>
            <p class="text-sm text-body">Track your assets and liabilities to calculate and monitor your total net worth over time.</p>
          </div>

          <div class="rounded-xl border border-hairline bg-canvas p-6 opacity-60">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-canvas-soft-2 text-mute">
              <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" />
                <path d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" />
              </svg>
            </div>
            <div class="mb-2 flex items-center gap-2">
              <h2 class="text-sm font-semibold text-ink">Portfolio Rebalancing Tool</h2>
              <span class="rounded-full bg-canvas-soft-2 px-2 py-0.5 text-xs font-medium text-mute">Coming Soon</span>
            </div>
            <p class="text-sm text-body">Optimize your asset allocation and get rebalancing recommendations for your investment portfolio.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-hairline bg-canvas-soft py-16">
      <div class="mx-auto max-w-3xl px-4 sm:px-6">
        <div class="prose prose-gray max-w-none text-body">
          <p class="mb-4">
            Our growing collection of <strong>free financial calculators</strong> helps you make smarter decisions about money, retirement, and investing. Every tool runs entirely in your browser&mdash;no data is stored on our servers, and no signup is required.
          </p>
          <p class="mb-4">
            Dive into a specific approach like <a href="/lean-fire-calculator" class="text-link transition-colors hover:text-link-deep">Lean FIRE</a>, <a href="/fat-fire-calculator" class="text-link transition-colors hover:text-link-deep">Fat FIRE</a>, or <a href="/barista-fire-calculator" class="text-link transition-colors hover:text-link-deep">Barista FIRE</a>. Explore our <a href="/learn/what-is-fire" class="text-link transition-colors hover:text-link-deep">learn articles</a> to understand the strategies behind early retirement.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-canvas py-16">
      <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
        <h2 class="mb-4 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
          Ready to Start Planning?
        </h2>
        <p class="mb-8 text-body">Calculate your FIRE number in seconds. It's free, private, and no signup required.</p>

        <a
          href="/lean-fire-calculator"
          class="inline-flex items-center gap-2 rounded-full bg-ink px-8 py-3 text-base font-medium text-canvas transition-opacity hover:opacity-90"
        >
          Open Calculator
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
