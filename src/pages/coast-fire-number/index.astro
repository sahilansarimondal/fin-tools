---
import PageLayout from '../../layouts/PageLayout.astro';
import CoastFireNumber from '../../components/calculator/CoastFireNumber.astro';
import HowItWorks from '../../components/ui/HowItWorks.astro';
import StructuredData from '../../components/seo/StructuredData.astro';
import type { FAQItem } from '../../utils/faq-data';

const coastFaqItems: FAQItem[] = [
  {
    question: 'What is a Coast FIRE number and how does it work?',
    answerHtml: 'Your <b>Coast FIRE number</b> is the amount you need invested today so that compound interest alone—with <b>zero additional contributions</b>—will grow your portfolio to your full FIRE number by your target retirement age.<br /><br />Once you hit your Coast FIRE number, you no longer need to save aggressively. You only need to earn enough to cover your current living expenses. Your investments do the rest. This is the most liberating milestone in the FIRE journey: the point where time, not money, does the work.',
    answerText: 'Your Coast FIRE number is the amount you need invested today so compound interest alone reaches your full FIRE number by retirement age. Once you hit it, you no longer need to save—just earn enough to cover living expenses.',
  },
  {
    question: 'How is the Coast FIRE number calculated?',
    answerHtml: 'The Coast FIRE formula is:<br /><br /><b>Coast FIRE Number = (Annual Expenses × 25) / (1 + Annual Return)<sup>Years to Retirement</sup></b><br /><br /><b>Example:</b> If you spend $60,000/year, your FIRE number is $1,500,000 (25× expenses). If you are 30, plan to retire at 55, and expect 7% annual returns:<br />• $1,500,000 / (1.07)<sup>25</sup> = <b>$276,000</b><br />• Once you save $276,000, compound interest grows it to $1.5M by age 55.<br />• You can stop contributing and just cover your living expenses.',
    answerText: 'Coast FIRE Number = (Annual Expenses × 25) / (1 + Return)^Years. Example: 30 years old, retire at 55, $60K expenses, 7% return: $1.5M / 1.07^25 = $276K needed today.',
  },
  {
    question: 'How much do I need to Coast FIRE at different ages?',
    answerHtml: 'Your Coast FIRE number drops dramatically the earlier you start. Here is how it changes on <b>$60,000 annual expenses</b> with 7% returns and retirement at 65:<br /><br /><ul><li><b>At 25</b> (40 years to grow): ~$196,000 needed — you have decades of compound growth ahead.</li><li><b>At 30</b> (35 years): ~$276,000 needed — still excellent runway.</li><li><b>At 35</b> (30 years): ~$385,000 needed — about twice the 25-year-old target.</li><li><b>At 40</b> (25 years): ~$536,000 needed — you need more than double the 30-year-old target.</li><li><b>At 45</b> (20 years): ~$750,000 needed — a significant sum.</li><li><b>At 50</b> (15 years): ~$1,050,000 needed — almost your full FIRE number.</li></ul><br />The key insight: your 20s and 30s are when Coast FIRE is most achievable. Every year you wait, the target grows.',
    answerText: 'Coast FIRE by age: at 25 need ~$196K, at 30 need ~$276K, at 35 need ~$385K, at 40 need ~$536K, at 45 need ~$750K, at 50 need ~$1.05M. The earlier you start, the less you need.',
  },
  {
    question: 'Is Coast FIRE the same as full FIRE?',
    answerHtml: 'No, they are different milestones:<br /><br /><b>Coast FIRE</b> means your current portfolio can grow to your future FIRE number without additional contributions—but you still need to earn enough to cover <b>today\'s living expenses</b> until you fully retire.<br /><br /><b>Full FIRE</b> means your portfolio is large enough to cover all your expenses indefinitely—you can stop working entirely.<br /><br />Think of Coast FIRE as <b>permission to relax your savings</b>. You can switch to a lower-stress job, work part-time, or pursue passion projects without derailing your retirement. Full FIRE is permission to <b>stop working entirely</b>. Many people hit Coast FIRE first, then continue building toward full FIRE.',
    answerText: 'Coast FIRE means you can stop saving—your portfolio will grow to your target on its own—but you still need to cover today\'s expenses with work income. Full FIRE means you can stop working entirely.',
  },
  {
    question: 'Who should use a Coast FIRE calculator?',
    answerHtml: 'A Coast FIRE number calculator is especially useful for:<br /><br /><ul><li><b>Career Changers</b> — Wondering if you can switch to a lower-paying but more fulfilling career? Coast FIRE tells you if your savings are already sufficient to let compound interest do the rest.</li><li><b>Young Professionals</b> — In your 20s or 30s? Time is your biggest asset. See exactly how much less you need today because of your long runway.</li><li><b>Semi-Retirees</b> — Already considering part-time work? Your Coast FIRE number tells you if you can scale back contributions and still reach your full retirement target.</li><li><b>Parents</b> — Want to work less while your kids are young? Coast FIRE can show you if your savings are already on track to handle retirement without aggressive contributions.</li></ul>',
    answerText: 'Coast FIRE calculators help career changers, young professionals with time on their side, semi-retirees considering part-time work, and parents who want to scale back while their kids are young.',
  },
  {
    question: 'What return rate should I use for Coast FIRE calculations?',
    answerHtml: 'The return rate you choose dramatically affects your Coast FIRE number. Here is guidance on what to use:<br /><br /><ul><li><b>7% (recommended):</b> The standard inflation-adjusted return for a diversified stock portfolio. This matches the historical S&P 500 average of ~10% minus ~3% inflation.</li><li><b>6% (conservative):</b> Use if you want a larger safety margin or plan a more conservative asset allocation.</li><li><b>8% (aggressive):</b> Only use if you are 100% equities and comfortable with volatility.</li></ul><br />A 1% difference in return rate dramatically changes your Coast FIRE number. At age 30 with $60K expenses: 6% = ~$349K, 7% = ~$276K, 8% = ~$219K. Use 7% as your default and test sensitivity with the calculator.',
    answerText: 'Use 7% (inflation-adjusted) as the default return rate. 6% for conservative, 8% for aggressive. At age 30/ $60K expenses: 6% = ~$349K, 7% = ~$276K, 8% = ~$219K. Small differences compound massively.',
  },
  {
    question: 'Can I still save after reaching my Coast FIRE number?',
    answerHtml: 'Absolutely. Reaching your Coast FIRE number means you have <b>permission to stop</b>, not an obligation to stop. Many people continue saving for these reasons:<br /><br /><ul><li><b>Earlier full retirement:</b> Extra contributions accelerate your timeline to full FIRE—you can stop working entirely years sooner.</li><li><b>Fat FIRE upgrade:</b> Continue building toward 30x expenses for a luxury retirement with maximum safety margin.</li><li><b>Legacy planning:</b> A larger portfolio means more to pass on to family or charity.</li><li><b>Buffer zone:</b> Extra savings provide additional protection against sequence-of-returns risk.</li></ul><br />Think of Coast FIRE as the <b>floor</b>, not the ceiling. It is the minimum needed to stay on track, and anything beyond it is bonus flexibility.',
    answerText: 'Yes. Coast FIRE is the minimum—you can always save more to reach full FIRE sooner, upgrade to a luxury retirement, or build a larger safety buffer against market volatility.',
  },
  {
    question: 'How does inflation affect my Coast FIRE number?',
    answerHtml: 'This calculator accounts for inflation by using <b>inflation-adjusted returns</b>. All results are shown in today\'s dollars.<br /><br />The default 7% return assumption already subtracts ~3% inflation from the historical ~10% stock market average, giving you a real (inflation-adjusted) return projection.<br /><br />Key inflation considerations for Coast FIRE:<br /><br /><ul><li><b>Expenses grow with inflation:</b> Your $60,000/year expenses today will be higher in the future. The calculator handles this through the real return assumption.</li><li><b>Your Coast FIRE target adjusts:</b> Because the formula uses real returns, the Coast FIRE number stays in today\'s dollars automatically.</li><li><b>Conservative bias:</b> Using 7% (not 10%) builds in a 3% inflation buffer. For extra safety, use 6%.</li></ul>',
    answerText: 'Inflation is built into the calculator. The 7% default return already subtracts ~3% inflation from historical averages. All results are in today\'s dollars. For extra safety, use 6%.',
  },
];
---

<PageLayout
  title="Coast FIRE Number Calculator — Find Your Coast Fire Number by Age"
  description="Free Coast FIRE number calculator by age. Find out how much to coast fire at 35, 40, or any age, then let compound interest grow your savings to retirement."
  canonical="https://truefinancetools.com/coast-fire-number"
  ogImage="https://truefinancetools.com/og-coast-fire-number.png"
  ogImageAlt="Coast FIRE Number Calculator — Find Your Coast Fire Number by Age"
  pageType="website"
  keywords="coast fire number, coast fire calculator by age, how much to coast fire at 35, coast fire number calculator, coast fire formula, compound interest retirement"
>
  <StructuredData
    title="Coast FIRE Number Calculator"
    description="Free Coast FIRE number calculator by age for estimating how much to save today so compound interest alone reaches your retirement target."
    url="https://truefinancetools.com/coast-fire-number"
    toolName="Coast FIRE Calculator"
    toolDescription="Calculate your Coast FIRE number — the amount you need today so compound interest alone reaches your full retirement target."
    faqItems={coastFaqItems}
    features={[
      'Coast FIRE number by age calculator',
      'Compound interest projection charts',
      'See if your current savings can coast to retirement',
      'Adjust return rate, inflation, and timeline',
      'Compare Coast FIRE against other strategies'
    ]}
  />

  <section class="border-b border-hairline bg-canvas py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h1 class="mb-4 text-3xl font-semibold tracking-tight text-ink sm:text-4xl" style="letter-spacing: -0.02em;">
        Coast FIRE Number Calculator
      </h1>
      <p class="text-lg text-body">Find the amount you need today so compound interest does the rest of the work.</p>
    </div>
  </section>

  <CoastFireNumber />

  <HowItWorks title="How the Coast FIRE Number Calculator Works">
    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">1. Enter Your Age and Retirement Target</h3>
      <p class="text-sm text-body">Tell the calculator your current age and retirement age so it can estimate how many years your savings have to compound.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M12 6a6 6 0 100 12 6 6 0 000-12Zm0 8a2 2 0 100-4 2 2 0 000 4Z" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">2. Add Expenses and Savings</h3>
      <p class="text-sm text-body">Use your annual retirement expenses, current invested assets, expected return, inflation, and withdrawal assumptions.</p>
    </div>

    <div class="text-center">
      <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-canvas-soft-2 text-ink">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path d="M4 19.5h16M6 16.5l4-4 3 3L20 5.5" />
        </svg>
      </div>
      <h3 class="mb-2 text-sm font-semibold text-ink">3. See Your Coast FIRE Number</h3>
      <p class="text-sm text-body">The tool shows the lump sum you need today, your progress, and whether your current savings can coast to retirement.</p>
    </div>
  </HowItWorks>

  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        What is a Coast FIRE Number?
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <p class="mb-4">
          Your <strong>Coast FIRE number</strong> is the amount of money you need saved today so that compound interest alone—with zero additional contributions—will grow your portfolio to your full FIRE number by your target retirement age. It is the most liberating milestone in the FIRE journey: the point where time takes over and your past savings do all the future work.
        </p>

        <p class="mb-4">
          Once you hit your Coast FIRE number, you no longer need to save aggressively for retirement. You can switch to a lower-stress job, work part-time, pursue passion projects, or become a stay-at-home parent—all while knowing your portfolio is on track to reach your full retirement target. This <strong>Coast FIRE calculator by age</strong> helps you find that exact number based on your unique timeline.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">The Coast FIRE Formula</h3>
        <div class="rounded-lg bg-canvas-soft-2 p-4 font-mono text-sm text-ink">
          Coast FIRE Number = (Annual Expenses × 25) / (1 + Return Rate)<sup>Years to Retirement</sup>
        </div>

        <p class="mb-4 mt-4">
          For example, if you spend $60,000/year, your FIRE number is $1,500,000 (25× expenses). If you are 30, plan to retire at 55, and expect 7% annual returns: $1,500,000 / (1.07)<sup>25</sup> = <strong>$276,000</strong>. Once you save $276,000, you have "coasted"—compound interest will grow it to $1.5M by age 55 without another dollar of contributions.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">Coast FIRE vs Full FIRE</h3>
        <div class="overflow-x-auto rounded-lg border border-hairline">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline bg-canvas-soft-2">
                <th class="p-3 font-medium text-ink">Factor</th>
                <th class="p-3 font-medium text-ink">Coast FIRE</th>
                <th class="p-3 font-medium text-ink">Full FIRE</th>
              </tr>
            </thead>
            <tbody class="font-mono text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Savings needed</td>
                <td class="p-3 text-ink">Discounted future target</td>
                <td class="p-3 text-ink">25× current expenses</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Work required</td>
                <td class="p-3 text-ink">Yes (cover living expenses)</td>
                <td class="p-3 text-ink">No (portfolio covers everything)</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Saving required</td>
                <td class="p-3 text-ink">None (portfolio grows itself)</td>
                <td class="p-3 text-ink">None (portfolio covers everything)</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="p-3 text-body font-sans">Best for</td>
                <td class="p-3 text-ink">Career changers, semi-retirees</td>
                <td class="p-3 text-ink">Those ready to stop working entirely</td>
              </tr>
              <tr class="bg-success/5">
                <td class="p-3 font-sans font-semibold text-ink">Key benefit</td>
                <td class="p-3 font-semibold text-success-deep">Flexibility to work on your terms</td>
                <td class="p-3 font-semibold text-success-deep">Complete freedom from work</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Coast FIRE by Age</h3>
        <p class="mb-4">Your Coast FIRE number depends heavily on your age. The earlier you start, the less you need because compound interest has more time to work. Here is how the target changes on <strong>$60,000 annual expenses</strong> with 7% returns and retirement at 65:</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-link">At 25 (40 years to grow)</h4>
            <p class="text-sm text-body">You need roughly <strong>$196,000</strong> saved. That is just 13% of your full FIRE number. Time is your superpower.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-link">At 30 (35 years to grow)</h4>
            <p class="text-sm text-body">You need roughly <strong>$276,000</strong> saved. Just 18% of your full FIRE number. Still excellent runway.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-link">At 35 (30 years to grow)</h4>
            <p class="text-sm text-body">You need roughly <strong>$385,000</strong> saved. About 26% of your full FIRE number—double the 25-year-old target.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-link">At 40 (25 years to grow)</h4>
            <p class="text-sm text-body">You need roughly <strong>$536,000</strong> saved. About 36% of your full FIRE number. Time is running shorter but still powerful.</p>
          </div>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Who Should Use This Calculator?</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Career Changers</h4>
            <p class="text-sm text-body">Switch to lower-paying but fulfilling work once you have coasted. Your savings grow while you enjoy the journey.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Semi-Retirees</h4>
            <p class="text-sm text-body">Reduce to part-time work. Let compound interest cover the gap between part-time income and full retirement.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Young Savers</h4>
            <p class="text-sm text-body">In your 20s or 30s? Time is your biggest asset. Calculate your Coast FIRE number and see how early you can relax.</p>
          </div>
          <div class="rounded-lg border border-hairline bg-canvas p-4">
            <h4 class="mb-2 text-sm font-semibold text-ink">Parents</h4>
            <p class="text-sm text-body">Want to be present for your kids' childhood? Coast FIRE lets you step back from full-time work without derailing retirement.</p>
          </div>
        </div>

        <h3 class="mb-3 mt-8 text-lg font-semibold text-ink">Coast FIRE Pros and Cons</h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div class="rounded-lg border border-success/30 bg-success/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-success-deep">Advantages</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Dramatically lower savings target than full FIRE</li>
              <li>• Permission to pursue lower-stress, fulfilling work</li>
              <li>• Compound interest does the heavy lifting</li>
              <li>• Time is on your side—especially in your 20s and 30s</li>
              <li>• No need to track strict budgets or savings rates</li>
              <li>• Easier transition than going from full work to full retirement</li>
            </ul>
          </div>
          <div class="rounded-lg border border-error/30 bg-error/5 p-4">
            <h4 class="mb-2 text-sm font-semibold text-error">Trade-offs</h4>
            <ul class="space-y-1 text-sm text-body">
              <li>• Still need to earn enough to cover living expenses</li>
              <li>• Sensitive to market returns—a bad decade hurts</li>
              <li>• Less margin for error than full FIRE</li>
              <li>• Sequence-of-returns risk in early years</li>
              <li>• No guarantee of 7% returns over your timeline</li>
              <li>• Delayed full retirement compared to aggressive saving</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-8 text-center text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Frequently Asked Questions About Coast FIRE Numbers
      </h2>

      <div class="space-y-4">
        {coastFaqItems.map((item) => (
          <details class="group rounded-lg border border-hairline bg-canvas p-4 shadow-sm">
            <summary class="cursor-pointer py-2 text-sm font-medium text-ink">{item.question}</summary>
            <p class="mt-3 text-sm text-body" set:html={item.answerHtml} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-hairline bg-canvas py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <h2 class="mb-6 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Complete Guide to Using a Coast FIRE Number Calculator
      </h2>

      <div class="prose prose-gray max-w-none text-body">
        <p class="mb-4">
          A <strong>coast fire number calculator</strong> answers one specific question: how much money do you need invested today so you can stop making retirement contributions and still reach your target by retirement age? This is different from a standard FIRE calculator, which projects how long it will take to build your full retirement portfolio. Coast FIRE focuses on the starting point where compound growth takes over.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">Why Choose Coast FIRE?</h3>

        <p class="mb-4">
          The key advantage of a <strong>Coast FIRE calculator by age</strong> is that it makes time visible. A 25-year-old may need a relatively small percentage of their future FIRE number because decades of growth remain. A 45-year-old may need a much larger lump sum because the compounding window is shorter. By entering your current age and retirement age, you can see how each year changes the target and plan accordingly.
        </p>

        <p class="mb-4">
          For anyone searching <strong>how much to Coast FIRE at 35</strong>, the answer depends on your expenses, expected return, inflation, and retirement age. The calculator helps you test those assumptions instantly. Increase your annual return, lower your retirement expenses, or push retirement later, and your Coast FIRE number adjusts in real time.
        </p>

        <h3 class="mb-3 text-lg font-semibold text-ink">Key Features of This Coast FIRE Number Calculator</h3>

        <p class="mb-4">
          Unlike basic Coast FIRE calculators that just show a formula, our tool is fully interactive and real-time. All calculations happen in your browser—no data is stored on our servers. Adjust your age, retirement age, expenses, return rate, or current savings and watch your Coast FIRE number update instantly. The interactive chart shows your growth trajectory and compares your current savings against the target.
        </p>

        <p class="mb-4">
          The calculator also shows you whether your current savings have already passed the Coast FIRE threshold, and if not, how much more you need to save. Export your plan as a PDF or share your projection with your partner via a unique link. Whether you are just starting your career or are already well into accumulation, this tool helps you find the moment when compound interest takes over and you gain the freedom to work on your terms.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-hairline bg-canvas-soft py-16">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6">
      <h2 class="mb-4 text-2xl font-semibold tracking-tight text-ink" style="letter-spacing: -0.02em;">
        Explore Other FIRE Strategies
      </h2>
      <p class="mb-8 text-body">Compare different approaches to find the right one for your lifestyle.</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a href="/lean-fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Lean FIRE Calculator</h3>
          <p class="text-xs text-body">Minimalist approach with the 20x rule for early retirement.</p>
        </a>
        <a href="/fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Regular FIRE Calculator</h3>
          <p class="text-xs text-body">Comfortable middle-class retirement with the 25x rule.</p>
        </a>
        <a href="/fat-fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Fat FIRE Calculator</h3>
          <p class="text-xs text-body">For those who want a luxury retirement lifestyle.</p>
        </a>
        <a href="/barista-fire-calculator" class="group rounded-lg border border-hairline bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
          <h3 class="mb-2 text-sm font-semibold text-ink group-hover:text-link">Barista FIRE Calculator</h3>
          <p class="text-xs text-body">Work part-time, let investments cover the rest.</p>
        </a>
        <a href="/learn/what-is-fire" class="group rounded-lg border-2 border-ink bg-canvas p-5 text-left shadow-sm transition-all hover:shadow-md">
