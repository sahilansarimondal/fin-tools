---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogImageAlt?: string;
  pageType?: 'website' | 'article';
  keywords?: string;
}

const { title, description, canonical, ogImage, ogImageAlt, pageType, keywords } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  pageType={pageType}
  keywords={keywords}
>
  <Header />

  <main>
    <slot />
  </main>

  <Footer />
</BaseLayout>
