---
---

<button
  id="theme-toggle"
  class="relative flex h-10 w-[56px] items-center rounded-full bg-canvas-soft-2 p-1 transition-colors dark:bg-canvas"
  aria-label="Toggle theme"
>
  <span id="theme-toggle-knob" class="relative z-10 flex h-7 w-7 items-center justify-center rounded-full bg-ink shadow-sm transition-transform dark:bg-white">
    <svg id="theme-icon-moon" class="h-3.5 w-3.5 text-canvas dark:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
    </svg>
    <svg id="theme-icon-sun" class="hidden h-3.5 w-3.5 text-ink dark:block" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
    </svg>
  </span>
</button>

<script>
  function isCurrentlyDark(): boolean {
    return document.documentElement.classList.contains('dark');
  }

  function updateKnobPosition() {
    const knob = document.getElementById('theme-toggle-knob');
    if (!knob) return;
    if (isCurrentlyDark()) {
      knob.style.transform = 'translateX(0)';
    } else {
      knob.style.transform = 'translateX(28px)';
    }
  }

  function applyTheme(dark: boolean) {
    if (dark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }

    const meta = document.querySelector('meta[name="theme-color"]');
    if (meta) {
      meta.setAttribute('content', dark ? '#0a0a0a' : '#fafafa');
    }

    updateKnobPosition();
  }

  function toggleTheme() {
    const dark = !isCurrentlyDark();
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    applyTheme(dark);
  }

  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);

  updateKnobPosition();

  window
    .matchMedia('(prefers-color-scheme: dark)')
    .addEventListener('change', () => {
      if (!localStorage.getItem('theme')) {
        applyTheme(window.matchMedia('(prefers-color-scheme: dark)').matches);
      }
    });
</script>
