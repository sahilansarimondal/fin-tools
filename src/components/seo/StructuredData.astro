---
import { faqItems } from '../../utils/faq-data';

export interface Props {
  title: string;
  description: string;
  url: string;
  type?: string;
}

const { title, description, url, type = 'website' } = Astro.props;

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description,
  url,
  applicationCategory: 'FinanceApplication',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: 'True Finance Tools',
    url: 'https://truefinancetools.com',
  },
  featureList: [
    'FIRE Calculator',
    'Coast FIRE Calculator',
    'Coast FIRE Number Calculator',
    'Barista FIRE Calculator',
    'Lean FIRE Calculator',
    'Fat FIRE Calculator',
    'Retirement Planning',
    'Financial Independence Calculator'
  ],
  applicationSubCategory: 'Retirement Calculator',
  operatingSystem: 'Web Browser',
};

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answerHtml,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
<script type="application/ld+json" set:html={JSON.stringify(faqData)} />
