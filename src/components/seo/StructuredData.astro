---
import { faqItems, type FAQItem } from '../../utils/faq-data';

export interface Props {
  title: string;
  description: string;
  url: string;
  type?: string;
  toolName?: string;
  toolDescription?: string;
  faqItems?: FAQItem[];
  features?: string[];
}

const { title, description, url, type = 'website', toolName, toolDescription, faqItems: pageFaqItems, features } = Astro.props;
const items = pageFaqItems || faqItems;

const defaultFeatures = [
  'FIRE Calculator',
  'Coast FIRE Number Calculator',
  'Barista FIRE Calculator',
  'Lean FIRE Calculator',
  'Fat FIRE Calculator',
  'Retirement Planning',
  'Financial Independence Calculator'
];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: title,
  description,
  url,
  applicationCategory: 'FinanceApplication',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: 'True Finance Tools',
    url: 'https://truefinancetools.com',
  },
  featureList: features || defaultFeatures,
  applicationSubCategory: 'Retirement Calculator',
  operatingSystem: 'Web Browser',
};

const softwareSchema = toolName
  ? {
      '@context': 'https://schema.org',
      '@type': 'SoftwareApplication',
      name: toolName,
      operatingSystem: 'All',
      applicationCategory: 'CalculatorApplication',
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      description: toolDescription || description,
    }
  : null;

const faqData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answerHtml,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
{softwareSchema && <script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />}
<script type="application/ld+json" set:html={JSON.stringify(faqData)} />
