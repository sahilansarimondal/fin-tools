---
import ThemeToggle from '../ui/ThemeToggle.astro';
import Logo from '../ui/Logo.astro';

const currentPath = Astro.url.pathname;

const calculatorCategories = [
  { name: 'FIRE Calculator', href: '/fire-calculator' },
  { name: 'Lean FIRE Calculator', href: '/lean-fire-calculator' },
  { name: 'Fat FIRE Calculator', href: '/fat-fire-calculator' },
  { name: 'Barista FIRE Calculator', href: '/barista-fire-calculator' },
  { name: 'Coast FIRE Number', href: '/coast-fire-number' },
  { name: 'Coast FIRE by Age Calculator', href: '/coast-fire-by-age-calculator' },
  { name: 'Coast FIRE Shift Calculator', href: '/coast-fire-shift-calculator' },
  { name: 'Geographic Arbitrage Calculator', href: '/geographic-arbitrage-calculator' },
  { name: 'Die With Zero Calculator', href: '/die-with-zero-calculator' },
  { name: 'VPW Calculator', href: '/vpw-calculator' },
  { name: 'Perpetual SWR Calculator', href: '/perpetual-swr-calculator' },
  { name: 'Guardrails Withdrawal Calculator', href: '/guardrails-withdrawal-calculator' },
  { name: 'Retirement Bucket Strategy Calculator', href: '/retirement-bucket-strategy-calculator' },
  { name: 'Social Security Bridge Calculator', href: '/social-security-bridge-calculator' },
  { name: 'Sequence of Returns Calculator', href: '/sequence-of-returns-calculator' },
  { name: 'One More Year Calculator', href: '/one-more-year-calculator' },
  { name: 'Bond Tent Calculator', href: '/bond-tent-calculator' },
  { name: 'Owner Earnings Calculator', href: '/owner-earnings-calculator' },
  { name: 'Core-Satellite Rebalancer', href: '/core-satellite-rebalancer' },
  { name: 'Cash Cushion Optimizer', href: '/cash-cushion-optimizer' },
  { name: 'Dividend Tax Drag Calculator', href: '/dividend-tax-drag-calculator' },
  { name: 'Tax Gain Harvesting Calculator', href: '/tax-gain-harvesting-calculator' },
  { name: 'Mega Backdoor Roth Calculator', href: '/mega-backdoor-roth-calculator' },
  { name: 'RSU Sell-to-Cover Tax Calculator', href: '/rsu-sell-to-cover-tax-calculator' },
  { name: 'RSU Vesting Tax Calculator', href: '/rsu-vesting-tax-calculator' },
  { name: 'HSA Shoebox Strategy Calculator', href: '/hsa-shoebox-strategy-calculator' },
  { name: 'HSA vs FSA Calculator', href: '/hsa-vs-fsa-calculator' },
  { name: 'ACA Subsidy Cliff Calculator', href: '/aca-subsidy-cliff-calculator' },
  { name: '72(t) SEPP Calculator', href: '/sepp-calculator' },
  { name: '72(t) vs Roth Ladder Calculator', href: '/72t-vs-roth-conversion-ladder-calculator' },
  { name: '529 vs UTMA/UGMA Calculator', href: '/529-vs-utma-calculator' },
  { name: 'House Hacking Calculator', href: '/house-hacking-calculator' },
  { name: 'JISA vs Bare Trust Calculator', href: '/jisa-vs-bare-trust-calculator' },
  { name: 'LISA vs Workplace Pension Calculator', href: '/lisa-vs-workplace-pension-calculator' },
  { name: 'UK Redundancy Tax Calculator', href: '/uk-redundancy-tax-calculator' },
  { name: 'Mortgage vs ISA Calculator (UK)', href: '/mortgage-overpayment-vs-investing-calculator-uk' },
  { name: 'Refinance Break-Even Calculator', href: '/refinance-break-even-calculator' },
  { name: 'SIPP Drawdown Tax Calculator', href: '/sipp-drawdown-tax-calculator' },
  { name: 'Plan 5 Student Loan Calculator', href: '/plan-5-student-loan-repayment-calculator' },
  { name: 'Salary Sacrifice Pension Calculator', href: '/salary-sacrifice-pension-calculator' },
  { name: 'College Savings Calculator', href: '/529-vs-utma-calculator' },
  { name: 'HICBC Calculator', href: '/hicbc-calculator' },
  { name: 'UK Pension Taper Calculator', href: '/uk-pension-taper-calculator' },
];

const navLinks = [
  { href: '/tools', label: 'Calculators', match: 'prefix' as const },
  { href: '/learn/what-is-fire', label: 'Learn', match: 'prefix-start' as const },
  { href: '/about', label: 'About', match: 'exact' as const },
  { href: '/contact', label: 'Contact', match: 'exact' as const },
];

function isActive(href: string, match: 'prefix' | 'prefix-start' | 'exact'): boolean {
  if (match === 'prefix') return currentPath === href || currentPath.startsWith(href + '/');
  if (match === 'prefix-start') return currentPath.startsWith('/learn');
  return currentPath === href;
}
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-ink transition-opacity hover:opacity-70">
      <Logo class="h-6 w-6" />
      <span class="hidden font-semibold tracking-tight sm:inline">True Finance Tools</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map(({ href, label, match }) => (
        <a
          href={href}
          class:list={[
            'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
            isActive(href, match) ? 'bg-ink text-canvas' : 'text-body hover:text-ink',
          ]}
        >
          {label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />

      <a
        href="/tools"
        class="hidden rounded-full bg-ink px-4 py-2 text-sm font-medium text-canvas transition-opacity hover:opacity-90 md:inline-flex"
      >
        Start Calculating
      </a>

      <button
        id="mobile-menu-toggle"
        class="flex items-center justify-center rounded-md p-3 text-ink md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-hairline bg-canvas transition-all duration-200 ease-in-out md:hidden" role="menu" aria-hidden="true">
    <nav class="flex flex-col gap-1 p-4">
      {navLinks.map(({ href, label, match }) => (
        <a
          href={href}
          class:list={[
            'rounded-lg px-3 py-3 text-sm font-medium transition-colors',
            isActive(href, match)
              ? 'bg-canvas-soft-2 font-semibold text-ink'
              : 'text-body hover:bg-canvas-soft-2 hover:text-ink',
          ]}
          role="menuitem"
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  function toggleMenu() {
    if (menu?.classList.contains('hidden')) {
      openMenu();
    } else {
      closeMenu();
    }
  }

  toggle?.addEventListener('click', toggleMenu);

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('click', (e) => {
    if (!menu?.classList.contains('hidden') && !menu?.contains(e.target as Node) && !toggle?.contains(e.target as Node)) {
      closeMenu();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
      toggle?.focus();
    }
  });
</script>
