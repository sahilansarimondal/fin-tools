---
import ThemeToggle from '../ui/ThemeToggle.astro';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-ink transition-opacity hover:opacity-70">
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2L2 7l10 5 10-5-10-5z" />
        <path d="M2 17l10 5 10-5" />
        <path d="M2 12l10 5 10-5" />
      </svg>
      <span class="hidden font-semibold tracking-tight sm:inline">True Finance Tools</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      <a
        href="/fire-calculator"
        class:list={[
          'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
          currentPath === '/fire-calculator' || currentPath.startsWith('/fire-calculator/')
            ? 'bg-ink text-canvas'
            : 'text-body hover:text-ink',
        ]}
      >
        FIRE Calculator
      </a>
      <a
        href="/tools"
        class:list={[
          'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
          currentPath === '/tools' || currentPath.startsWith('/tools/')
            ? 'bg-ink text-canvas'
            : 'text-body hover:text-ink',
        ]}
      >
        Tools
      </a>
      <a
        href="/learn/what-is-fire"
        class:list={[
          'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
          currentPath.startsWith('/learn') ? 'bg-ink text-canvas' : 'text-body hover:text-ink',
        ]}
      >
        Learn
      </a>
      <a
        href="/about"
        class:list={[
          'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
          currentPath === '/about' ? 'bg-ink text-canvas' : 'text-body hover:text-ink',
        ]}
      >
        About
      </a>
      <a
        href="/contact"
        class:list={[
          'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
          currentPath === '/contact' ? 'bg-ink text-canvas' : 'text-body hover:text-ink',
        ]}
      >
        Contact
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />

      <a
        href="/fire-calculator"
        class="hidden rounded-full bg-ink px-4 py-2 text-sm font-medium text-canvas transition-opacity hover:opacity-90 md:inline-flex"
      >
        Start Planning
      </a>

      <button
        id="mobile-menu-toggle"
        class="flex items-center justify-center rounded-md p-3 text-ink md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-hairline bg-canvas transition-all duration-200 ease-in-out md:hidden" role="menu" aria-hidden="true">
    <nav class="flex flex-col gap-1 p-4">
      <a
        href="/fire-calculator"
        class="rounded-lg px-3 py-3 text-sm font-medium text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        role="menuitem"
      >
        FIRE Calculator
      </a>
      <a
        href="/tools"
        class="rounded-lg px-3 py-3 text-sm font-medium text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        role="menuitem"
      >
        Tools
      </a>
      <a
        href="/learn/what-is-fire"
        class="rounded-lg px-3 py-3 text-sm font-medium text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        role="menuitem"
      >
        Learn
      </a>
      <a
        href="/about"
        class="rounded-lg px-3 py-3 text-sm font-medium text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        role="menuitem"
      >
        About
      </a>
      <a
        href="/contact"
        class="rounded-lg px-3 py-3 text-sm font-medium text-body transition-colors hover:bg-canvas-soft-2 hover:text-ink"
        role="menuitem"
      >
        Contact
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  function toggleMenu() {
    if (menu?.classList.contains('hidden')) {
      openMenu();
    } else {
      closeMenu();
    }
  }

  toggle?.addEventListener('click', toggleMenu);

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('click', (e) => {
    if (!menu?.classList.contains('hidden') && !menu?.contains(e.target as Node) && !toggle?.contains(e.target as Node)) {
      closeMenu();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
      toggle?.focus();
    }
  });
</script>
