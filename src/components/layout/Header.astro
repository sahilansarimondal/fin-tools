---
import ThemeToggle from '../ui/ThemeToggle.astro';
import Logo from '../ui/Logo.astro';

const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/tools', label: 'Calculators', match: 'prefix' as const, hasDropdown: true },
  { href: '/learn/what-is-fire', label: 'Learn', match: 'prefix-start' as const },
  { href: '/about', label: 'About', match: 'exact' as const },
  { href: '/contact', label: 'Contact', match: 'exact' as const },
];

const calculatorCategories = [
  {
    title: 'FIRE Strategies',
    calculators: [
      { href: '/fire-calculator', label: 'FIRE Calculator' },
      { href: '/lean-fire-calculator', label: 'Lean FIRE' },
      { href: '/fat-fire-calculator', label: 'Fat FIRE' },
      { href: '/barista-fire-calculator', label: 'Barista FIRE' },
      { href: '/coast-fire-number', label: 'Coast FIRE Number' },
      { href: '/coast-fire-by-age-calculator', label: 'Coast FIRE by Age' },
      { href: '/coast-fire-shift-calculator', label: 'Coast FIRE Shift' },
      { href: '/geographic-arbitrage-calculator', label: 'Geo Arbitrage' },
    ],
  },
  {
    title: 'Withdrawal & Income',
    calculators: [
      { href: '/die-with-zero-calculator', label: 'Die with Zero' },
      { href: '/vpw-calculator', label: 'VPW Withdrawal' },
      { href: '/perpetual-swr-calculator', label: 'Perpetual SWR' },
      { href: '/guardrails-withdrawal-calculator', label: 'Guardrails Withdrawal' },
      { href: '/retirement-bucket-strategy-calculator', label: 'Bucket Strategy' },
    ],
  },
  {
    title: 'Risk & Analysis',
    calculators: [
      { href: '/sequence-of-returns-calculator', label: 'SRR Stress Test' },
      { href: '/one-more-year-calculator', label: 'OMY Syndrome' },
      { href: '/bond-tent-calculator', label: 'Bond Tent Glide Path' },
      { href: '/cash-cushion-optimizer', label: 'Cash Cushion' },
    ],
  },
  {
    title: 'Portfolio & Tax',
    calculators: [
      { href: '/owner-earnings-calculator', label: 'Owner Earnings' },
      { href: '/core-satellite-rebalancer', label: 'Core-Satellite Rebalancer' },
      { href: '/tax-gain-harvesting-calculator', label: 'Tax Gain Harvesting' },
      { href: '/hsa-shoebox-strategy-calculator', label: 'HSA Shoebox Strategy' },
      { href: '/aca-subsidy-cliff-calculator', label: 'ACA Subsidy Cliff' },
      { href: '/sepp-calculator', label: '72(t) SEPP' },
    ],
  },
  {
    title: 'UK Tools',
    calculators: [
      { href: '/mortgage-overpayment-vs-investing-calculator-uk', label: 'Mortgage vs ISA (UK)' },
      { href: '/sipp-drawdown-tax-calculator', label: 'SIPP Drawdown Tax (UK)' },
    ],
  },
];

function isActive(href: string, match: 'prefix' | 'prefix-start' | 'exact'): boolean {
  if (match === 'prefix') return currentPath === href || currentPath.startsWith(href + '/');
  if (match === 'prefix-start') return currentPath.startsWith('/learn');
  return currentPath === href;
}
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-ink transition-opacity hover:opacity-70">
      <Logo class="h-6 w-6" />
      <span class="hidden font-semibold tracking-tight sm:inline">True Finance Tools</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.map(({ href, label, match, hasDropdown }) => (
        <div class="relative" data-nav-item={hasDropdown ? 'calc-dropdown' : undefined}>
          <a
            href={href}
            class:list={[
              'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
              isActive(href, match) ? 'bg-ink text-canvas' : 'text-body hover:text-ink',
              hasDropdown && 'flex items-center gap-1',
            ]}
          >
            {label}
            {hasDropdown && (
              <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M19 9l-7 7-7-7" />
              </svg>
            )}
          </a>
          {hasDropdown && (
            <div class="calc-dropdown-menu invisible absolute left-0 top-full z-50 mt-1 w-[720px] rounded-lg border border-hairline bg-canvas p-5 shadow-lg opacity-0 transition-all duration-200">
              <div class="grid grid-cols-5 gap-4">
                {calculatorCategories.map((category) => (
                  <div>
                    <p class="mb-2 truncate text-xs font-semibold uppercase tracking-wider text-mute">{category.title}</p>
                    <div class="space-y-0.5">
                      {category.calculators.map((calc) => (
                        <a
                          href={calc.href}
                          class:list={[
                            'block rounded-md px-3 py-1.5 text-sm transition-colors',
                            isActive(calc.href, 'exact')
                              ? 'bg-canvas-soft-2 font-medium text-ink'
                              : 'text-body hover:bg-canvas-soft hover:text-ink',
                          ]}
                        >
                          {calc.label}
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
              <div class="mt-4 border-t border-hairline pt-3">
                <a
                  href="/tools"
                  class:list={[
                    'block rounded-md px-3 py-2 text-sm font-medium transition-colors',
                    isActive('/tools', 'prefix')
                      ? 'bg-canvas-soft-2 text-ink'
                      : 'text-link hover:bg-canvas-soft hover:text-link-deep',
                  ]}
                >
                  Browse All 25+ Tools &rarr;
                </a>
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />

      <a
        href="/tools"
        class="hidden rounded-full bg-ink px-4 py-2 text-sm font-medium text-canvas transition-opacity hover:opacity-90 md:inline-flex"
      >
        Start Calculating
      </a>

      <button
        id="mobile-menu-toggle"
        class="flex items-center justify-center rounded-md p-3 text-ink md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-hairline bg-canvas transition-all duration-200 ease-in-out md:hidden" role="menu" aria-hidden="true">
    <nav class="flex flex-col gap-1 p-4">
      {navLinks.map(({ href, label, match }) => (
        <a
          href={href}
          class:list={[
            'rounded-lg px-3 py-3 text-sm font-medium transition-colors',
            isActive(href, match)
              ? 'bg-canvas-soft-2 font-semibold text-ink'
              : 'text-body hover:bg-canvas-soft-2 hover:text-ink',
          ]}
          role="menuitem"
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
  }

  function toggleMenu() {
    if (menu?.classList.contains('hidden')) {
      openMenu();
    } else {
      closeMenu();
    }
  }

  toggle?.addEventListener('click', toggleMenu);

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  document.addEventListener('click', (e) => {
    if (!menu?.classList.contains('hidden') && !menu?.contains(e.target as Node) && !toggle?.contains(e.target as Node)) {
      closeMenu();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
      toggle?.focus();
    }
  });

  const calcDropdown = document.querySelector('[data-nav-item="calc-dropdown"]');
  const calcDropdownMenu = document.querySelector('.calc-dropdown-menu') as HTMLElement;

  if (calcDropdown && calcDropdownMenu) {
    let timeout: ReturnType<typeof setTimeout>;

    calcDropdown.addEventListener('mouseenter', () => {
      clearTimeout(timeout);
      calcDropdownMenu.classList.remove('invisible', 'opacity-0');
      calcDropdownMenu.classList.add('opacity-100');
    });

    calcDropdown.addEventListener('mouseleave', () => {
      timeout = setTimeout(() => {
        calcDropdownMenu.classList.add('invisible', 'opacity-0');
        calcDropdownMenu.classList.remove('opacity-100');
      }, 150);
    });

    calcDropdownMenu.addEventListener('mouseenter', () => {
      clearTimeout(timeout);
    });

    calcDropdownMenu.addEventListener('mouseleave', () => {
      timeout = setTimeout(() => {
        calcDropdownMenu.classList.add('invisible', 'opacity-0');
        calcDropdownMenu.classList.remove('opacity-100');
      }, 150);
    });
  }
</script>
