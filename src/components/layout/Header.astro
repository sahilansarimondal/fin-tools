---
import ThemeToggle from '../ui/ThemeToggle.astro';
import Logo from '../ui/Logo.astro';

const currentPath = Astro.url.pathname;

const calculatorGroups = [
  {
    label: 'FIRE & Retirement',
    calculators: [
      { name: 'FIRE Calculator', href: '/fire-calculator' },
      { name: 'Lean FIRE Calculator', href: '/lean-fire-calculator' },
      { name: 'Fat FIRE Calculator', href: '/fat-fire-calculator' },
      { name: 'Barista FIRE Calculator', href: '/barista-fire-calculator' },
      { name: 'Coast FIRE Number', href: '/coast-fire-number' },
      { name: 'Coast FIRE by Age', href: '/coast-fire-by-age-calculator' },
      { name: 'Coast FIRE Shift', href: '/coast-fire-shift-calculator' },
      { name: 'Geographic Arbitrage', href: '/geographic-arbitrage-calculator' },
    ],
  },
  {
    label: 'Withdrawal Strategies',
    calculators: [
      { name: 'Die With Zero', href: '/die-with-zero-calculator' },
      { name: 'VPW Calculator', href: '/vpw-calculator' },
      { name: 'Perpetual SWR', href: '/perpetual-swr-calculator' },
      { name: 'Guardrails Withdrawal', href: '/guardrails-withdrawal-calculator' },
      { name: 'Retirement Bucket Strategy', href: '/retirement-bucket-strategy-calculator' },
      { name: 'Social Security Bridge', href: '/social-security-bridge-calculator' },
    ],
  },
  {
    label: 'Tax Optimization',
    calculators: [
      { name: 'Mega Backdoor Roth', href: '/mega-backdoor-roth-calculator' },
      { name: 'Tax Gain Harvesting', href: '/tax-gain-harvesting-calculator' },
      { name: 'Dividend Tax Drag', href: '/dividend-tax-drag-calculator' },
      { name: '72(t) SEPP Calculator', href: '/sepp-calculator' },
      { name: '72(t) vs Roth Ladder', href: '/72t-vs-roth-conversion-ladder-calculator' },
      { name: 'Early 401k vs Roth Conversion', href: '/early-401k-penalty-vs-roth-conversion-calculator' },
      { name: 'ACA Subsidy Cliff', href: '/aca-subsidy-cliff-calculator' },
      { name: 'HSA Shoebox Strategy', href: '/hsa-shoebox-strategy-calculator' },
      { name: 'HSA vs FSA', href: '/hsa-vs-fsa-calculator' },
      { name: 'US Bonus Withholding Tax', href: '/bonus-tax-calculator' },
      { name: 'Side Hustle Tax (SE)', href: '/side-hustle-tax-calculator' },
    ],
  },
  {
    label: 'Portfolio & Analysis',
    calculators: [
      { name: 'Core-Satellite Rebalancer', href: '/core-satellite-rebalancer' },
      { name: 'Owner Earnings', href: '/owner-earnings-calculator' },
      { name: 'Cash Cushion Optimizer', href: '/cash-cushion-optimizer' },
      { name: 'Sequence of Returns', href: '/sequence-of-returns-calculator' },
      { name: 'One More Year Syndrome', href: '/one-more-year-calculator' },
      { name: 'Bond Tent Calculator', href: '/bond-tent-calculator' },
    ],
  },
  {
    label: 'UK Finance',
    calculators: [
      { name: 'Salary Sacrifice Pension', href: '/salary-sacrifice-pension-calculator' },
      { name: 'SIPP Drawdown Tax', href: '/sipp-drawdown-tax-calculator' },
      { name: 'UK Redundancy Tax', href: '/uk-redundancy-tax-calculator' },
      { name: 'LISA vs Workplace Pension', href: '/lisa-vs-workplace-pension-calculator' },
      { name: 'Mortgage vs ISA (UK)', href: '/mortgage-overpayment-vs-investing-calculator-uk' },
      { name: 'Plan 5 Student Loan', href: '/plan-5-student-loan-repayment-calculator' },
      { name: 'JISA vs Bare Trust', href: '/jisa-vs-bare-trust-calculator' },
      { name: 'HICBC Calculator', href: '/hicbc-calculator' },
      { name: 'UK Pension Taper', href: '/uk-pension-taper-calculator' },
      { name: 'Help to Buy Repayment Calculator', href: '/help-to-buy-repayment-calculator' },
    ],
  },
  {
    label: 'Real Estate & Other',
    calculators: [
      { name: 'House Hacking', href: '/house-hacking-calculator' },
      { name: 'Refinance Break-Even', href: '/refinance-break-even-calculator' },
      { name: '529 vs UTMA/UGMA', href: '/529-vs-utma-calculator' },
      { name: 'RSU Sell-to-Cover Tax', href: '/rsu-sell-to-cover-tax-calculator' },
      { name: 'RSU Vesting Tax', href: '/rsu-vesting-tax-calculator' },
    ],
  },
];

const navLinks = [
  { href: '/', label: 'Home', match: 'exact' as const },
  { href: '/tools', label: 'Calculators', match: 'prefix' as const },
  { href: '/learn/what-is-fire', label: 'Learn', match: 'prefix-start' as const },
  { href: '/about', label: 'About', match: 'exact' as const },
  { href: '/contact', label: 'Contact', match: 'exact' as const },
];

function isActive(href: string, match: 'prefix' | 'prefix-start' | 'exact'): boolean {
  if (match === 'prefix') return currentPath === href || currentPath.startsWith(href + '/');
  if (match === 'prefix-start') return currentPath.startsWith('/learn');
  return currentPath === href;
}
---

<header class="sticky top-0 z-50 border-b border-hairline bg-canvas/80 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-ink transition-opacity hover:opacity-70">
      <Logo class="h-6 w-6" />
      <span class="hidden font-semibold tracking-tight sm:inline">True Finance Tools</span>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      {navLinks.filter((l) => l.label !== 'Calculators').map(({ href, label, match }) => (
        <a
          href={href}
          class:list={[
            'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
            isActive(href, match) ? 'bg-ink text-canvas' : 'text-body hover:text-ink',
          ]}
        >
          {label}
        </a>
      ))}

      <!-- Calculators dropdown trigger -->
      <div class="relative" id="calculators-wrapper">
        <button
          id="calculators-trigger"
          class:list={[
            'inline-flex items-center gap-1 rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
            isActive('/tools', 'prefix') ? 'bg-ink text-canvas' : 'text-body hover:text-ink',
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          Calculators
          <svg
            id="calculators-chevron"
            class="h-4 w-4 transition-transform duration-200"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M6 9l6 6 6-6" />
          </svg>
        </button>

        <!-- Mega-menu dropdown -->
        <div
          id="calculators-menu"
          class="absolute left-1/2 top-full z-50 mt-2 hidden w-[640px] -translate-x-1/2 rounded-xl border border-hairline bg-canvas p-6 shadow-lg lg:w-[800px]"
          role="menu"
        >
          <div class="grid grid-cols-3 gap-x-6 gap-y-8">
            {calculatorGroups.map((group) => (
              <div>
                <h3 class="mb-2 text-xs font-semibold uppercase tracking-wider text-ink">{group.label}</h3>
                <ul class="space-y-1">
                  {group.calculators.map((calc) => (
                    <li>
                      <a
                        href={calc.href}
                        class="text-sm text-ink-secondary transition-colors hover:text-ink"
                        role="menuitem"
                      >
                        {calc.name}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
          <div class="mt-4 border-t border-hairline pt-4">
            <a href="/tools" class="text-sm font-medium text-ink transition-colors hover:text-ink-secondary">
              View All Calculators &rarr;
            </a>
          </div>
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />

      <a
        href="/tools"
        class="hidden rounded-full bg-ink px-4 py-2 text-sm font-medium text-canvas transition-opacity hover:opacity-90 md:inline-flex"
      >
        Start Calculating
      </a>

      <button
        id="mobile-menu-toggle"
        class="flex items-center justify-center rounded-md p-3 text-ink md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M3 12h18M3 6h18M3 18h18" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-hairline bg-canvas transition-all duration-200 ease-in-out md:hidden"
    role="menu"
    aria-hidden="true"
  >
    <nav class="flex max-h-[80vh] flex-col gap-1 overflow-y-auto p-4">
      {navLinks.filter((l) => l.label !== 'Calculators').map(({ href, label, match }) => (
        <a
          href={href}
          class:list={[
            'rounded-lg px-3 py-3 text-sm font-medium transition-colors',
            isActive(href, match)
              ? 'bg-canvas-soft-2 font-semibold text-ink'
              : 'text-body hover:bg-canvas-soft-2 hover:text-ink',
          ]}
          role="menuitem"
        >
          {label}
        </a>
      ))}

      <!-- Mobile Calculators accordion -->
      <div class="rounded-lg bg-canvas-soft">
        <button
          data-mobile-accordion-trigger
          class="flex w-full items-center justify-between px-3 py-3 text-sm font-medium text-body transition-colors hover:text-ink"
          aria-expanded="false"
        >
          Calculators
          <svg
            data-mobile-accordion-chevron
            class="h-4 w-4 transition-transform duration-200"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path d="M6 9l6 6 6-6" />
          </svg>
        </button>
        <div data-mobile-accordion-content class="hidden px-3 pb-3">
          {calculatorGroups.map((group) => (
            <div class="mt-3">
              <h4 class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-ink">
                {group.label}
              </h4>
              <ul class="space-y-0.5">
                {group.calculators.map((calc) => (
                  <li>
                    <a
                      href={calc.href}
                      class="block rounded px-2 py-1.5 text-sm text-ink-secondary transition-colors hover:bg-canvas-soft-2 hover:text-ink"
                      role="menuitem"
                    >
                      {calc.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
          <a
            href="/tools"
            class="mt-3 block rounded px-2 py-2 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
            role="menuitem"
          >
            View All Calculators &rarr;
          </a>
        </div>
      </div>

      <!-- Mobile CTA -->
      <a
        href="/tools"
        class="mt-2 rounded-full bg-ink px-4 py-3 text-center text-sm font-medium text-canvas transition-opacity hover:opacity-90"
        role="menuitem"
      >
        Start Calculating
      </a>
    </nav>
  </div>
</header>

<script>
  // --- Mobile menu toggle ---
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');

  function openMenu() {
    menu?.classList.remove('hidden');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
  }

  function closeMenu() {
    menu?.classList.add('hidden');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');

    // Collapse the mobile accordion when menu closes
    collapseMobileAccordion();
  }

  function toggleMenu() {
    if (menu?.classList.contains('hidden')) {
      openMenu();
    } else {
      closeMenu();
    }
  }

  toggle?.addEventListener('click', toggleMenu);

  // Close mobile menu when clicking a link inside it
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close mobile menu on outside click
  document.addEventListener('click', (e) => {
    if (
      !menu?.classList.contains('hidden') &&
      !menu?.contains(e.target as Node) &&
      !toggle?.contains(e.target as Node)
    ) {
      closeMenu();
    }
  });

  // Close mobile menu on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
      toggle?.focus();
    }
  });

  // --- Desktop calculators mega-menu ---
  const calculatorsTrigger = document.getElementById('calculators-trigger');
  const calculatorsMenu = document.getElementById('calculators-menu');
  const calculatorsChevron = document.getElementById('calculators-chevron');
  const calculatorsWrapper = document.getElementById('calculators-wrapper');

  function openCalculatorsMenu() {
    calculatorsMenu?.classList.remove('hidden');
    calculatorsTrigger?.setAttribute('aria-expanded', 'true');
    calculatorsChevron?.classList.add('rotate-180');
  }

  function closeCalculatorsMenu() {
    calculatorsMenu?.classList.add('hidden');
    calculatorsTrigger?.setAttribute('aria-expanded', 'false');
    calculatorsChevron?.classList.remove('rotate-180');
  }

  calculatorsTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    if (calculatorsMenu?.classList.contains('hidden')) {
      openCalculatorsMenu();
    } else {
      closeCalculatorsMenu();
    }
  });

  // Close mega-menu on outside click
  document.addEventListener('click', (e) => {
    if (
      !calculatorsMenu?.classList.contains('hidden') &&
      !calculatorsWrapper?.contains(e.target as Node)
    ) {
      closeCalculatorsMenu();
    }
  });

  // Close mega-menu on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !calculatorsMenu?.classList.contains('hidden')) {
      closeCalculatorsMenu();
      calculatorsTrigger?.focus();
    }
  });

  // --- Mobile calculators accordion ---
  const mobileAccordionTrigger = document.querySelector('[data-mobile-accordion-trigger]');
  const mobileAccordionContent = document.querySelector('[data-mobile-accordion-content]');
  const mobileAccordionChevron = document.querySelector('[data-mobile-accordion-chevron]');

  function collapseMobileAccordion() {
    mobileAccordionContent?.classList.add('hidden');
    mobileAccordionChevron?.classList.remove('rotate-180');
    mobileAccordionTrigger?.setAttribute('aria-expanded', 'false');
  }

  mobileAccordionTrigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isOpen = !mobileAccordionContent?.classList.contains('hidden');
    if (isOpen) {
      collapseMobileAccordion();
    } else {
      mobileAccordionContent?.classList.remove('hidden');
      mobileAccordionChevron?.classList.add('rotate-180');
      mobileAccordionTrigger?.setAttribute('aria-expanded', 'true');
    }
  });
</script>
