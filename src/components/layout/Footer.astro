---
import Logo from '../ui/Logo.astro';

const year = new Date().getFullYear();

const linkClass = 'text-sm text-body transition-colors hover:text-ink py-2.5 inline-block';

const footerSections = [
  {
    title: 'Learn',
    links: [
      { href: '/learn/what-is-fire', label: 'What is FIRE?' },
      { href: '/learn/fire-strategies', label: 'FIRE Strategies' },
      { href: '/learn/barista-fire', label: 'Barista FIRE' },
      { href: '/learn/fire-number', label: 'Your FIRE Number' },
    ],
  },
  {
    title: 'Company',
    links: [
      { href: '/about', label: 'About' },
      { href: '/contact', label: 'Contact' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { href: '/privacy', label: 'Privacy Policy' },
      { href: '/terms', label: 'Terms & Conditions' },
    ],
  },
];
---

<footer class="border-t border-hairline bg-canvas">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a href="/" class="flex items-center gap-2 text-ink">
          <Logo class="h-5 w-5" />
          <span class="text-sm font-semibold tracking-tight">True Finance Tools</span>
        </a>
        <p class="mt-3 text-sm text-mute">
          Free tools to calculate your path to financial independence and early retirement.
        </p>
      </div>

      <!-- Calculators (featured) -->
      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-mute">Calculators</h3>
        <ul class="space-y-2">
          <li><a href="/tools" class={linkClass + ' font-medium'}>All Tools →</a></li>
        </ul>
        <ul class="mt-3 space-y-2">
          <li><a href="/fire-calculator" class={linkClass}>FIRE Calculator</a></li>
          <li><a href="/coast-fire-number" class={linkClass}>Coast FIRE Number</a></li>
          <li><a href="/vpw-calculator" class={linkClass}>VPW Withdrawal</a></li>
          <li><a href="/social-security-bridge-calculator" class={linkClass}>Social Security Bridge</a></li>
          <li><a href="/72t-vs-roth-conversion-ladder-calculator" class={linkClass}>72(t) vs Roth Ladder</a></li>
          <li><a href="/aca-subsidy-cliff-calculator" class={linkClass}>ACA Subsidy Cliff</a></li>
          <li><a href="/mortgage-overpayment-vs-investing-calculator-uk" class={linkClass}>Mortgage vs ISA (UK)</a></li>
          <li><a href="/mega-backdoor-roth-calculator" class={linkClass}>Mega Backdoor Roth</a></li>
          <li><a href="/tax-gain-harvesting-calculator" class={linkClass}>Tax Gain Harvesting</a></li>
        </ul>
      </div>

      {footerSections.map((section) => (
        <div>
          <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-mute">{section.title}</h3>
          <ul class="space-y-2">
            {section.links.map((link) => (
              <li><a href={link.href} class={linkClass}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-hairline pt-8 sm:flex-row">
      <p class="text-xs text-mute">&copy; {year} True Finance Tools. All rights reserved.</p>
      <p class="text-xs text-mute">
        This calculator provides estimates only. Consult a financial advisor for personalized advice.
      </p>
    </div>
  </div>
</footer>
