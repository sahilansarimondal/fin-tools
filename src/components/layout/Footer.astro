---
const year = new Date().getFullYear();
---

<footer class="border-t border-hairline bg-canvas">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 sm:py-16">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2 text-ink">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 2L2 7l10 5 10-5-10-5z" />
            <path d="M2 17l10 5 10-5" />
            <path d="M2 12l10 5 10-5" />
          </svg>
          <span class="text-sm font-semibold tracking-tight">True Finance Tools</span>
        </a>
        <p class="mt-3 text-sm text-mute">
          Free tools to calculate your path to financial independence and early retirement.
        </p>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-mute">Calculators</h3>
        <ul class="space-y-2">
          <li><a href="/tools" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">All Tools</a></li>
          <li><a href="/fire-calculator" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">FIRE Calculator</a></li>
          <li><a href="/fire-calculator?fireType=lean" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Lean FIRE</a></li>
          <li><a href="/fire-calculator?fireType=fat" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Fat FIRE</a></li>
          <li><a href="/fire-calculator?fireType=coast" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Coast FIRE</a></li>
          <li><a href="/fire-calculator?fireType=barista" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Barista FIRE</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-mute">Learn</h3>
        <ul class="space-y-2">
          <li><a href="/learn/what-is-fire" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">What is FIRE?</a></li>
          <li><a href="/learn/fire-strategies" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">FIRE Strategies</a></li>
          <li><a href="/learn/barista-fire" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Barista FIRE</a></li>
          <li><a href="/learn/fire-number" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Your FIRE Number</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-mute">Company</h3>
        <ul class="space-y-2">
          <li><a href="/about" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">About</a></li>
          <li><a href="/contact" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Contact</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-mute">Legal</h3>
        <ul class="space-y-2">
          <li><a href="/privacy" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Privacy Policy</a></li>
          <li><a href="/terms" class="text-sm text-body transition-colors hover:text-ink py-2.5 inline-block">Terms &amp; Conditions</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-hairline pt-8 sm:flex-row">
      <p class="text-xs text-mute">&copy; {year} True Finance Tools. All rights reserved.</p>
      <p class="text-xs text-mute">
        This calculator provides estimates only. Consult a financial advisor for personalized advice.
      </p>
    </div>
  </div>
</footer>
