---
import Card from '../ui/Card.astro';
import Input from '../ui/Input.astro';
import Slider from '../ui/Slider.astro';
import ResultCard from '../ui/ResultCard.astro';
import Button from '../ui/Button.astro';
---

<div id="coast-fire-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
  <div class="mb-8 text-center">
    <p class="mb-2 font-mono text-xs uppercase tracking-wider text-mute">Free Calculator</p>
    <h1 class="mb-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl" style="letter-spacing: -0.02em;">
      Coast FIRE Number Calculator
    </h1>
    <p class="mx-auto max-w-2xl text-body">
      Find out how much you need to save to reach Coast FIRE and let compound interest carry you to retirement.
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <Card padding="lg" class="lg:sticky lg:top-24">
        <form id="coast-form" class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <Input label="Current Age" name="currentAge" type="number" value={30} min={18} max={80} required />
            <Input label="Retirement Age" name="retirementAge" type="number" value={65} min={30} max={90} required />
          </div>

          <Input label="Annual Retirement Expenses" name="annualExpenses" type="number" value={50000} min={0} step={1000} suffix="$" hideArrows required />

          <Input label="Current Invested Assets" name="currentSavings" type="number" value={50000} min={0} step={1000} suffix="$" hideArrows required />

          <Input label="Monthly Contributions" name="monthlyContributions" type="number" value={0} min={0} step={100} suffix="$" hideArrows helpText="Leave at $0 to check your pure Coast FIRE number" tooltip="Coast FIRE is calculated as a lump sum you need today — one lump of savings that grows on its own. But if you haven't hit that number yet, adding small monthly contributions can help you reach it sooner. Set this to $0 to see the true Coast FIRE target, or add contributions to see how extra savings accelerate your path." />

          <Slider
            label="Withdrawal Multiplier"
            name="withdrawalMultiplier"
            value={25} min={20} max={40} step={1}
            suffix="x"
            inputId="withdrawalMultiplier"
            displayId="withdrawalMultiplierValue"
            helpText="Higher = more conservative"
            tooltip="The number of times your annual expenses you need saved. 25x = 4% withdrawal rule. Higher = more conservative. Lower = more aggressive."
          />

          <div class="grid gap-4 sm:grid-cols-2">
            <Slider
              label="Annual Return"
              name="annualReturn"
              value={7} min={1} max={15} step={0.5}
              suffix="%"
              inputId="annualReturn"
              displayId="annualReturnValue"
              tooltip="The average annual return of the S&P 500 has been ~10% historically. We recommend using 7% for conservative long-term planning."
            />
            <Slider
              label="Inflation Rate"
              name="inflation"
              value={3} min={0} max={8} step={0.5}
              suffix="%"
              inputId="inflation"
              displayId="inflationValue"
              tooltip="The general rise in prices over time. Historical average is ~3%. Higher inflation means higher retirement expenses and a larger nest egg needed."
            />
          </div>

          <div class="grid gap-4 sm:grid-cols-2">
            <Slider
              label="Safe Withdrawal Rate"
              name="swr"
              value={4} min={2} max={6} step={0.5}
              suffix="%"
              inputId="swr"
              displayId="swrValue"
              tooltip="The '4% rule' from the Trinity Study. This assumes you withdraw this percentage of your portfolio annually with a high probability of your money lasting 30+ years."
            />
            <Slider
              label="Investment Fees"
              name="fees"
              value={0.18} min={0} max={3} step={0.1}
              suffix="%"
              inputId="fees"
              displayId="feesValue"
              tooltip="The annual expense ratio of your investments. Index funds charge 0.03-0.10%. Over decades, even small fees significantly reduce portfolio growth."
            />
          </div>
        </form>
      </Card>
    </div>

    <div class="space-y-6 lg:col-span-7">
      <div id="coast-status" class="rounded-lg border bg-canvas p-6 shadow-sm">
        <div class="flex items-start gap-4">
          <div id="coast-icon" class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-success-deep/10">
            <svg class="h-6 w-6 text-success-deep" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div class="min-w-0 flex-1">
            <p id="coast-status-title" class="text-lg font-semibold text-ink">Calculating...</p>
            <p id="coast-status-desc" class="mt-1 text-sm text-body">Adjust your inputs to see your Coast FIRE status.</p>
            <div class="mt-4">
              <div class="h-2 w-full overflow-hidden rounded-full bg-hairline">
                <div id="coast-progress-bar" class="h-full rounded-full bg-success-deep transition-all duration-500" style="width: 0%"></div>
              </div>
              <div class="mt-1 flex justify-between text-xs text-mute">
                <span id="coast-progress-label">0% of Coast Number</span>
                <span id="coast-progress-target">100%</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div id="results-summary" class="grid gap-4 sm:grid-cols-2">
        <ResultCard label="Coast FIRE Number" valueId="coast-number" value="$—" description="Amount needed today to coast" />
        <ResultCard label="Your Current Savings" valueId="current-savings-display" value="$—" valueClass="text-ink" description="What you have invested now" />
        <ResultCard label="FIRE Number" valueId="fire-number-display" value="$—" description="Target at retirement" />
        <ResultCard label="Projected at Retirement" valueId="projected-retirement" value="$—" valueClass="text-link" description="What your savings will grow to" />
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <ResultCard label="Coast Age" valueId="coast-age" value="—" description="When you'll reach Coast FIRE" />
        <ResultCard label="Annual Income" valueId="projected-income" value="$—" valueClass="text-success-deep" description="Projected from your portfolio" />
        <ResultCard label="Gap to Coast" valueId="coast-gap" value="$—" description="Additional savings needed" />
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-sm font-medium text-ink">Portfolio Growth Projection</h2>
          <div class="flex gap-2">
            <button id="chart-type-line" class="chart-type-btn rounded-md cursor-pointer bg-ink px-3 py-2.5 text-xs font-medium text-canvas" data-active="true">Line</button>
            <button id="chart-type-bar" class="chart-type-btn rounded-md cursor-pointer bg-canvas-soft-2 px-3 py-2.5 text-xs font-medium text-body hover:text-ink" data-active="false">Bar</button>
          </div>
        </div>
        <div class="relative h-64 sm:h-80">
          <canvas id="projection-chart"></canvas>
        </div>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <details class="group">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-ink">
            <span>Year-by-Year Projection</span>
            <svg class="h-4 w-4 text-mute transition-transform group-open:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="mt-4 overflow-x-auto">
            <table class="w-full text-left text-xs tabular-nums">
              <thead>
                <tr class="border-b border-hairline">
                  <th class="pb-2 pr-4 font-medium text-mute">Age</th>
                  <th class="pb-2 pr-4 font-medium text-mute">Year</th>
                  <th class="pb-2 pr-4 font-medium text-mute">Savings</th>
                  <th class="pb-2 pr-4 font-medium text-mute">Growth</th>
                  <th class="pb-2 pr-4 font-medium text-mute">Contributions</th>
                  <th class="pb-2 font-medium text-mute">Target</th>
                </tr>
              </thead>
              <tbody id="projection-table-body" class="text-body">
              </tbody>
            </table>
          </div>
        </details>
      </div>

      <div class="flex flex-wrap gap-3">
        <button
          id="export-pdf"
          class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Export PDF
        </button>

        <button
          id="share-results"
          class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          Share
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { calculateCoastFire, type CoastFireInput } from '../../utils/coast-fire-calculations';
  import { formatCurrency, formatCurrencyShort } from '../../utils/formatters';

  let chart: any = null;

  function getFormData(): CoastFireInput {
    const form = document.getElementById('coast-form') as HTMLFormElement;
    const formData = new FormData(form);

    return {
      currentAge: Number(formData.get('currentAge')) || 30,
      retirementAge: Number(formData.get('retirementAge')) || 65,
      annualExpenses: Number(formData.get('annualExpenses')) || 50000,
      currentSavings: Number(formData.get('currentSavings')) || 50000,
      monthlyContributions: Number(formData.get('monthlyContributions')) || 0,
      annualReturnRate: Number(formData.get('annualReturn')) || 7,
      inflationRate: Number(formData.get('inflation')) || 3,
      safeWithdrawalRate: Number(formData.get('swr')) || 4,
      annualFees: Number(formData.get('fees')) || 0.18,
      withdrawalMultiplier: Number(formData.get('withdrawalMultiplier')) || 25,
    };
  }

  function updateResults() {
    const input = getFormData();
    const result = calculateCoastFire(input);

    const isDark = document.documentElement.classList.contains('dark');

    document.getElementById('coast-number')!.textContent = formatCurrency(result.coastNumber);
    document.getElementById('current-savings-display')!.textContent = formatCurrency(input.currentSavings);
    document.getElementById('fire-number-display')!.textContent = formatCurrency(result.futureFireNumber);
    document.getElementById('projected-retirement')!.textContent = formatCurrency(result.projectedValueAtRetirement);
    document.getElementById('projected-income')!.textContent = formatCurrency(result.projectedAnnualIncome);
    document.getElementById('coast-age')!.textContent = result.coastAge !== null ? `${result.coastAge}` : '—';

    document.getElementById('coast-progress-bar')!.style.width = `${result.progress}%`;
    document.getElementById('coast-progress-label')!.textContent = `${result.progress.toFixed(1)}% of Coast Number`;

    const gapEl = document.getElementById('coast-gap')!;
    gapEl.textContent = result.hasReachedCoast ? `+${formatCurrency(result.surplus)}` : formatCurrency(result.gap);

    const statusTitle = document.getElementById('coast-status-title')!;
    const statusDesc = document.getElementById('coast-status-desc')!;
    const statusBox = document.getElementById('coast-status')!;
    const coastIcon = document.getElementById('coast-icon')!;
    const progressBar = document.getElementById('coast-progress-bar')!;

    if (result.hasReachedCoast) {
      statusTitle.textContent = 'You\'ve Reached Coast FIRE!';
      statusDesc.textContent = `Your savings of ${formatCurrency(input.currentSavings)} will grow to ${formatCurrency(result.futureFireNumber)} by retirement — no more contributions needed.`;
      statusBox.className = 'rounded-lg border bg-canvas p-6 shadow-sm border-success/30';
      coastIcon.className = 'flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-success/10';
      coastIcon.innerHTML = `<svg class="h-6 w-6 text-success-deep" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M5 13l4 4L19 7" /></svg>`;
      progressBar.className = 'h-full rounded-full bg-success-deep transition-all duration-500';
      gapEl.className = 'tabular-nums text-success-deep';
    } else {
      statusTitle.textContent = 'Still on Your Way';
      statusDesc.textContent = `You need ${formatCurrency(result.gap)} more to reach your Coast FIRE number of ${formatCurrency(result.coastNumber)}.`;
      statusBox.className = 'rounded-lg border bg-canvas p-6 shadow-sm border-warning/30';
      coastIcon.className = 'flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-warning/10';
      coastIcon.innerHTML = `<svg class="h-6 w-6 text-warning" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
      progressBar.className = 'h-full rounded-full bg-warning transition-all duration-500';
      gapEl.className = 'tabular-nums text-warning';
    }

    updateChart(result.projection, result.futureFireNumber);

    const tbody = document.getElementById('projection-table-body')!;
    tbody.innerHTML = result.projection.map((p, i) => {
      const highlighted = p.savings >= p.target && i > 0;
      return `
        <tr class="${highlighted ? 'bg-success/5' : ''} ${i < result.projection.length - 1 ? 'border-b border-hairline/50' : ''}">
          <td class="py-1.5 pr-4 ${highlighted ? 'font-medium text-success-deep' : 'text-body'}">${p.age}</td>
          <td class="py-1.5 pr-4 text-mute">${p.year}</td>
          <td class="py-1.5 pr-4 font-medium text-ink">${formatCurrencyShort(p.savings)}</td>
          <td class="py-1.5 pr-4 text-mute">${formatCurrencyShort(p.growth)}</td>
          <td class="py-1.5 pr-4 text-mute">${formatCurrencyShort(p.contributions)}</td>
          <td class="py-1.5 text-mute">${formatCurrencyShort(p.target)}</td>
        </tr>
      `;
    }).join('');
  }

  function updateChart(projection: any[], fireNumber: number) {
    const ctx = document.getElementById('projection-chart') as HTMLCanvasElement;
    if (!ctx) return;

    const maxTicks = Math.min(projection.length, 8);
    const step = Math.max(1, Math.floor(projection.length / maxTicks));
    const indices = projection.map((_, i) => i).filter((i) => i % step === 0 || i === projection.length - 1);

    const labels = indices.map((i) => `Age ${projection[i].age}`);
    const savingsData = indices.map((i) => projection[i].savings);
    const targetData = indices.map((i) => projection[i].target);

    if (chart) {
      chart.destroy();
    }

    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? '#262626' : '#ebebeb';
    const textColor = isDark ? '#737373' : '#888888';
    const tooltipBg = isDark ? '#ededed' : '#171717';
    const tooltipText = isDark ? '#171717' : '#ffffff';
    const linkColor = isDark ? '#3291ff' : '#0070f3';
    const successColor = isDark ? '#50e3c2' : '#29bc9b';

    chart = new (window as any).Chart(ctx, {
      type: document.getElementById('chart-type-line')?.dataset.active === 'true' ? 'line' : 'bar',
      data: {
        labels,
        datasets: [
          {
            label: 'Portfolio Value',
            data: savingsData,
            borderColor: linkColor,
            backgroundColor: isDark ? 'rgba(50, 145, 255, 0.1)' : 'rgba(0, 112, 243, 0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
          {
            label: 'FIRE Target',
            data: targetData,
            borderColor: successColor,
            backgroundColor: 'transparent',
            borderDash: [5, 5],
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index',
        },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'end',
            labels: {
              boxWidth: 12,
              boxHeight: 2,
              usePointStyle: false,
              padding: 16,
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
            },
          },
          tooltip: {
            backgroundColor: tooltipBg,
            titleColor: tooltipText,
            bodyColor: tooltipText,
            borderColor: tooltipBg,
            borderWidth: 1,
            padding: 12,
            titleFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
              weight: 500,
            },
            bodyFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
            },
            callbacks: {
              label: function (context: any) {
                return `${context.dataset.label}: ${formatCurrency(context.parsed.y)}`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              font: { family: 'Inter, system-ui, sans-serif', size: 11 },
              color: textColor,
              maxTicksLimit: 8,
            },
            border: { display: false },
          },
          y: {
            grid: { color: gridColor },
            ticks: {
              font: { family: 'Inter, system-ui, sans-serif', size: 11 },
              color: textColor,
              callback: function (value: any) {
                return formatCurrencyShort(value);
              },
            },
            border: { display: false },
          },
        },
      },
    });
  }

  function initSliders() {
    const sliders = [
      { id: 'withdrawalMultiplier', displayId: 'withdrawalMultiplierValue', suffix: 'x' },
      { id: 'annualReturn', displayId: 'annualReturnValue', suffix: '%' },
      { id: 'inflation', displayId: 'inflationValue', suffix: '%' },
      { id: 'swr', displayId: 'swrValue', suffix: '%' },
      { id: 'fees', displayId: 'feesValue', suffix: '%' },
    ];

    sliders.forEach(({ id, displayId, suffix }) => {
      const slider = document.getElementById(id) as HTMLInputElement;
      const display = document.getElementById(displayId);

      if (slider && display) {
        slider.addEventListener('input', () => {
          display.textContent = `${slider.value}${suffix}`;
          updateResults();
        });
      }
    });
  }

  function initChartTypeToggle() {
    const lineBtn = document.getElementById('chart-type-line');
    const barBtn = document.getElementById('chart-type-bar');

    lineBtn?.addEventListener('click', () => {
      lineBtn.dataset.active = 'true';
      lineBtn.classList.add('bg-ink', 'text-canvas');
      lineBtn.classList.remove('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      barBtn!.dataset.active = 'false';
      barBtn!.classList.remove('bg-ink', 'text-canvas');
      barBtn!.classList.add('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      updateResults();
    });

    barBtn?.addEventListener('click', () => {
      barBtn.dataset.active = 'true';
      barBtn.classList.add('bg-ink', 'text-canvas');
      barBtn.classList.remove('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      lineBtn!.dataset.active = 'false';
      lineBtn!.classList.remove('bg-ink', 'text-canvas');
      lineBtn!.classList.add('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      updateResults();
    });
  }

  function initFormListeners() {
    const form = document.getElementById('coast-form') as HTMLFormElement;
    form?.addEventListener('input', () => {
      updateResults();
    });
  }

  function initExport() {
    document.getElementById('export-pdf')?.addEventListener('click', async () => {
      const { default: html2canvas } = await import('html2canvas');
      const { default: jsPDF } = await import('jspdf');

      const element = document.getElementById('coast-fire-calculator')!;
      const canvas = await html2canvas(element);
      const imgData = canvas.toDataURL('image/png');

      const pdf = new jsPDF('p', 'mm', 'a4');
      const pdfWidth = pdf.internal.pageSize.getWidth();
      const pdfHeight = (canvas.height * pdfWidth) / canvas.width;

      pdf.addImage(imgData, 'PNG', 0, 0, pdfWidth, pdfHeight);
      pdf.save('coast-fire-number-results.pdf');
    });
  }

  function initShare() {
    document.getElementById('share-results')?.addEventListener('click', async () => {
      const input = getFormData();
      const params = new URLSearchParams({
        age: input.currentAge.toString(),
        retire: input.retirementAge.toString(),
        expenses: input.annualExpenses.toString(),
        savings: input.currentSavings.toString(),
        monthly: input.monthlyContributions.toString(),
        return: input.annualReturnRate.toString(),
        inflation: input.inflationRate.toString(),
        swr: input.safeWithdrawalRate.toString(),
        fees: input.annualFees.toString(),
        multiplier: input.withdrawalMultiplier.toString(),
      });

      const url = `${window.location.origin}/coast-fire-number?${params.toString()}`;

      if (navigator.share) {
        try {
          await navigator.share({
            title: 'My Coast FIRE Number Results',
            text: 'Check out my Coast FIRE plan!',
            url,
          });
        } catch (err) {
          navigator.clipboard.writeText(url);
          alert('Link copied to clipboard!');
        }
      } else {
        navigator.clipboard.writeText(url);
        alert('Link copied to clipboard!');
      }
    });
  }

  function loadFromUrl() {
    const params = new URLSearchParams(window.location.search);
    if (params.has('age')) {
      const form = document.getElementById('coast-form') as HTMLFormElement;
      const fields: Record<string, string> = {
        currentAge: 'age',
        retirementAge: 'retire',
        annualExpenses: 'expenses',
        currentSavings: 'savings',
        monthlyContributions: 'monthly',
        annualReturn: 'return',
        inflation: 'inflation',
        swr: 'swr',
        fees: 'fees',
        withdrawalMultiplier: 'multiplier',
      };

      Object.entries(fields).forEach(([fieldId, param]) => {
        const input = document.getElementById(fieldId) as HTMLInputElement;
        if (input && params.has(param)) {
          input.value = params.get(param)!;
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadFromUrl();
    initSliders();
    initChartTypeToggle();
    initFormListeners();
    initExport();
    initShare();
    updateResults();

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      updateResults();
    });

    const observer = new MutationObserver(() => {
      updateResults();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  });
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
