---
import Card from '../ui/Card.astro';
import Input from '../ui/Input.astro';
import Slider from '../ui/Slider.astro';
import { formatCurrency, formatCurrencyShort } from '../../utils/formatters';
---

<div id="coast-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
  <div class="mb-8 text-center">
    <p class="mb-2 font-mono text-xs uppercase tracking-wider text-mute">Free Calculator</p>
    <h1 class="mb-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl" style="letter-spacing: -0.02em;">
      Coast FIRE Number Calculator
    </h1>
    <p class="mx-auto max-w-2xl text-body">
      Find your Coast FIRE number by age. See how much you need today so compound interest alone gets you to retirement.
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <Card padding="lg" class="lg:sticky lg:top-24">
        <div class="mb-6 rounded-md bg-canvas-soft-2 p-3 text-xs text-body">
          <span class="font-medium text-ink">Coast FIRE:</span> The amount you need today for compound interest to grow to your FIRE number — with zero additional contributions.
        </div>

        <form id="coast-form" class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <Input label="Current Age" name="currentAge" type="number" value={30} min={18} max={70} required />
            <Input label="Target Retirement Age" name="retirementAge" type="number" value={55} min={30} max={80} required />
          </div>

          <Input label="Current Savings & Investments" name="currentSavings" type="number" value={50000} min={0} step={1000} suffix="$" required />

          <Slider label="Expected Annual Return" name="annualReturn" value={7} min={1} max={15} step={0.5} suffix="%" inputId="annualReturn" displayId="annualReturnValue" />

          <div class="border-t border-hairline pt-4">
            <div class="mb-2 flex items-center justify-between">
              <label for="annualExpenses" class="text-sm font-medium text-ink">Annual Expenses</label>
              <span id="expenses-badge" class="rounded-full bg-canvas-soft-2 px-2 py-0.5 text-xs text-mute">Optional</span>
            </div>
            <Input label="" name="annualExpenses" type="number" value={60000} min={0} step={1000} suffix="$" helpText="Used to calculate your FIRE number (25x). Defaults to $60,000 if empty." class="mt-0" />
          </div>
        </form>
      </Card>
    </div>

    <div class="space-y-6 lg:col-span-7">
      <div id="coast-status" class="rounded-lg border border-hairline bg-canvas p-6 shadow-sm">
        <div class="flex items-start gap-4">
          <div id="status-icon" class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-success/10">
            <svg class="h-6 w-6 text-success" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <p id="status-title" class="text-lg font-semibold text-ink">Calculating...</p>
            <p id="status-description" class="text-sm text-body">Enter your details to find your Coast FIRE number.</p>
          </div>
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-mute">Coast FIRE Number</p>
          <p id="coast-number" class="text-2xl font-semibold tabular-nums text-ink">$0</p>
          <p class="mt-1 text-xs text-mute">Needed today</p>
        </div>
        <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-mute">Your FIRE Number</p>
          <p id="fire-number" class="text-2xl font-semibold tabular-nums text-ink">$0</p>
          <p class="mt-1 text-xs text-mute">25x annual expenses</p>
        </div>
        <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
          <p class="mb-1 text-xs font-medium uppercase tracking-wider text-mute">Progress</p>
          <p id="coast-progress" class="text-2xl font-semibold tabular-nums text-ink">0%</p>
          <p class="mt-1 text-xs text-mute">Towards Coast FIRE</p>
        </div>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <p class="text-sm font-medium text-ink">Coast FIRE Progress</p>
          <p id="progress-percent" class="font-mono text-sm text-mute">0%</p>
        </div>
        <div class="h-3 w-full overflow-hidden rounded-full bg-canvas-soft-2">
          <div id="progress-bar" class="h-full rounded-full bg-link transition-all duration-500" style="width: 0%"></div>
        </div>
        <div class="mt-2 flex justify-between text-xs text-mute">
          <span>$0</span>
          <span id="progress-target">$0</span>
        </div>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas shadow-sm">
        <div class="flex items-center justify-between border-b border-hairline p-4">
          <p class="text-sm font-medium text-ink">Growth Without Contributions</p>
          <div class="flex gap-1">
            <button id="chart-line-btn" class="rounded-md bg-ink px-3 py-1 text-xs font-medium text-canvas">Line</button>
            <button id="chart-bar-btn" class="rounded-md bg-canvas-soft-2 px-3 py-1 text-xs font-medium text-body hover:text-ink">Bar</button>
          </div>
        </div>
        <div class="p-4">
          <div class="relative h-72">
            <canvas id="coast-chart"></canvas>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <p class="mb-3 text-sm font-medium text-ink">Projected Portfolio at Retirement</p>
        <div class="grid gap-4 sm:grid-cols-2">
          <div>
            <p class="text-xs text-mute">Your savings at <span id="retirement-age-label">55</span></p>
            <p id="projected-value" class="text-lg font-semibold tabular-nums text-ink">$0</p>
          </div>
          <div>
            <p class="text-xs text-mute">FIRE target</p>
            <p id="projected-target" class="text-lg font-semibold tabular-nums text-ink">$0</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
  import { calculateCoastFireNumber } from '../../utils/calculations';
  import { formatCurrency, formatCurrencyShort } from '../../utils/formatters';

  const form = document.getElementById('coast-form') as HTMLFormElement;
  let chart: any = null;
  let chartType: 'line' | 'bar' = 'line';

  function getFormData() {
    const fd = new FormData(form);
    const annualExpenses = Number(fd.get('annualExpenses')) || 60000;
    return {
      currentAge: Number(fd.get('currentAge')) || 30,
      retirementAge: Number(fd.get('retirementAge')) || 55,
      currentSavings: Number(fd.get('currentSavings')) || 50000,
      annualReturnRate: Number(fd.get('annualReturn')) || 7,
      annualExpenses,
    };
  }

  function updateResults() {
    const data = getFormData();
    const result = calculateCoastFireNumber(data);

    const statusIcon = document.getElementById('status-icon')!;
    const statusTitle = document.getElementById('status-title')!;
    const statusDesc = document.getElementById('status-description')!;
    const coastNumber = document.getElementById('coast-number')!;
    const fireNumber = document.getElementById('fire-number')!;
    const coastProgress = document.getElementById('coast-progress')!;
    const progressBar = document.getElementById('progress-bar')!;
    const progressPercent = document.getElementById('progress-percent')!;
    const progressTarget = document.getElementById('progress-target')!;
    const retirementAgeLabel = document.getElementById('retirement-age-label')!;
    const projectedValue = document.getElementById('projected-value')!;
    const projectedTarget = document.getElementById('projected-target')!;

    coastNumber.textContent = formatCurrency(result.coastNumber);
    fireNumber.textContent = formatCurrency(result.fireNumber);
    coastProgress.textContent = `${Math.round(result.progress)}%`;
    progressBar.style.width = `${Math.min(result.progress, 100)}%`;
    progressPercent.textContent = `${Math.round(result.progress)}%`;
    progressTarget.textContent = formatCurrency(result.coastNumber);
    retirementAgeLabel.textContent = String(data.retirementAge);
    projectedValue.textContent = formatCurrency(result.projectedValue);
    projectedTarget.textContent = formatCurrency(result.fireNumber);

    if (result.hasCoasted) {
      statusIcon.className = 'flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-success/10';
      statusIcon.innerHTML = '<svg class="h-6 w-6 text-success" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>';
      statusTitle.textContent = "You've hit Coast FIRE!";
      statusTitle.className = 'text-lg font-semibold text-success-deep';
      statusDesc.textContent = `Your $${formatCurrencyShort(data.currentSavings)} in savings will compound to ${formatCurrency(result.projectedValue)} by age ${data.retirementAge}. You no longer need to save aggressively.`;
      progressBar.className = 'h-full rounded-full bg-success transition-all duration-500';
    } else {
      statusIcon.className = 'flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-link/10';
      statusIcon.innerHTML = '<svg class="h-6 w-6 text-link" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
      statusTitle.textContent = `You need ${formatCurrency(result.gap)} more`;
      statusTitle.className = 'text-lg font-semibold text-ink';
      statusDesc.textContent = `Save ${formatCurrency(result.gap)} more to reach your Coast FIRE number of ${formatCurrency(result.coastNumber)}. After that, compound interest does the rest.`;
      progressBar.className = 'h-full rounded-full bg-link transition-all duration-500';
    }

    updateChart(result.projection, result.fireNumber);
  }

  function updateChart(projection: any[], fireNumber: number) {
    const canvas = document.getElementById('coast-chart') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    if (chart) chart.destroy();

    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? '#262626' : '#ebebeb';
    const textColor = isDark ? '#737373' : '#888888';
    const linkColor = isDark ? '#3291ff' : '#0070f3';
    const errorColor = isDark ? '#ff4444' : '#ee0000';
    const successColor = isDark ? '#29bc9b' : '#50e3c2';

    const labels = projection.filter((_: any, i: number) => i % 2 === 0 || i === projection.length - 1).map((p: any) => `Age ${p.age}`);
    const savingsData = projection.filter((_: any, i: number) => i % 2 === 0 || i === projection.length - 1).map((p: any) => p.savings);
    const targetData = projection.filter((_: any, i: number) => i % 2 === 0 || i === projection.length - 1).map(() => fireNumber);

    chart = new (window as any).Chart(ctx, {
      type: chartType,
      data: {
        labels,
        datasets: [
          {
            label: 'Portfolio Growth',
            data: savingsData,
            borderColor: linkColor,
            backgroundColor: chartType === 'line' ? `${linkColor}15` : `${linkColor}80`,
            fill: true,
            tension: 0.3,
            pointRadius: 0,
            borderWidth: 2,
          },
          {
            label: 'FIRE Target',
            data: targetData,
            borderColor: errorColor,
            borderDash: [5, 5],
            backgroundColor: chartType === 'bar' ? `${errorColor}30` : 'transparent',
            fill: false,
            pointRadius: 0,
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: {
            display: true,
            position: 'bottom',
            labels: { color: textColor, usePointStyle: true, padding: 16, font: { size: 12 } },
          },
          tooltip: {
            backgroundColor: isDark ? '#1a1a1a' : '#ffffff',
            titleColor: isDark ? '#ededed' : '#171717',
            bodyColor: isDark ? '#a3a3a3' : '#4d4d4d',
            borderColor: isDark ? '#262626' : '#ebebeb',
            borderWidth: 1,
            padding: 12,
            callbacks: {
              label: (ctx: any) => `${ctx.dataset.label}: ${formatCurrency(ctx.raw)}`,
            },
          },
        },
        scales: {
          x: { grid: { color: gridColor }, ticks: { color: textColor, font: { size: 11 } } },
          y: {
            grid: { color: gridColor },
            ticks: { color: textColor, font: { size: 11 }, callback: (v: any) => formatCurrencyShort(v) },
          },
        },
      },
    });
  }

  function initSliders() {
    const returnSlider = document.getElementById('annualReturn') as HTMLInputElement;
    const returnValue = document.getElementById('annualReturnValue');

    if (returnSlider && returnValue) {
      returnSlider.addEventListener('input', () => {
        returnValue.textContent = `${returnSlider.value}%`;
        updateResults();
      });
    }
  }

  function initChartTypeToggle() {
    const lineBtn = document.getElementById('chart-line-btn');
    const barBtn = document.getElementById('chart-bar-btn');

    lineBtn?.addEventListener('click', () => {
      chartType = 'line';
      lineBtn.className = 'rounded-md bg-ink px-3 py-1 text-xs font-medium text-canvas';
      barBtn!.className = 'rounded-md bg-canvas-soft-2 px-3 py-1 text-xs font-medium text-body hover:text-ink';
      updateResults();
    });

    barBtn?.addEventListener('click', () => {
      chartType = 'bar';
      barBtn.className = 'rounded-md bg-ink px-3 py-1 text-xs font-medium text-canvas';
      lineBtn!.className = 'rounded-md bg-canvas-soft-2 px-3 py-1 text-xs font-medium text-body hover:text-ink';
      updateResults();
    });
  }

  function loadFromUrl() {
    const params = new URLSearchParams(window.location.search);
    const fields: Record<string, string> = {
      currentAge: 'currentAge',
      retirementAge: 'retirementAge',
      savings: 'currentSavings',
      return: 'annualReturn',
      expenses: 'annualExpenses',
    };
    for (const [param, name] of Object.entries(fields)) {
      const val = params.get(param);
      if (val !== null) {
        const input = form.querySelector(`[name="${name}"]`) as HTMLInputElement;
        if (input) input.value = val;
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadFromUrl();
    initSliders();
    initChartTypeToggle();
    form.addEventListener('input', updateResults);
    updateResults();

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => updateResults());
    new MutationObserver(() => updateResults()).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  });
</script>
