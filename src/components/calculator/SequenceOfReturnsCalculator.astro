---
import Card from '../ui/Card.astro';
import Input from '../ui/Input.astro';
import Slider from '../ui/Slider.astro';
import ResultCard from '../ui/ResultCard.astro';
---

<div id="srr-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
  <div class="grid gap-6 lg:grid-cols-12">
    <!-- LEFT PANEL: Inputs (5 cols) -->
    <div class="lg:col-span-5">
      <Card padding="lg" class="lg:sticky lg:top-24">
        <!-- Stress Scenario Dropdown -->
        <div class="mb-6">
          <label class="mb-2 block text-sm font-medium text-ink">Historical Crash Scenario</label>
          <select
            id="srr-scenario"
            name="stressScenario"
            class="w-full rounded-md border border-hairline bg-canvas px-3 py-2.5 text-sm text-ink shadow-sm focus:border-link focus:outline-none focus:ring-1 focus:ring-link"
          >
            <option value="dotcom">Dot-Com Bubble (2000–2002)</option>
            <option value="gfc">Global Financial Crisis (2008)</option>
            <option value="stagflation">Stagflation (1973–1974)</option>
            <option value="custom">Custom Stress Test</option>
          </select>
        </div>

        <!-- Custom Returns Inputs (hidden by default) -->
        <div id="srr-custom-inputs" class="mb-4 hidden space-y-3 rounded-lg border border-hairline bg-canvas-soft p-4">
          <p class="text-xs font-medium text-mute">Custom Crash Returns (Years 1–3)</p>
          <Input label="Year 1 Return" name="customY1" type="number" value={-20} min={-50} max={50} step={1} suffix="%" hideArrows required />
          <Input label="Year 2 Return" name="customY2" type="number" value={-15} min={-50} max={50} step={1} suffix="%" hideArrows required />
          <Input label="Year 3 Return" name="customY3" type="number" value={-10} min={-50} max={50} step={1} suffix="%" hideArrows required />
        </div>

        <!-- Form Inputs -->
        <form id="srr-form" class="space-y-4">
          <Input
            label="Initial Portfolio"
            name="initialPortfolio"
            type="number"
            value={1000000}
            min={0}
            step={10000}
            suffix="$"
            hideArrows
            required
          />
          <Input
            label="Annual Withdrawal"
            name="initialAnnualWithdrawal"
            type="number"
            value={40000}
            min={0}
            step={1000}
            suffix="$"
            hideArrows
            required
          />
          <Slider
            label="Inflation Rate"
            name="annualInflationRate"
            value={3}
            min={0}
            max={8}
            step={0.5}
            suffix="%"
            inputId="srr-inflation"
            displayId="srr-inflationValue"
            tooltip="Expected annual inflation rate"
          />
          <Slider
            label="Average Annual Return"
            name="averageReturn"
            value={7}
            min={1}
            max={15}
            step={0.5}
            suffix="%"
            inputId="srr-avgReturn"
            displayId="srr-avgReturnValue"
            tooltip="Baseline steady return for comparison"
          />
        </form>
      </Card>
    </div>

    <!-- RIGHT PANEL: Results (7 cols) -->
    <div class="space-y-6 lg:col-span-7">
      <!-- KPI cards row (3 cards) -->
      <div class="grid gap-4 sm:grid-cols-3">
        <ResultCard
          label="Average Scenario"
          valueId="srr-avg-survival"
          value="Survived 30+ Years"
          valueClass="text-success-deep"
          description="Steady returns — portfolio survives"
        />
        <ResultCard
          label="Stress Scenario"
          valueId="srr-stress-survival"
          value="FAILED in Year 17"
          valueClass="text-error"
          description="Crash + withdrawals = depleted"
        />
        <ResultCard
          label="Initial SWR"
          valueId="srr-swr"
          value="4.0%"
          valueClass="text-link"
          description="Safe Withdrawal Rate"
        />
      </div>

      <!-- Chart -->
      <Card padding="lg">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-sm font-medium text-ink">Portfolio Projection: Steady vs. Crash</h2>
        </div>
        <div class="relative h-64 sm:h-80">
          <canvas
            id="srr-chart"
            role="img"
            aria-label="Chart comparing portfolio projections under steady returns versus a market crash scenario over 30 years"
          ></canvas>
        </div>
      </Card>
    </div>
  </div>
</div>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>

<script>
  import { calculateSRR, buildStressReturns, STRESS_SCENARIOS } from '../../utils/srr-calculations';
  import { formatCurrency, formatCurrencyShort } from '../../utils/formatters';

  let chart = null;

  function getFormData() {
    const form = document.getElementById('srr-form');
    const formData = new FormData(form);
    const scenario = document.getElementById('srr-scenario').value;

    return {
      initialPortfolio: Number(formData.get('initialPortfolio')) || 1000000,
      initialAnnualWithdrawal: Number(formData.get('initialAnnualWithdrawal')) || 40000,
      annualInflationRate: Number(formData.get('annualInflationRate')) || 3,
      averageReturn: Number(formData.get('averageReturn')) || 7,
      stressScenario: scenario,
      customReturns: scenario === 'custom'
        ? [
            Number(formData.get('customY1')) || 0,
            Number(formData.get('customY2')) || 0,
            Number(formData.get('customY3')) || 0,
          ]
        : undefined,
    };
  }

  function updateResults() {
    const input = getFormData();
    const result = calculateSRR(input);

    // Update KPI cards
    const avgSurvivalEl = document.getElementById('srr-avg-survival');
    const stressSurvivalEl = document.getElementById('srr-stress-survival');
    const swrEl = document.getElementById('srr-swr');

    if (result.averageSurvivalYears >= 30) {
      avgSurvivalEl.textContent = 'Survived 30+ Years';
      avgSurvivalEl.className = 'text-2xl font-semibold tabular-nums text-success-deep';
    } else {
      avgSurvivalEl.textContent = 'FAILED in Year ' + result.averageSurvivalYears;
      avgSurvivalEl.className = 'text-2xl font-semibold tabular-nums text-error';
    }

    if (result.stressSurvivalYears >= 30) {
      stressSurvivalEl.textContent = 'Survived 30+ Years';
      stressSurvivalEl.className = 'text-2xl font-semibold tabular-nums text-success-deep';
    } else {
      stressSurvivalEl.textContent = 'FAILED in Year ' + result.stressSurvivalYears;
      stressSurvivalEl.className = 'text-2xl font-semibold tabular-nums text-error';
    }

    swrEl.textContent = result.initialSWR.toFixed(1) + '%';

    updateChart(result);
  }

  function updateChart(result) {
    const ctx = document.getElementById('srr-chart');
    if (!ctx) return;
    if (chart) chart.destroy();

    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? '#262626' : '#ebebeb';
    const textColor = isDark ? '#737373' : '#888888';
    const tooltipBg = isDark ? '#ededed' : '#171717';
    const tooltipText = isDark ? '#171717' : '#ffffff';
    const linkColor = isDark ? '#3291ff' : '#0070f3';
    const errorColor = isDark ? '#ff4444' : '#ee0000';

    const labels = result.averageData.map(function (d) {
      return 'Year ' + d.year;
    });
    const avgData = result.averageData.map(function (d) {
      return d.endBalance;
    });
    const stressData = result.stressData.map(function (d) {
      return d.endBalance;
    });

    chart = new window.Chart(ctx, {
      type: 'line',
      data: {
        labels: labels,
        datasets: [
          {
            label: 'Steady Returns',
            data: avgData,
            borderColor: linkColor,
            backgroundColor: isDark
              ? 'rgba(50,145,255,0.1)'
              : 'rgba(0,112,243,0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
          {
            label: 'Stress Scenario',
            data: stressData,
            borderColor: errorColor,
            backgroundColor: isDark
              ? 'rgba(255,68,68,0.1)'
              : 'rgba(238,0,0,0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
            borderDash: [5, 5],
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index',
        },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'end',
            labels: {
              boxWidth: 12,
              boxHeight: 2,
              usePointStyle: false,
              padding: 16,
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
            },
          },
          tooltip: {
            backgroundColor: tooltipBg,
            titleColor: tooltipText,
            bodyColor: tooltipText,
            borderColor: tooltipBg,
            borderWidth: 1,
            padding: 12,
            titleFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
              weight: 500,
            },
            bodyFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
            },
            callbacks: {
              label: function (context) {
                return (
                  context.dataset.label +
                  ': ' +
                  formatCurrency(context.parsed.y)
                );
              },
            },
          },
        },
        scales: {
          x: {
            grid: {
              display: false,
            },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              maxTicksLimit: 8,
            },
            border: {
              display: false,
            },
          },
          y: {
            grid: {
              color: gridColor,
            },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              callback: function (value) {
                return formatCurrencyShort(value);
              },
            },
            border: {
              display: false,
            },
            min: 0,
          },
        },
      },
    });
  }

  function initScenarioDropdown() {
    const dropdown = document.getElementById('srr-scenario');
    const customInputs = document.getElementById('srr-custom-inputs');

    dropdown.addEventListener('change', function () {
      if (dropdown.value === 'custom') {
        customInputs.classList.remove('hidden');
      } else {
        customInputs.classList.add('hidden');
      }
      updateResults();
    });
  }

  function initSliders() {
    const sliders = [
      {
        id: 'srr-inflation',
        displayId: 'srr-inflationValue',
        suffix: '%',
      },
      {
        id: 'srr-avgReturn',
        displayId: 'srr-avgReturnValue',
        suffix: '%',
      },
    ];

    sliders.forEach(function (slider) {
      var el = document.getElementById(slider.id);
      var display = document.getElementById(slider.displayId);

      if (el && display) {
        el.addEventListener('input', function () {
          display.textContent = el.value + slider.suffix;
          updateResults();
        });
      }
    });
  }

  function initFormListeners() {
    var form = document.getElementById('srr-form');
    if (form) {
      form.addEventListener('input', function () {
        updateResults();
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    initScenarioDropdown();
    initSliders();
    initFormListeners();
    updateResults();

    window
      .matchMedia('(prefers-color-scheme: dark)')
      .addEventListener('change', function () {
        updateResults();
      });

    var observer = new MutationObserver(function () {
      updateResults();
    });
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });
  });
</script>
