---
import Card from '../ui/Card.astro';
import Input from '../ui/Input.astro';
import ResultCard from '../ui/ResultCard.astro';
---

<div id="ur-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
  <div class="grid gap-6 lg:grid-cols-12">
    <!-- LEFT PANEL: Inputs (5 cols, sticky) -->
    <div class="lg:col-span-5">
      <Card padding="lg" class="lg:sticky lg:top-24">
        <form id="ur-form" class="space-y-4">
          <Input
            label="Total Gross Redundancy Package"
            name="totalGrossPackage"
            type="number"
            value={50000}
            min={0}
            max={2000000}
            step={1000}
            suffix="£"
            hideArrows
            required
            tooltip="The total gross value of everything your employer is paying you upon termination."
          />

          <Input
            label="Non-Qualifying Compensation"
            name="nonQualifyingCompensation"
            type="number"
            value={5000}
            min={0}
            max={2000000}
            step={500}
            suffix="£"
            hideArrows
            required
            tooltip="Payments like Notice Pay (PILON), accrued holiday pay, final salary, or bonuses. These are fully taxable as normal earnings and do not qualify for the £30,000 exemption."
          />

          <Input
            label="Current Taxable Income This Year"
            name="currentYearIncome"
            type="number"
            value={30000}
            min={0}
            max={2000000}
            step={1000}
            suffix="£"
            hideArrows
            required
            tooltip="Your total taxable earnings received from the start of the current tax year up until your redundancy date."
          />

          <div class="flex flex-col gap-1.5">
            <label for="ur-region" class="inline-flex items-center gap-1.5 text-sm font-medium text-ink">
              Tax Region
              <span class="group relative inline-flex shrink-0">
                <span class="inline-flex h-4 w-4 cursor-help items-center justify-center rounded-full bg-hairline text-[10px] font-semibold leading-none text-mute transition-colors hover:bg-hairline-strong hover:text-ink" aria-label="Select your region to apply the correct HMRC income tax bands.">?</span>
                <span class="pointer-events-none absolute bottom-full left-1/2 z-50 mb-2 w-56 -translate-x-1/2 rounded-lg border border-hairline bg-canvas px-3 py-2 text-xs leading-relaxed text-body opacity-0 shadow-lg transition-opacity duration-150 group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:pointer-events-auto group-focus-within:opacity-100" role="tooltip">
                  Select your region to apply the correct HMRC income tax bands.
                  <span class="absolute left-1/2 top-full -translate-x-1/2 border-4 border-transparent border-t-hairline"></span>
                </span>
              </span>
            </label>
            <select
              id="ur-region"
              name="region"
              class="h-11 w-full rounded-md border border-hairline bg-canvas px-3 text-base text-ink transition-colors focus:border-link focus:outline-none focus:ring-2 focus:ring-link/20"
            >
              <option value="england" selected>England, Wales &amp; Northern Ireland</option>
              <option value="scotland">Scotland</option>
            </select>
          </div>
        </form>
      </Card>
    </div>

    <!-- RIGHT PANEL: Results (7 cols) -->
    <div class="space-y-6 lg:col-span-7">
      <!-- Headline KPI -->
      <div id="ur-headline-card" class="rounded-lg border border-hairline bg-canvas p-6 shadow-sm text-center">
        <p class="mb-1 text-xs font-medium uppercase tracking-wider text-mute">Estimated Net Take-Home Pay</p>
        <p id="ur-net-take-home" class="text-3xl font-semibold tabular-nums text-ink sm:text-4xl">—</p>
        <p id="ur-net-label" class="mt-1 text-sm text-mute">Adjust inputs to see your estimated take-home pay</p>
      </div>

      <!-- 3 KPI cards -->
      <div class="grid gap-4 sm:grid-cols-3">
        <ResultCard
          label="Tax-Free Amount"
          valueId="ur-tax-free"
          value="—"
          valueClass="text-success-deep"
          description="£30,000 exemption on qualifying redundancy"
        />
        <ResultCard
          label="Income Tax on Package"
          valueId="ur-income-tax"
          value="—"
          valueClass="text-error"
          description="Marginal income tax on non-qualifying + excess"
        />
        <ResultCard
          label="Employee NI Deducted"
          valueId="ur-employee-ni"
          value="—"
          valueClass="text-error"
          description="NI on non-qualifying compensation only"
        />
      </div>

      <!-- Itemized Breakdown Table -->
      <Card padding="lg">
        <h2 class="mb-4 text-sm font-medium text-ink">Itemised Take-Home Pay Breakdown</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline">
                <th class="pb-2 font-medium text-mute">Item</th>
                <th class="pb-2 text-right font-medium text-mute">Amount</th>
              </tr>
            </thead>
            <tbody class="font-mono text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="py-2 font-sans text-body">Gross Redundancy Package</td>
                <td id="tb-gross-package" class="py-2 text-right text-ink">—</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 font-sans text-body">Less: Non-Qualifying Compensation</td>
                <td id="tb-non-qualifying" class="py-2 text-right text-error">—</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 font-sans font-medium text-ink">= Qualifying Redundancy</td>
                <td id="tb-qualifying" class="py-2 text-right font-medium text-ink">—</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 font-sans text-body">Less: £30,000 Tax-Free Exemption</td>
                <td id="tb-tax-free-exemption" class="py-2 text-right text-success-deep">—</td>
              </tr>
              <tr class="border-b border-hairline bg-canvas-soft">
                <td class="py-2 font-sans font-medium text-ink">= Taxable Excess</td>
                <td id="tb-taxable-excess" class="py-2 text-right font-medium text-ink">—</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 font-sans text-body">Income Tax on Package</td>
                <td id="tb-income-tax" class="py-2 text-right text-error">—</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 font-sans text-body">Employee NI on Non-Qualifying Pay</td>
                <td id="tb-ni" class="py-2 text-right text-error">—</td>
              </tr>
              <tr class="bg-success/5">
                <td class="py-2 font-sans font-semibold text-ink">Net Take-Home Pay</td>
                <td id="tb-net" class="py-2 text-right font-semibold text-success-deep">—</td>
              </tr>
            </tbody>
          </table>
        </div>
      </Card>

      <!-- Validation Warning -->
      <div id="ur-validation-warning" class="hidden rounded-lg border border-error/30 bg-error/5 p-4">
        <p class="text-sm font-medium text-error">⚠ Non-Qualifying Exceeds Gross Package</p>
        <p class="mt-1 text-xs text-body">Non-qualifying compensation exceeds total gross package. Qualifying redundancy set to £0. Check your inputs — the £30,000 tax-free exemption only applies to the genuine redundancy portion of your package.</p>
      </div>

      <!-- Employer NI Note -->
      <div class="rounded-lg border border-hairline bg-canvas-soft p-4">
        <p class="text-xs text-mute">
          <strong>Note:</strong> Your employer pays 15% Class 1A NI on any qualifying redundancy payment exceeding £30,000. This does not affect your take-home pay.
        </p>
      </div>

      <!-- Disclaimer -->
      <div class="rounded-lg bg-canvas-soft p-4">
        <p class="text-xs text-mute">
          <strong>Disclaimer:</strong> This calculator provides estimates based on HMRC 2026/27 tax year rules. It does not constitute tax, legal, or financial advice. Actual tax liabilities may differ based on your individual circumstances. Consult a qualified tax advisor or HMRC for official guidance.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  import { calculateRedundancyTax } from '../../utils/uk-redundancy-calculations';
  import { formatGBP } from '../../utils/formatters';

  function getFormData() {
    var form = document.getElementById('ur-form');
    var formData = new FormData(form);

    return {
      totalGrossPackage: Number(formData.get('totalGrossPackage')) || 50000,
      nonQualifyingCompensation: Number(formData.get('nonQualifyingCompensation')) || 5000,
      currentYearIncome: Number(formData.get('currentYearIncome')) || 30000,
      region: formData.get('region') || 'england',
    };
  }

  function updateResults() {
    var input = getFormData();
    var r = calculateRedundancyTax(input);

    // Headline
    var netTakeHomeEl = document.getElementById('ur-net-take-home');
    var netLabelEl = document.getElementById('ur-net-label');
    var headlineCard = document.getElementById('ur-headline-card');

    if (r.netTakeHome >= 0) {
      netTakeHomeEl.textContent = formatGBP(r.netTakeHome);
      netTakeHomeEl.className = 'text-3xl font-semibold tabular-nums text-success-deep sm:text-4xl';
      netLabelEl.textContent = 'This is your estimated take-home pay after all deductions.';
      headlineCard.className = 'rounded-lg border border-success/30 bg-success/5 p-6 shadow-sm text-center';
    } else {
      netTakeHomeEl.textContent = formatGBP(r.netTakeHome);
      netTakeHomeEl.className = 'text-3xl font-semibold tabular-nums text-error sm:text-4xl';
      netLabelEl.textContent = 'Your take-home pay is negative. Review your inputs.';
      headlineCard.className = 'rounded-lg border border-error/30 bg-error/5 p-6 shadow-sm text-center';
    }

    // KPI cards
    document.getElementById('ur-tax-free').textContent = formatGBP(r.taxFreePortion);
    document.getElementById('ur-income-tax').textContent = formatGBP(r.incomeTaxOnPackage);
    document.getElementById('ur-employee-ni').textContent = formatGBP(r.employeeNIOnNonQualifying);

    // Table
    document.getElementById('tb-gross-package').textContent = formatGBP(r.qualifyingRedundancy + input.nonQualifyingCompensation);
    document.getElementById('tb-non-qualifying').textContent = '- ' + formatGBP(input.nonQualifyingCompensation);
    document.getElementById('tb-qualifying').textContent = formatGBP(r.qualifyingRedundancy);
    document.getElementById('tb-tax-free-exemption').textContent = '- ' + formatGBP(r.taxFreePortion);
    document.getElementById('tb-taxable-excess').textContent = formatGBP(r.taxableExcess);
    document.getElementById('tb-income-tax').textContent = '- ' + formatGBP(r.incomeTaxOnPackage);
    document.getElementById('tb-ni').textContent = '- ' + formatGBP(r.employeeNIOnNonQualifying);
    document.getElementById('tb-net').textContent = formatGBP(r.netTakeHome);

    // Net row color
    var tbNet = document.getElementById('tb-net');
    if (r.netTakeHome >= 0) {
      tbNet.className = 'py-2 text-right font-semibold text-success-deep';
    } else {
      tbNet.className = 'py-2 text-right font-semibold text-error';
    }

    // Validation Warning
    var validationWarning = document.getElementById('ur-validation-warning');
    if (r.validationError) {
      validationWarning.classList.remove('hidden');
    } else {
      validationWarning.classList.add('hidden');
    }
  }

  function initFormListeners() {
    var form = document.getElementById('ur-form');
    if (form) {
      form.addEventListener('input', function () {
        updateResults();
      });
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    initFormListeners();
    updateResults();

    // Theme change observer
    var observer = new MutationObserver(function () {
      updateResults();
    });
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });
  });
</script>
