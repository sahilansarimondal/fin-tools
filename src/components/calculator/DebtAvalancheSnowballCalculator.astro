---
import Card from '../ui/Card.astro';
import ResultCard from '../ui/ResultCard.astro';
---

<div id="debt-avalanche-snowball-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
  <div class="grid gap-6 lg:grid-cols-12">
    <!-- LEFT PANEL: Inputs -->
    <div class="lg:col-span-5">
      <Card padding="lg" class="lg:sticky lg:top-24">
        <div class="mb-4">
          <p class="mb-2 text-sm font-semibold text-ink">Add Your Debts</p>
          <p class="text-xs text-body">Enter each debt's balance, APR, and minimum payment. Set your monthly budget below.</p>
        </div>

        <div id="debt-list" class="space-y-4">
          <!-- Debt rows injected by JS -->
        </div>

        <button id="add-debt-btn" type="button" class="mt-3 w-full rounded-lg border-2 border-dashed border-hairline py-2 text-sm font-medium text-body transition-colors hover:border-ink hover:text-ink">
          + Add Another Debt
        </button>

        <div class="mt-6 border-t border-hairline pt-4">
          <label class="mb-2 block text-sm font-medium text-ink" for="monthly-budget">Total Monthly Budget</label>
          <div class="relative">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-sm text-body" id="currency-symbol">$</span>
            <input id="monthly-budget" type="number" value="500" min="0" step="50" class="w-full rounded-lg border border-hairline bg-canvas py-2 pl-8 pr-3 text-sm text-ink outline-none transition-colors focus:border-link" />
          </div>
          <p class="mt-1 text-xs text-mute">Must cover all minimum payments plus extra toward your target debt.</p>
        </div>
      </Card>
    </div>

    <!-- RIGHT PANEL: Results -->
    <div class="lg:col-span-7">
      <div class="mb-6 grid gap-4 sm:grid-cols-3">
        <ResultCard label="Avalanche Interest" id="avalanche-interest" value="$0" description="Total interest paid" />
        <ResultCard label="Snowball Interest" id="snowball-interest" value="$0" description="Total interest paid" />
        <ResultCard label="Interest Saved" id="interest-saved" value="$0" description="With avalanche method" />
      </div>

      <div class="mb-6 grid gap-4 sm:grid-cols-2">
        <ResultCard label="Avalanche Payoff Date" id="avalanche-date" value="—" description="Debt-free date" />
        <ResultCard label="Snowball Payoff Date" id="snowball-date" value="—" description="Debt-free date" />
      </div>

      <!-- Chart placeholder -->
      <Card padding="lg">
        <h3 class="mb-4 text-sm font-semibold text-ink">Payoff Timeline</h3>
        <div class="flex h-64 items-center justify-center rounded-lg bg-canvas-soft-2">
          <p class="text-sm text-mute">Add debts above to see the payoff comparison chart.</p>
        </div>
      </Card>
    </div>
  </div>
</div>

<script>
  (function () {
    // Selection state
    var debts = [];
    var currency = '$';

    function formatCurrency(value) {
      return currency + Number(value).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function addDebtRow(balance, apr, minimum, name) {
      var list = document.getElementById('debt-list');
      var index = debts.length;
      debts.push({ balance: balance || 0, apr: apr || 0, minimum: minimum || 0, name: name || 'Debt ' + (index + 1) });

      var row = document.createElement('div');
      row.className = 'rounded-lg border border-hairline bg-canvas-soft-2 p-3 space-y-3';
      row.dataset.index = index;

      row.innerHTML =
        '<div class="flex items-center justify-between">' +
          '<input type="text" class="w-full rounded border border-hairline bg-canvas px-2 py-1 text-sm font-medium text-ink outline-none" value="' + debts[index].name + '" placeholder="Debt name" />' +
          '<button type="button" class="ml-2 text-mute hover:text-error" data-remove="' + index + '">' +
            '<svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" /></svg>' +
          '</button>' +
        '</div>' +
        '<div class="grid grid-cols-3 gap-2">' +
          '<div><label class="mb-1 block text-xs text-mute">Balance</label><div class="relative"><span class="absolute left-2 top-1/2 -translate-y-1/2 text-xs text-body">$</span><input type="number" class="w-full rounded border border-hairline bg-canvas py-1 pl-5 pr-2 text-sm text-ink outline-none" value="' + debts[index].balance + '" min="0" step="100" data-field="balance" /></div></div>' +
          '<div><label class="mb-1 block text-xs text-mute">APR %</label><input type="number" class="w-full rounded border border-hairline bg-canvas py-1 px-2 text-sm text-ink outline-none" value="' + debts[index].apr + '" min="0" max="100" step="0.1" data-field="apr" /></div>' +
          '<div><label class="mb-1 block text-xs text-mute">Min Payment</label><div class="relative"><span class="absolute left-2 top-1/2 -translate-y-1/2 text-xs text-body">$</span><input type="number" class="w-full rounded border border-hairline bg-canvas py-1 pl-5 pr-2 text-sm text-ink outline-none" value="' + debts[index].minimum + '" min="0" step="10" data-field="minimum" /></div></div>' +
        '</div>';

      list.appendChild(row);
    }

    function resetCalculator() {
      debts = [];
      document.getElementById('debt-list').innerHTML = '';
      addDebtRow(5000, 22.9, 150, 'Credit Card');
      addDebtRow(15000, 6.8, 300, 'Car Loan');
      addDebtRow(25000, 4.5, 400, 'Student Loan');
      recalculate();
    }

    function recalculate() {
      // Gather current values from DOM
      var rows = document.querySelectorAll('#debt-list > div');
      debts = [];
      rows.forEach(function (row) {
        var inputs = row.querySelectorAll('input');
        var name = inputs[0].value;
        var balance = parseFloat(inputs[1].value) || 0;
        var apr = parseFloat(inputs[2].value) || 0;
        var minimum = parseFloat(inputs[3].value) || 0;
        debts.push({ name: name, balance: balance, apr: apr, minimum: minimum });
      });

      var budget = parseFloat(document.getElementById('monthly-budget').value) || 0;

      // Check for minimum payment overflow
      var totalMin = debts.reduce(function (sum, d) { return sum + d.minimum; }, 0);
      if (totalMin > budget) {
        document.getElementById('avalanche-interest').querySelector('.result-value').textContent = 'Error';
        document.getElementById('snowball-interest').querySelector('.result-value').textContent = 'Error';
        document.getElementById('interest-saved').querySelector('.result-value').textContent = 'Error';
        document.getElementById('avalanche-date').querySelector('.result-value').textContent = '—';
        document.getElementById('snowball-date').querySelector('.result-value').textContent = '—';
        return;
      }

      // Run both simulations
      function simulate(orderFn) {
        var remaining = debts.map(function (d) { return { name: d.name, balance: d.balance, apr: d.apr, minimum: d.minimum }; });
        var totalInterest = 0;
        var months = 0;

        while (remaining.length > 0 && months < 600) {
          months++;
          var extra = budget;
          remaining.forEach(function (d) {
            var interest = d.balance * (d.apr / 100 / 12);
            totalInterest += interest;
            var payment = Math.min(d.minimum, d.balance + interest);
            d.balance -= (payment - interest);
            extra -= payment;
          });

          // Sort by orderFn
          remaining.sort(orderFn);

          // Apply extra to first debt
          if (remaining.length > 0 && extra > 0) {
            var target = remaining[0];
            var payExtra = Math.min(extra, target.balance);
            target.balance -= payExtra;
          }

          remaining = remaining.filter(function (d) { return d.balance > 0.01; });
        }

        return { interest: totalInterest, months: months };
      }

      var avalanceResult = simulate(function (a, b) { return b.apr - a.apr; });
      var snowballResult = simulate(function (a, b) { return a.balance - b.balance; });

      var avalanceInterest = avalanceResult.interest;
      var snowballInterest = snowballResult.interest;
      var saved = snowballInterest - avalanceInterest;

      var now = new Date();

      document.getElementById('avalanche-interest').querySelector('.result-value').textContent = formatCurrency(avalanceInterest);
      document.getElementById('snowball-interest').querySelector('.result-value').textContent = formatCurrency(snowballInterest);
      document.getElementById('interest-saved').querySelector('.result-value').textContent = formatCurrency(Math.max(0, saved));

      function getDateStr(months) {
        var d = new Date(now);
        d.setMonth(d.getMonth() + months);
        return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
      }

      document.getElementById('avalanche-date').querySelector('.result-value').textContent = getDateStr(avalanceResult.months);
      document.getElementById('snowball-date').querySelector('.result-value').textContent = getDateStr(snowballResult.months);
    }

    document.addEventListener('DOMContentLoaded', function () {
      resetCalculator();

      document.getElementById('add-debt-btn').addEventListener('click', function () {
        addDebtRow(0, 0, 0, 'Debt ' + (debts.length + 1));
      });

      document.getElementById('monthly-budget').addEventListener('input', recalculate);

      document.getElementById('debt-list').addEventListener('input', function (e) {
        recalculate();
      });

      document.getElementById('debt-list').addEventListener('click', function (e) {
        var btn = e.target.closest('[data-remove]');
        if (btn) {
          var row = btn.closest('[data-index]');
          if (row) {
            row.remove();
            recalculate();
          }
        }
      });
    });
  })();
</script>
