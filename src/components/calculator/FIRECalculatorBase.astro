---
import Card from '../ui/Card.astro';
import Input from '../ui/Input.astro';
import Slider from '../ui/Slider.astro';
import ResultCard from '../ui/ResultCard.astro';
import type { FIREType } from '../../utils/calculations';

export interface Props {
  fireType?: FIREType;
}

const { fireType } = Astro.props;
const isStandalone = !!fireType;

const fireTypeLabels: Record<FIREType, string> = {
  lean: 'Lean FIRE',
  regular: 'Regular FIRE',
  fat: 'Fat FIRE',
  coast: 'Coast FIRE',
  barista: 'Barista FIRE',
};

const fireTypeDescriptions: Record<FIREType, string> = {
  lean: 'Minimalist lifestyle, lower expenses (20x annual expenses)',
  regular: 'Comfortable middle-class lifestyle (25x annual expenses)',
  fat: 'Luxury lifestyle, higher expenses (30x annual expenses)',
  coast: 'Let compound interest do the work',
  barista: 'Work part-time, let investments cover the rest',
};
---

<div id="fire-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12" data-fire-type={fireType || ''}>
  <div class="mb-8 text-center">
    <p class="mb-2 font-mono text-xs uppercase tracking-wider text-mute">Free Calculator</p>
    <h1 class="mb-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl" style="letter-spacing: -0.02em;">
      {isStandalone ? `${fireTypeLabels[fireType!]} Calculator` : 'Plan Your Financial Independence'}
    </h1>
    <p class="mx-auto max-w-2xl text-body">
      {isStandalone
        ? `Calculate your ${fireTypeLabels[fireType!]} number and plan your path to early retirement.`
        : 'Calculate your FIRE number, compare scenarios, and build a roadmap to early retirement.'}
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <Card padding="lg" class="lg:sticky lg:top-24">
        {!isStandalone && (
          <div class="mb-6">
            <div class="flex items-center justify-between">
              <label for="lifestyleMultiplier" class="text-sm font-medium text-ink">
                Lifestyle
              </label>
              <span id="lifestyleMultiplierValue" class="font-mono text-sm font-medium text-ink tabular-nums">
                25x
              </span>
            </div>
            <input
              id="lifestyleMultiplier"
              name="lifestyleMultiplier"
              type="range"
              value={25}
              min={20}
              max={30}
              step={0.5}
              class="w-full accent-ink"
            />
            <div class="flex justify-between text-xs text-mute">
              <span>Lean (20x)</span>
              <span>Regular (25x)</span>
              <span>Fat (30x)</span>
            </div>
          </div>
        )}

        {isStandalone ? (
          <div class="mb-6 rounded-md bg-canvas-soft-2 p-3 text-xs text-body">
            <span class="font-medium text-ink">{fireTypeLabels[fireType!]}:</span> {fireTypeDescriptions[fireType!]}
          </div>
        ) : (
          <div id="fire-type-description" class="mb-6 rounded-md bg-canvas-soft-2 p-3 text-xs text-body">
            <span class="font-medium text-ink">Regular FIRE:</span> Comfortable middle-class lifestyle (25x annual expenses)
          </div>
        )}

        <form id="fire-form" class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <Input label="Current Age" name="currentAge" type="number" value={30} min={18} max={70} required />
            <Input label="Retirement Age" name="retirementAge" type="number" value={50} min={30} max={70} required />
          </div>

          <Input label="Current Savings & Investments" name="currentSavings" type="number" value={50000} min={0} step={1000} suffix="$" hideArrows required />

          <Input label="Monthly Income" name="monthlyIncome" type="number" value={8000} min={0} step={100} suffix="$" hideArrows required />

          <Slider label="Savings Rate" name="savingsRate" value={25} min={5} max={80} suffix="%" inputId="savingsRate" displayId="savingsRateValue" />

          <Input label="Monthly Expenses" name="monthlyExpenses" type="number" value={5000} min={0} step={100} suffix="$" hideArrows required />

          <div class="grid gap-4 sm:grid-cols-2">
            <Slider label="Annual Return" name="annualReturn" value={7} min={1} max={15} step={0.5} suffix="%" inputId="annualReturn" displayId="annualReturnValue" />
            <Slider label="Inflation Rate" name="inflation" value={3} min={1} max={8} step={0.5} suffix="%" inputId="inflation" displayId="inflationValue" />
          </div>

          <Slider label="Safe Withdrawal Rate" name="swr" value={4} min={2} max={6} step={0.5} suffix="%" inputId="swr" displayId="swrValue" />
        </form>
      </Card>
    </div>

    <div class="space-y-6 lg:col-span-7">
      <div id="results-summary" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <ResultCard label="FIRE Number" valueId="fire-number" value="$1,200,000" description="Amount needed for retirement" />
        <ResultCard label="Monthly Investment" valueId="monthly-investment" value="$1,500" valueClass="text-link" description="To reach your goal" />
        <ResultCard label="Years to FIRE" valueId="years-to-fire" value="12.4 yrs" description="When you'll reach FIRE" />
        <ResultCard label="Progress" valueId="fire-progress" value="4.2%" valueClass="text-success-deep" description="Towards your FIRE number" />
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-sm font-medium text-ink">Portfolio Growth Projection</h2>
          <div class="flex gap-2">
            <button id="chart-type-line" class="chart-type-btn rounded-md cursor-pointer bg-ink px-3 py-2.5 text-xs font-medium text-canvas" data-active="true">Line</button>
            <button id="chart-type-bar" class="chart-type-btn rounded-md cursor-pointer bg-canvas-soft-2 px-3 py-2.5 text-xs font-medium text-body hover:text-ink" data-active="false">Bar</button>
          </div>
        </div>
        <div class="relative h-64 sm:h-80">
          <canvas id="projection-chart"></canvas>
        </div>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <h2 class="mb-4 text-sm font-medium text-ink">Scenario Comparison</h2>
        <div id="scenario-comparison" class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline">
                <th class="pb-2 pr-4 text-xs font-medium text-mute">FIRE Type</th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">Target</th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">Monthly</th>
                <th class="hidden pb-2 text-xs font-medium text-mute sm:table-cell">Survivability</th>
              </tr>
            </thead>
            <tbody id="scenario-table-body" class="font-mono text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="py-2 pr-4 text-body">Lean FIRE</td>
                <td class="py-2 pr-4 text-ink">$960K</td>
                <td class="py-2 pr-4 text-link">$1,200</td>
                <td class="hidden py-2 sm:table-cell text-ink">40 yrs</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 pr-4 font-medium text-ink">Regular FIRE</td>
                <td class="py-2 pr-4 font-medium text-ink">$1.2M</td>
                <td class="py-2 pr-4 font-medium text-link">$1,500</td>
                <td class="hidden py-2 sm:table-cell font-medium text-ink">50 yrs</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 pr-4 text-body">Fat FIRE</td>
                <td class="py-2 pr-4 text-ink">$1.44M</td>
                <td class="py-2 pr-4 text-link">$1,800</td>
                <td class="hidden py-2 sm:table-cell text-ink">60 yrs</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <button
          id="export-pdf"
          class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Export PDF
        </button>

        <button
          id="share-results"
          class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
          </svg>
          Share
        </button>
      </div>
    </div>
  </div>
</div>

<script>
  import { calculateFIRE, generateScenarios, type FIREType, type FIREInput } from '../../utils/calculations';
  import { formatCurrency, formatCurrencyShort } from '../../utils/formatters';

  const calculator = document.getElementById('fire-calculator');
  const standaloneType = calculator?.dataset.fireType as FIREType | '';
  let currentFireType: FIREType = standaloneType || 'coast';
  let lifestyleMultiplier = 25;
  let chart: any = null;

  const fireTypeDescriptions: Record<FIREType, string> = {
    lean: '<span class="font-medium text-ink">Lean FIRE:</span> Minimalist lifestyle, lower expenses (20x annual expenses)',
    regular: '<span class="font-medium text-ink">Regular FIRE:</span> Comfortable middle-class lifestyle (25x annual expenses)',
    fat: '<span class="font-medium text-ink">Fat FIRE:</span> Luxury lifestyle, higher expenses (30x annual expenses)',
    coast: '<span class="font-medium text-ink">Coast FIRE:</span> Let compound interest do the work',
    barista: '<span class="font-medium text-ink">Barista FIRE:</span> Work part-time, let investments cover the rest',
  };

  function getFormData(): FIREInput {
    const form = document.getElementById('fire-form') as HTMLFormElement;
    const formData = new FormData(form);

    return {
      currentAge: Number(formData.get('currentAge')) || 30,
      retirementAge: Number(formData.get('retirementAge')) || 50,
      currentSavings: Number(formData.get('currentSavings')) || 50000,
      monthlyIncome: Number(formData.get('monthlyIncome')) || 8000,
      savingsRate: Number(formData.get('savingsRate')) || 25,
      monthlyExpenses: Number(formData.get('monthlyExpenses')) || 5000,
      annualReturnRate: Number(formData.get('annualReturn')) || 7,
      inflationRate: Number(formData.get('inflation')) || 3,
      safeWithdrawalRate: Number(formData.get('swr')) || 4,
      fireType: currentFireType,
      partTimeIncome: 0,
      lifestyleMultiplier,
    };
  }

  function updateResults() {
    const input = getFormData();
    const result = calculateFIRE(input);
    const scenarios = generateScenarios(input);

    document.getElementById('fire-number')!.textContent = formatCurrency(result.fireNumber);
    document.getElementById('monthly-investment')!.textContent = formatCurrency(result.monthlyInvestmentNeeded);
    document.getElementById('fire-progress')!.textContent = `${result.fireProgress.toFixed(1)}%`;

    const yearsToFIREEl = document.getElementById('years-to-fire')!;
    if (result.yearsToFIRE !== null) {
      yearsToFIREEl.textContent = `${result.yearsToFIRE.toFixed(1)} yrs`;
    } else {
      yearsToFIREEl.textContent = '—';
    }

    const tbody = document.getElementById('scenario-table-body')!;
    const types: FIREType[] = ['lean', 'regular', 'fat'];
    tbody.innerHTML = types.map((type) => {
      const s = scenarios[type];
      const isActive = lifestyleMultiplier === ({ lean: 20, regular: 25, fat: 30 }[type]);
      return `
        <tr class="${isActive ? 'bg-canvas-soft-2' : ''} ${type !== 'fat' ? 'border-b border-hairline/50' : ''}">
          <td class="py-2 pr-4 ${isActive ? 'font-medium text-ink' : 'text-body'}">${type.charAt(0).toUpperCase() + type.slice(1)} FIRE</td>
          <td class="py-2 pr-4 ${isActive ? 'font-medium text-ink' : 'text-ink'}">${formatCurrencyShort(s.fireNumber)}</td>
          <td class="py-2 pr-4 ${isActive ? 'font-medium text-link' : 'text-link'}">${formatCurrency(s.monthlyInvestmentNeeded)}</td>
          <td class="hidden py-2 sm:table-cell ${isActive ? 'font-medium text-ink' : 'text-ink'}">${Math.floor(s.survivabilityYears)} yrs</td>
        </tr>
      `;
    }).join('');

    updateChart(result.projection, result.fireNumber);
  }

  function updateChart(projection: any[], fireNumber: number) {
    const ctx = document.getElementById('projection-chart') as HTMLCanvasElement;
    if (!ctx) return;

    const labels = projection.filter((_, i) => i % 2 === 0 || i === projection.length - 1).map((p) => `Age ${p.age}`);
    const savingsData = projection.filter((_, i) => i % 2 === 0 || i === projection.length - 1).map((p) => p.savings);
    const targetData = projection.filter((_, i) => i % 2 === 0 || i === projection.length - 1).map((p) => p.target);

    if (chart) {
      chart.destroy();
    }

    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? '#262626' : '#ebebeb';
    const textColor = isDark ? '#737373' : '#888888';
    const tooltipBg = isDark ? '#ededed' : '#171717';
    const tooltipText = isDark ? '#171717' : '#ffffff';
    const linkColor = isDark ? '#3291ff' : '#0070f3';
    const errorColor = isDark ? '#ff4444' : '#ee0000';

    chart = new (window as any).Chart(ctx, {
      type: document.getElementById('chart-type-line')?.dataset.active === 'true' ? 'line' : 'bar',
      data: {
        labels,
        datasets: [
          {
            label: 'Portfolio Value',
            data: savingsData,
            borderColor: linkColor,
            backgroundColor: isDark ? 'rgba(50, 145, 255, 0.1)' : 'rgba(0, 112, 243, 0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
          {
            label: 'FIRE Target',
            data: targetData,
            borderColor: errorColor,
            backgroundColor: 'transparent',
            borderDash: [5, 5],
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index',
        },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'end',
            labels: {
              boxWidth: 12,
              boxHeight: 2,
              usePointStyle: false,
              padding: 16,
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
            },
          },
          tooltip: {
            backgroundColor: tooltipBg,
            titleColor: tooltipText,
            bodyColor: tooltipText,
            borderColor: tooltipBg,
            borderWidth: 1,
            padding: 12,
            titleFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
              weight: 500,
            },
            bodyFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
            },
            callbacks: {
              label: function (context: any) {
                return `${context.dataset.label}: ${formatCurrency(context.parsed.y)}`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: {
              display: false,
            },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              maxTicksLimit: 8,
            },
            border: {
              display: false,
            },
          },
          y: {
            grid: {
              color: gridColor,
            },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              callback: function (value: any) {
                return formatCurrencyShort(value);
              },
            },
            border: {
              display: false,
            },
          },
        },
      },
    });
  }

  function initSliders() {
    const sliders = [
      { id: 'savingsRate', displayId: 'savingsRateValue', suffix: '%' },
      { id: 'annualReturn', displayId: 'annualReturnValue', suffix: '%' },
      { id: 'inflation', displayId: 'inflationValue', suffix: '%' },
      { id: 'swr', displayId: 'swrValue', suffix: '%' },
    ];

    sliders.forEach(({ id, displayId, suffix }) => {
      const slider = document.getElementById(id) as HTMLInputElement;
      const display = document.getElementById(displayId);

      if (slider && display) {
        slider.addEventListener('input', () => {
          display.textContent = `${slider.value}${suffix}`;
          updateResults();
        });
      }
    });

    const lifestyleSlider = document.getElementById('lifestyleMultiplier') as HTMLInputElement;
    const lifestyleDisplay = document.getElementById('lifestyleMultiplierValue');
    if (lifestyleSlider && lifestyleDisplay) {
      lifestyleSlider.addEventListener('input', () => {
        lifestyleMultiplier = Number(lifestyleSlider.value);
        lifestyleDisplay.textContent = `${lifestyleMultiplier}x`;
        updateDescription();
        updateResults();
      });
    }
  }

  function updateDescription() {
    const description = document.getElementById('fire-type-description');
    if (!description || standaloneType) return;

    let label: string;
    let multiplier: number;
    if (lifestyleMultiplier <= 22) {
      label = 'Lean FIRE';
      multiplier = 20;
    } else if (lifestyleMultiplier >= 28) {
      label = 'Fat FIRE';
      multiplier = 30;
    } else {
      label = 'Regular FIRE';
      multiplier = 25;
    }

    description.innerHTML = `<span class="font-medium text-ink">${label}:</span> ${lifestyleMultiplier}x annual expenses`;
  }

  function initChartTypeToggle() {
    const lineBtn = document.getElementById('chart-type-line');
    const barBtn = document.getElementById('chart-type-bar');

    lineBtn?.addEventListener('click', () => {
      lineBtn.dataset.active = 'true';
      lineBtn.classList.add('bg-ink', 'text-canvas');
      lineBtn.classList.remove('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      barBtn!.dataset.active = 'false';
      barBtn!.classList.remove('bg-ink', 'text-canvas');
      barBtn!.classList.add('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      updateResults();
    });

    barBtn?.addEventListener('click', () => {
      barBtn.dataset.active = 'true';
      barBtn.classList.add('bg-ink', 'text-canvas');
      barBtn.classList.remove('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      lineBtn!.dataset.active = 'false';
      lineBtn!.classList.remove('bg-ink', 'text-canvas');
      lineBtn!.classList.add('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      updateResults();
    });
  }

  function initFormListeners() {
    const form = document.getElementById('fire-form') as HTMLFormElement;
    form?.addEventListener('input', () => {
      updateResults();
    });
  }

  function initExport() {
    document.getElementById('export-pdf')?.addEventListener('click', async () => {
      const { default: html2canvas } = await import('html2canvas');
      const { default: jsPDF } = await import('jspdf');

      const element = document.getElementById('fire-calculator')!;
      const canvas = await html2canvas(element);
      const imgData = canvas.toDataURL('image/png');

      const pdf = new jsPDF('p', 'mm', 'a4');
      const pdfWidth = pdf.internal.pageSize.getWidth();
      const pdfHeight = (canvas.height * pdfWidth) / canvas.width;

      pdf.addImage(imgData, 'PNG', 0, 0, pdfWidth, pdfHeight);
      pdf.save('fire-calculator-results.pdf');
    });
  }

  function initShare() {
    document.getElementById('share-results')?.addEventListener('click', async () => {
      const input = getFormData();
      const params = new URLSearchParams({
        age: input.currentAge.toString(),
        retire: input.retirementAge.toString(),
        savings: input.currentSavings.toString(),
        income: input.monthlyIncome.toString(),
        rate: input.savingsRate.toString(),
        expenses: input.monthlyExpenses.toString(),
        return: input.annualReturnRate.toString(),
        inflation: input.inflationRate.toString(),
        swr: input.safeWithdrawalRate.toString(),
        lifestyle: input.lifestyleMultiplier?.toString() || '25',
      });

      const basePath = standaloneType ? `/${standaloneType}-fire-calculator` : '/fire-calculator';
      const url = `${window.location.origin}${basePath}?${params.toString()}`;

      if (navigator.share) {
        try {
          await navigator.share({
            title: 'My FIRE Calculator Results',
            text: 'Check out my FIRE retirement plan!',
            url,
          });
        } catch (err) {
          navigator.clipboard.writeText(url);
          alert('Link copied to clipboard!');
        }
      } else {
        navigator.clipboard.writeText(url);
        alert('Link copied to clipboard!');
      }
    });
  }

  function loadFromUrl() {
    const params = new URLSearchParams(window.location.search);
    if (params.has('age')) {
      const form = document.getElementById('fire-form') as HTMLFormElement;
      const fields: Record<string, string> = {
        currentAge: 'age',
        retirementAge: 'retire',
        currentSavings: 'savings',
        monthlyIncome: 'income',
        savingsRate: 'rate',
        monthlyExpenses: 'expenses',
        annualReturn: 'return',
        inflation: 'inflation',
        swr: 'swr',
      };

      Object.entries(fields).forEach(([fieldId, param]) => {
        const input = document.getElementById(fieldId) as HTMLInputElement;
        if (input && params.has(param)) {
          input.value = params.get(param)!;
        }
      });

      if (!standaloneType && params.has('lifestyle')) {
        const lifestyleValue = Number(params.get('lifestyle'));
        if (!isNaN(lifestyleValue) && lifestyleValue >= 20 && lifestyleValue <= 30) {
          lifestyleMultiplier = lifestyleValue;
          const lifestyleSlider = document.getElementById('lifestyleMultiplier') as HTMLInputElement;
          const lifestyleDisplay = document.getElementById('lifestyleMultiplierValue');
          if (lifestyleSlider) lifestyleSlider.value = lifestyleValue.toString();
          if (lifestyleDisplay) lifestyleDisplay.textContent = `${lifestyleValue}x`;
        }
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadFromUrl();
    initSliders();
    initChartTypeToggle();
    initFormListeners();
    initExport();
    initShare();
    updateResults();

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      updateResults();
    });

    const observer = new MutationObserver(() => {
      updateResults();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  });
</script>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
