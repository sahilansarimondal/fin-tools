---
import Card from '../ui/Card.astro';
import Input from '../ui/Input.astro';
import Slider from '../ui/Slider.astro';
import ResultCard from '../ui/ResultCard.astro';
import type { FIREType } from '../../utils/calculations';

export interface Props {
  fireType?: FIREType;
}

const { fireType } = Astro.props;
const isStandalone = !!fireType;

const fireTypeLabels: Record<FIREType, string> = {
  lean: 'Lean FIRE',
  regular: 'Regular FIRE',
  fat: 'Fat FIRE',
  coast: 'Coast FIRE',
  barista: 'Barista FIRE',
};

const fireTypeDescriptions: Record<FIREType, string> = {
  lean: 'Minimalist lifestyle, lower expenses (20x annual expenses)',
  regular: 'Comfortable middle-class lifestyle (25x annual expenses)',
  fat: 'Luxury lifestyle, higher expenses (30x annual expenses)',
  coast: 'Let compound interest do the work',
  barista: 'Work part-time, let investments cover the rest',
};
---

<div id="fire-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12" data-fire-type={fireType || ''}>
  <div class="mb-8 text-center">
    <p class="mb-2 font-mono text-xs uppercase tracking-wider text-mute">Free Calculator</p>
    <h1 class="mb-3 text-3xl font-semibold tracking-tight text-ink sm:text-4xl lg:text-5xl" style="letter-spacing: -0.02em;">
      {isStandalone ? `${fireTypeLabels[fireType!]} Calculator` : 'Plan Your Financial Independence'}
    </h1>
    <p class="mx-auto max-w-2xl text-body">
      {isStandalone
        ? `Calculate your ${fireTypeLabels[fireType!]} number and plan your path to early retirement.`
        : 'Calculate your FIRE number, compare scenarios, and build a roadmap to early retirement.'}
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-12">
    <div class="lg:col-span-5">
      <Card padding="lg" class="lg:sticky lg:top-24">
        {!isStandalone && (
          <div class="mb-6">
            <div class="flex items-center justify-between">
              <label for="lifestyleMultiplier" class="text-sm font-medium text-ink">
                Lifestyle
              </label>
              <span id="lifestyleMultiplierValue" class="font-mono text-sm font-medium text-ink tabular-nums">
                25x
              </span>
            </div>
            <input
              id="lifestyleMultiplier"
              name="lifestyleMultiplier"
              type="range"
              value={25}
              min={20}
              max={30}
              step={0.5}
              class="w-full accent-ink"
            />
            <div class="flex justify-between text-xs text-mute">
              <span>Lean (20x)</span>
              <span>Regular (25x)</span>
              <span>Fat (30x)</span>
            </div>
          </div>
        )}

        {isStandalone ? (
          <div class="mb-6 rounded-md bg-canvas-soft-2 p-3 text-xs text-body">
            <span class="font-medium text-ink">{fireTypeLabels[fireType!]}:</span> {fireTypeDescriptions[fireType!]}
          </div>
        ) : (
          <div id="fire-type-description" class="mb-6 rounded-md bg-canvas-soft-2 p-3 text-xs text-body">
            <span class="font-medium text-ink">Regular FIRE:</span> Comfortable middle-class lifestyle (25x annual expenses)
          </div>
        )}

        <form id="fire-form" class="space-y-4">
          <div class="grid gap-4 sm:grid-cols-2">
            <Input label="Current Age" name="currentAge" type="number" value={30} min={18} max={70} required />
            <Input label="Retirement Age" name="retirementAge" type="number" value={50} min={30} max={70} required />
          </div>

          <Input label="Current Savings & Investments" name="currentSavings" type="number" value={50000} min={0} step={1000} suffix="$" hideArrows required />

          <Input label="Monthly Income" name="monthlyIncome" type="number" value={8000} min={0} step={100} suffix="$" hideArrows required />

          <Slider label="Savings Rate" name="savingsRate" value={25} min={5} max={80} suffix="%" inputId="savingsRate" displayId="savingsRateValue" />

          <Input label="Monthly Expenses" name="monthlyExpenses" type="number" value={5000} min={0} step={100} suffix="$" hideArrows required />

          <div class="grid gap-4 sm:grid-cols-2">
            <Slider label="Annual Return" name="annualReturn" value={7} min={1} max={15} step={0.5} suffix="%" inputId="annualReturn" displayId="annualReturnValue" tooltip="The average annual return of the S&P 500 has been ~10% historically. We recommend using 7% for conservative long-term planning." />
            <Slider label="Inflation Rate" name="inflation" value={3} min={1} max={8} step={0.5} suffix="%" inputId="inflation" displayId="inflationValue" tooltip="The general rise in prices over time. Historical average is ~3%. Higher inflation means higher retirement expenses." />
          </div>

          <Slider label="Safe Withdrawal Rate" name="swr" value={4} min={2} max={6} step={0.5} suffix="%" inputId="swr" displayId="swrValue" tooltip="The '4% rule' from the Trinity Study. This assumes you withdraw this percentage of your portfolio annually with a high probability of your money lasting 30+ years." />
        </form>
      </Card>
    </div>

    <div class="space-y-6 lg:col-span-7">
      <div id="results-summary" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <ResultCard label="FIRE Number" valueId="fire-number" value="$1,200,000" description="Amount needed for retirement" />
        <ResultCard label="Monthly Investment" valueId="monthly-investment" value="$1,500" valueClass="text-link" description="To reach your goal" />
        <ResultCard label="Years to FIRE" valueId="years-to-fire" value="12.4 yrs" description="When you'll reach FIRE" />
        <ResultCard label="Progress" valueId="fire-progress" value="4.2%" valueClass="text-success-deep" description="Towards your FIRE number" />
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-sm font-medium text-ink">Portfolio Growth Projection</h2>
          <div class="flex gap-2">
            <button id="chart-type-line" class="chart-type-btn rounded-md cursor-pointer bg-ink px-3 py-2.5 text-xs font-medium text-canvas" data-active="true">Line</button>
            <button id="chart-type-bar" class="chart-type-btn rounded-md cursor-pointer bg-canvas-soft-2 px-3 py-2.5 text-xs font-medium text-body hover:text-ink" data-active="false">Bar</button>
          </div>
        </div>
        <div class="relative h-64 sm:h-80">
          <canvas id="projection-chart"></canvas>
        </div>
      </div>

      <div class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm">
        <h2 class="mb-4 text-sm font-medium text-ink">Scenario Comparison</h2>
        <div id="scenario-comparison" class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline">
                <th class="pb-2 pr-4 text-xs font-medium text-mute">FIRE Type</th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">Target</th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">Monthly</th>
                <th class="hidden pb-2 text-xs font-medium text-mute sm:table-cell">Survivability</th>
              </tr>
            </thead>
            <tbody id="scenario-table-body" class="font-mono text-xs tabular-nums">
              <tr class="border-b border-hairline/50">
                <td class="py-2 pr-4 text-body">Lean FIRE</td>
                <td class="py-2 pr-4 text-ink">$960K</td>
                <td class="py-2 pr-4 text-link">$1,200</td>
                <td class="hidden py-2 sm:table-cell text-ink">40 yrs</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 pr-4 font-medium text-ink">Regular FIRE</td>
                <td class="py-2 pr-4 font-medium text-ink">$1.2M</td>
                <td class="py-2 pr-4 font-medium text-link">$1,500</td>
                <td class="hidden py-2 sm:table-cell font-medium text-ink">50 yrs</td>
              </tr>
              <tr class="border-b border-hairline/50">
                <td class="py-2 pr-4 text-body">Fat FIRE</td>
                <td class="py-2 pr-4 text-ink">$1.44M</td>
                <td class="py-2 pr-4 text-link">$1,800</td>
                <td class="hidden py-2 sm:table-cell text-ink">60 yrs</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="flex flex-wrap gap-3">
        <button
          id="export-pdf"
          class="inline-flex items-center gap-2 rounded-full border border-hairline bg-canvas px-4 py-2 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Export PDF
        </button>

        <div class="flex flex-wrap items-center gap-2">
          <span class="text-sm font-medium text-ink/60 mr-1">Share</span>
          <button
            data-share="x"
            class="share-btn inline-flex items-center justify-center h-9 w-9 rounded-full border border-hairline bg-canvas text-ink transition-colors hover:bg-ink hover:text-canvas"
            title="Share on X"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </button>
          <button
            data-share="facebook"
            class="share-btn inline-flex items-center justify-center h-9 w-9 rounded-full border border-hairline bg-canvas text-ink transition-colors hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2]"
            title="Share on Facebook"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </button>
          <button
            data-share="linkedin"
            class="share-btn inline-flex items-center justify-center h-9 w-9 rounded-full border border-hairline bg-canvas text-ink transition-colors hover:bg-[#0A66C2] hover:text-white hover:border-[#0A66C2]"
            title="Share on LinkedIn"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </button>
          <button
            data-share="whatsapp"
            class="share-btn inline-flex items-center justify-center h-9 w-9 rounded-full border border-hairline bg-canvas text-ink transition-colors hover:bg-[#25D366] hover:text-white hover:border-[#25D366]"
            title="Share on WhatsApp"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </button>
          <button
            data-share="reddit"
            class="share-btn inline-flex items-center justify-center h-9 w-9 rounded-full border border-hairline bg-canvas text-ink transition-colors hover:bg-[#FF4500] hover:text-white hover:border-[#FF4500]"
            title="Share on Reddit"
          >
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/></svg>
          </button>
          <button
            id="copy-link"
            class="share-btn inline-flex items-center gap-1.5 h-9 rounded-full border border-hairline bg-canvas px-3 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
            title="Copy link"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            Copy link
          </button>
          <button
            id="native-share"
            class="share-btn inline-flex items-center gap-1.5 h-9 rounded-full border border-hairline bg-canvas px-3 text-sm font-medium text-ink transition-colors hover:bg-canvas-soft-2"
            title="More share options"
            style="display: none;"
          >
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
            </svg>
            Share
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #copy-link.copied {
    border-color: var(--color-green-500, #22c55e);
    background-color: var(--color-green-50, #f0fdf4);
    color: var(--color-green-700, #15803d);
  }
  :global(html.dark) #copy-link.copied {
    border-color: var(--color-green-400, #4ade80);
    background-color: rgb(20 83 45 / 0.3);
    color: var(--color-green-400, #4ade80);
  }
</style>

<script>
  import { calculateFIRE, generateScenarios, type FIREType, type FIREInput } from '../../utils/calculations';
  import { formatCurrency, formatCurrencyShort } from '../../utils/formatters';

  const calculator = document.getElementById('fire-calculator');
  const standaloneType = calculator?.dataset.fireType as FIREType | '';
  let currentFireType: FIREType = standaloneType || 'coast';
  let lifestyleMultiplier = 25;
  let chart: any = null;

  const fireTypeDescriptions: Record<FIREType, string> = {
    lean: '<span class="font-medium text-ink">Lean FIRE:</span> Minimalist lifestyle, lower expenses (20x annual expenses)',
    regular: '<span class="font-medium text-ink">Regular FIRE:</span> Comfortable middle-class lifestyle (25x annual expenses)',
    fat: '<span class="font-medium text-ink">Fat FIRE:</span> Luxury lifestyle, higher expenses (30x annual expenses)',
    coast: '<span class="font-medium text-ink">Coast FIRE:</span> Let compound interest do the work',
    barista: '<span class="font-medium text-ink">Barista FIRE:</span> Work part-time, let investments cover the rest',
  };

  function getFormData(): FIREInput {
    const form = document.getElementById('fire-form') as HTMLFormElement;
    const formData = new FormData(form);

    return {
      currentAge: Number(formData.get('currentAge')) || 30,
      retirementAge: Number(formData.get('retirementAge')) || 50,
      currentSavings: Number(formData.get('currentSavings')) || 50000,
      monthlyIncome: Number(formData.get('monthlyIncome')) || 8000,
      savingsRate: Number(formData.get('savingsRate')) || 25,
      monthlyExpenses: Number(formData.get('monthlyExpenses')) || 5000,
      annualReturnRate: Number(formData.get('annualReturn')) || 7,
      inflationRate: Number(formData.get('inflation')) || 3,
      safeWithdrawalRate: Number(formData.get('swr')) || 4,
      fireType: currentFireType,
      partTimeIncome: 0,
      lifestyleMultiplier,
    };
  }

  function updateResults() {
    const input = getFormData();
    const result = calculateFIRE(input);
    const scenarios = generateScenarios(input);

    document.getElementById('fire-number')!.textContent = formatCurrency(result.fireNumber);
    document.getElementById('monthly-investment')!.textContent = formatCurrency(result.monthlyInvestmentNeeded);
    document.getElementById('fire-progress')!.textContent = `${result.fireProgress.toFixed(1)}%`;

    const yearsToFIREEl = document.getElementById('years-to-fire')!;
    if (result.yearsToFIRE !== null) {
      yearsToFIREEl.textContent = `${result.yearsToFIRE.toFixed(1)} yrs`;
    } else {
      yearsToFIREEl.textContent = '—';
    }

    const tbody = document.getElementById('scenario-table-body')!;
    const types: FIREType[] = ['lean', 'regular', 'fat'];
    tbody.innerHTML = types.map((type) => {
      const s = scenarios[type];
      const isActive = lifestyleMultiplier === ({ lean: 20, regular: 25, fat: 30 }[type]);
      return `
        <tr class="${isActive ? 'bg-canvas-soft-2' : ''} ${type !== 'fat' ? 'border-b border-hairline/50' : ''}">
          <td class="py-2 pr-4 ${isActive ? 'font-medium text-ink' : 'text-body'}">${type.charAt(0).toUpperCase() + type.slice(1)} FIRE</td>
          <td class="py-2 pr-4 ${isActive ? 'font-medium text-ink' : 'text-ink'}">${formatCurrencyShort(s.fireNumber)}</td>
          <td class="py-2 pr-4 ${isActive ? 'font-medium text-link' : 'text-link'}">${formatCurrency(s.monthlyInvestmentNeeded)}</td>
          <td class="hidden py-2 sm:table-cell ${isActive ? 'font-medium text-ink' : 'text-ink'}">${Math.floor(s.survivabilityYears)} yrs</td>
        </tr>
      `;
    }).join('');

    updateChart(result.projection, result.fireNumber);
  }

  function updateChart(projection: any[], fireNumber: number) {
    const ctx = document.getElementById('projection-chart') as HTMLCanvasElement;
    if (!ctx) return;

    const labels = projection.filter((_, i) => i % 2 === 0 || i === projection.length - 1).map((p) => `Age ${p.age}`);
    const savingsData = projection.filter((_, i) => i % 2 === 0 || i === projection.length - 1).map((p) => p.savings);
    const targetData = projection.filter((_, i) => i % 2 === 0 || i === projection.length - 1).map((p) => p.target);

    if (chart) {
      chart.destroy();
    }

    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? '#262626' : '#ebebeb';
    const textColor = isDark ? '#737373' : '#888888';
    const tooltipBg = isDark ? '#ededed' : '#171717';
    const tooltipText = isDark ? '#171717' : '#ffffff';
    const linkColor = isDark ? '#3291ff' : '#0070f3';
    const errorColor = isDark ? '#ff4444' : '#ee0000';

    chart = new (window as any).Chart(ctx, {
      type: document.getElementById('chart-type-line')?.dataset.active === 'true' ? 'line' : 'bar',
      data: {
        labels,
        datasets: [
          {
            label: 'Portfolio Value',
            data: savingsData,
            borderColor: linkColor,
            backgroundColor: isDark ? 'rgba(50, 145, 255, 0.1)' : 'rgba(0, 112, 243, 0.1)',
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
          {
            label: 'FIRE Target',
            data: targetData,
            borderColor: errorColor,
            backgroundColor: 'transparent',
            borderDash: [5, 5],
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: 'index',
        },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'end',
            labels: {
              boxWidth: 12,
              boxHeight: 2,
              usePointStyle: false,
              padding: 16,
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
            },
          },
          tooltip: {
            backgroundColor: tooltipBg,
            titleColor: tooltipText,
            bodyColor: tooltipText,
            borderColor: tooltipBg,
            borderWidth: 1,
            padding: 12,
            titleFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
              weight: 500,
            },
            bodyFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
            },
            callbacks: {
              label: function (context: any) {
                return `${context.dataset.label}: ${formatCurrency(context.parsed.y)}`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: {
              display: false,
            },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              maxTicksLimit: 8,
            },
            border: {
              display: false,
            },
          },
          y: {
            grid: {
              color: gridColor,
            },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              callback: function (value: any) {
                return formatCurrencyShort(value);
              },
            },
            border: {
              display: false,
            },
          },
        },
      },
    });
  }

  function initSliders() {
    const sliders = [
      { id: 'savingsRate', displayId: 'savingsRateValue', suffix: '%' },
      { id: 'annualReturn', displayId: 'annualReturnValue', suffix: '%' },
      { id: 'inflation', displayId: 'inflationValue', suffix: '%' },
      { id: 'swr', displayId: 'swrValue', suffix: '%' },
    ];

    sliders.forEach(({ id, displayId, suffix }) => {
      const slider = document.getElementById(id) as HTMLInputElement;
      const display = document.getElementById(displayId);

      if (slider && display) {
        slider.addEventListener('input', () => {
          display.textContent = `${slider.value}${suffix}`;
          updateResults();
        });
      }
    });

    const lifestyleSlider = document.getElementById('lifestyleMultiplier') as HTMLInputElement;
    const lifestyleDisplay = document.getElementById('lifestyleMultiplierValue');
    if (lifestyleSlider && lifestyleDisplay) {
      lifestyleSlider.addEventListener('input', () => {
        lifestyleMultiplier = Number(lifestyleSlider.value);
        lifestyleDisplay.textContent = `${lifestyleMultiplier}x`;
        updateDescription();
        updateResults();
      });
    }
  }

  function updateDescription() {
    const description = document.getElementById('fire-type-description');
    if (!description || standaloneType) return;

    let label: string;
    let multiplier: number;
    if (lifestyleMultiplier <= 22) {
      label = 'Lean FIRE';
      multiplier = 20;
    } else if (lifestyleMultiplier >= 28) {
      label = 'Fat FIRE';
      multiplier = 30;
    } else {
      label = 'Regular FIRE';
      multiplier = 25;
    }

    description.innerHTML = `<span class="font-medium text-ink">${label}:</span> ${lifestyleMultiplier}x annual expenses`;
  }

  function initChartTypeToggle() {
    const lineBtn = document.getElementById('chart-type-line');
    const barBtn = document.getElementById('chart-type-bar');

    lineBtn?.addEventListener('click', () => {
      lineBtn.dataset.active = 'true';
      lineBtn.classList.add('bg-ink', 'text-canvas');
      lineBtn.classList.remove('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      barBtn!.dataset.active = 'false';
      barBtn!.classList.remove('bg-ink', 'text-canvas');
      barBtn!.classList.add('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      updateResults();
    });

    barBtn?.addEventListener('click', () => {
      barBtn.dataset.active = 'true';
      barBtn.classList.add('bg-ink', 'text-canvas');
      barBtn.classList.remove('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      lineBtn!.dataset.active = 'false';
      lineBtn!.classList.remove('bg-ink', 'text-canvas');
      lineBtn!.classList.add('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      updateResults();
    });
  }

  function initFormListeners() {
    const form = document.getElementById('fire-form') as HTMLFormElement;
    form?.addEventListener('input', () => {
      updateResults();
    });
  }

  function inlineAllStyles(original: HTMLElement, clone: HTMLElement) {
    const origComputed = getComputedStyle(original);
    const importantProps: string[] = [];
    for (let i = 0; i < origComputed.length; i++) {
      importantProps.push(origComputed[i]);
    }
    for (const prop of importantProps) {
      const val = origComputed.getPropertyValue(prop);
      if (val && val !== 'initial' && val !== '' && !val.startsWith('var(')) {
        try { clone.style.setProperty(prop, val); } catch {}
      }
    }
    const origChildren = original.children;
    const cloneChildren = clone.children;
    for (let i = 0; i < origChildren.length && i < cloneChildren.length; i++) {
      if (origChildren[i] instanceof HTMLElement && cloneChildren[i] instanceof HTMLElement) {
        inlineAllStyles(origChildren[i] as HTMLElement, cloneChildren[i] as HTMLElement);
      }
    }
  }

  function initExport() {
    document.getElementById('export-pdf')?.addEventListener('click', async () => {
      const btn = document.getElementById('export-pdf') as HTMLButtonElement;
      try {
        btn.disabled = true;
        btn.textContent = 'Generating PDF...';

        const html2canvas = (await import('html2canvas')).default;
        const { jsPDF } = await import('jspdf');

        const element = document.getElementById('fire-calculator')!;
        const clone = element.cloneNode(true) as HTMLElement;
        inlineAllStyles(element, clone);

        const origCanvas = element.querySelector('canvas');
        const cloneCanvas = clone.querySelector('canvas');
        if (origCanvas && cloneCanvas) {
          const ctx = cloneCanvas.getContext('2d');
          if (ctx) {
            cloneCanvas.width = origCanvas.width;
            cloneCanvas.height = origCanvas.height;
            ctx.drawImage(origCanvas, 0, 0);
          }
        }

        clone.style.position = 'fixed';
        clone.style.left = '-9999px';
        clone.style.top = '0';
        clone.style.width = element.offsetWidth + 'px';
        document.body.appendChild(clone);

        const renderedCanvas = await html2canvas(clone, {
          scale: 2,
          useCORS: true,
          backgroundColor: '#ffffff',
          logging: false,
        });

        document.body.removeChild(clone);

        const imgData = renderedCanvas.toDataURL('image/png');

        const pdf = new jsPDF('p', 'mm', 'a4');
        const pdfWidth = pdf.internal.pageSize.getWidth();
        const pdfHeight = (renderedCanvas.height * pdfWidth) / renderedCanvas.width;

        if (pdfHeight > pdf.internal.pageSize.getHeight()) {
          const totalPages = Math.ceil(pdfHeight / pdf.internal.pageSize.getHeight());
          for (let i = 0; i < totalPages; i++) {
            if (i > 0) pdf.addPage();
            pdf.addImage(imgData, 'PNG', 0, -(i * pdf.internal.pageSize.getHeight()), pdfWidth, pdfHeight);
          }
        } else {
          pdf.addImage(imgData, 'PNG', 0, 0, pdfWidth, pdfHeight);
        }

        pdf.save('fire-calculator-results.pdf');
      } catch (err) {
        console.error('PDF export failed:', err);
        alert('Failed to generate PDF. Please try again.');
      } finally {
        btn.disabled = false;
        btn.textContent = 'Export PDF';
      }
    });
  }

  function initShare() {
    const shareText = 'Check out my FIRE retirement plan!';

    function getShareUrl() {
      const input = getFormData();
      const params = new URLSearchParams({
        age: input.currentAge.toString(),
        retire: input.retirementAge.toString(),
        savings: input.currentSavings.toString(),
        income: input.monthlyIncome.toString(),
        rate: input.savingsRate.toString(),
        expenses: input.monthlyExpenses.toString(),
        return: input.annualReturnRate.toString(),
        inflation: input.inflationRate.toString(),
        swr: input.safeWithdrawalRate.toString(),
        lifestyle: input.lifestyleMultiplier?.toString() || '25',
      });
      const basePath = standaloneType ? `/${standaloneType}-fire-calculator` : '/fire-calculator';
      return `${window.location.origin}${basePath}?${params.toString()}`;
    }

    function openShareWindow(url: string) {
      window.open(url, '_blank', 'noopener,noreferrer,width=600,height=500');
    }

    document.querySelectorAll('[data-share]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const url = getShareUrl();
        const platform = (btn as HTMLElement).dataset.share;
        const shareUrls: Record<string, string> = {
          x: `https://twitter.com/intent/tweet?url=${encodeURIComponent(url)}&text=${encodeURIComponent(shareText)}`,
          facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
          linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
          whatsapp: `https://api.whatsapp.com/send?text=${encodeURIComponent(shareText + ' ' + url)}`,
          reddit: `https://reddit.com/submit?url=${encodeURIComponent(url)}&title=${encodeURIComponent(shareText)}`,
        };
        if (platform && shareUrls[platform]) {
          openShareWindow(shareUrls[platform]);
        }
      });
    });

    document.getElementById('copy-link')?.addEventListener('click', async () => {
      const url = getShareUrl();
      try {
        if (navigator.clipboard) {
          await navigator.clipboard.writeText(url);
        } else {
          const textarea = document.createElement('textarea');
          textarea.value = url;
          textarea.style.position = 'fixed';
          textarea.style.opacity = '0';
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand('copy');
          document.body.removeChild(textarea);
        }
        const btn = document.getElementById('copy-link');
        if (btn) {
          btn.classList.add('copied');
          setTimeout(() => btn.classList.remove('copied'), 2000);
        }
      } catch {
        alert('Failed to copy link.');
      }
    });

    const nativeShareBtn = document.getElementById('native-share');
    if (navigator.share && nativeShareBtn) {
      nativeShareBtn.style.display = '';
      nativeShareBtn.addEventListener('click', async () => {
        const url = getShareUrl();
        try {
          await navigator.share({
            title: 'My FIRE Calculator Results',
            text: shareText,
            url,
          });
        } catch (err) {
          if (err instanceof Error && err.name !== 'AbortError') {
            alert('Failed to share.');
          }
        }
      });
    }
  }

  function loadFromUrl() {
    const params = new URLSearchParams(window.location.search);
    if (params.has('age')) {
      const form = document.getElementById('fire-form') as HTMLFormElement;
      const fields: Record<string, string> = {
        currentAge: 'age',
        retirementAge: 'retire',
        currentSavings: 'savings',
        monthlyIncome: 'income',
        savingsRate: 'rate',
        monthlyExpenses: 'expenses',
        annualReturn: 'return',
        inflation: 'inflation',
        swr: 'swr',
      };

      Object.entries(fields).forEach(([fieldId, param]) => {
        const input = document.getElementById(fieldId) as HTMLInputElement;
        if (input && params.has(param)) {
          input.value = params.get(param)!;
        }
      });

      if (!standaloneType && params.has('lifestyle')) {
        const lifestyleValue = Number(params.get('lifestyle'));
        if (!isNaN(lifestyleValue) && lifestyleValue >= 20 && lifestyleValue <= 30) {
          lifestyleMultiplier = lifestyleValue;
          const lifestyleSlider = document.getElementById('lifestyleMultiplier') as HTMLInputElement;
          const lifestyleDisplay = document.getElementById('lifestyleMultiplierValue');
          if (lifestyleSlider) lifestyleSlider.value = lifestyleValue.toString();
          if (lifestyleDisplay) lifestyleDisplay.textContent = `${lifestyleValue}x`;
        }
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    loadFromUrl();
    initSliders();
    initChartTypeToggle();
    initFormListeners();
    initExport();
    initShare();
    updateResults();

    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
      updateResults();
    });

    const observer = new MutationObserver(() => {
      updateResults();
    });
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  });
</script>

