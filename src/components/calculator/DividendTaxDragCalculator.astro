---
import Card from '../ui/Card.astro';
import Slider from '../ui/Slider.astro';
import ResultCard from '../ui/ResultCard.astro';
import Tooltip from '../ui/Tooltip.astro';
import { defaultInput, presets } from '../../utils/dividend-tax-drag-calculations';
---

<div id="dtd-calculator" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12">
  <div class="grid gap-6 lg:grid-cols-12">
    <!-- LEFT PANEL: Inputs (5 cols, sticky) -->
    <div class="lg:col-span-5">
      <!-- Preset buttons -->
      <div class="mb-4 flex flex-wrap gap-2">
        {
          presets.map((preset, idx) => (
            <button
              data-preset={idx}
              class={`preset-btn rounded-full cursor-pointer px-3 py-1.5 text-xs font-medium transition-colors ${idx === 0 ? 'bg-ink text-canvas' : 'bg-canvas-soft-2 text-body hover:text-ink'}`}
            >
              {preset.name}
            </button>
          ))
        }
      </div>

      <Card padding="lg" class="lg:sticky lg:top-24">
        <form id="dtd-form" class="space-y-6">
          <!-- 1. Initial Investment -->
          <Slider
            label="Initial Investment"
            name="initialInvestment"
            value={defaultInput.initialInvestment}
            min={1000}
            max={1000000}
            step={1000}
            inputId="dtd-initial"
            displayId="dtd-initial-display"
            tooltip="The amount you invest as a lump sum at the start."
          />

          <!-- 2. Monthly Contribution -->
          <Slider
            label="Monthly Contribution"
            name="monthlyContribution"
            value={defaultInput.monthlyContribution}
            min={0}
            max={5000}
            step={50}
            inputId="dtd-monthly"
            displayId="dtd-monthly-display"
            tooltip="Additional amount you add to the account each month."
          />

          <!-- 3. Time Horizon -->
          <Slider
            label="Time Horizon"
            name="timeHorizon"
            value={defaultInput.timeHorizon}
            min={1}
            max={50}
            step={1}
            suffix=" years"
            inputId="dtd-horizon"
            displayId="dtd-horizon-display"
            tooltip="Number of years you plan to hold the investment."
          />

          <!-- 4. Expected Annual Price Appreciation -->
          <Slider
            label="Expected Annual Price Appreciation"
            name="priceAppreciation"
            value={Math.round(defaultInput.priceAppreciation * 100)}
            min={0}
            max={15}
            step={0.1}
            suffix="%"
            inputId="dtd-appreciation"
            displayId="dtd-appreciation-display"
            tooltip="Expected annual growth in share price (excluding dividends)."
          />

          <!-- 5. Annual Dividend Yield -->
          <Slider
            label="Annual Dividend Yield"
            name="dividendYield"
            value={Math.round(defaultInput.dividendYield * 100)}
            min={0}
            max={10}
            step={0.1}
            suffix="%"
            inputId="dtd-yield"
            displayId="dtd-yield-display"
            tooltip="Expected annual dividend yield as a percentage of the portfolio value."
          />

          <!-- 6. Percent Qualified Dividends -->
          <Slider
            label="Percent of Dividends that are 'Qualified'"
            name="percentQualified"
            value={Math.round(defaultInput.percentQualified * 100)}
            min={0}
            max={100}
            step={1}
            suffix="%"
            inputId="dtd-qualified"
            displayId="dtd-qualified-display"
            tooltip="Qualified dividends are taxed at the lower long-term capital gains rate. Most US stock dividends (held >60 days) are qualified."
          />

          <!-- 7. Federal Ordinary Income Tax Bracket -->
          <div class="flex flex-col gap-2">
            <label for="dtd-ordinary-bracket" class="inline-flex items-center gap-1.5 text-sm font-medium text-ink">
              Federal Ordinary Income Tax Bracket
              <Tooltip content="Your marginal federal income tax bracket. Non-qualified dividends and short-term capital gains are taxed at this rate." />
            </label>
            <select
              id="dtd-ordinary-bracket"
              name="federalOrdinaryBracket"
              class="h-11 w-full rounded-lg border border-hairline bg-canvas px-3 text-base text-ink transition-colors focus:border-link focus:outline-none focus:ring-2 focus:ring-link/20"
            >
              <option value="10">10%</option>
              <option value="12">12%</option>
              <option value="22">22%</option>
              <option value="24">24%</option>
              <option value="32" selected>32%</option>
              <option value="35">35%</option>
              <option value="37">37%</option>
            </select>
          </div>

          <!-- 8. Federal LTCG Tax Bracket -->
          <div class="flex flex-col gap-2">
            <label for="dtd-ltcg-bracket" class="inline-flex items-center gap-1.5 text-sm font-medium text-ink">
              Federal Long-Term Capital Gains Tax Bracket
              <Tooltip content="Qualified dividends are taxed at the long-term capital gains rate. Most retirees in the 10-12% ordinary brackets pay 0% LTCG." />
            </label>
            <select
              id="dtd-ltcg-bracket"
              name="federalLTCGBracket"
              class="h-11 w-full rounded-lg border border-hairline bg-canvas px-3 text-base text-ink transition-colors focus:border-link focus:outline-none focus:ring-2 focus:ring-link/20"
            >
              <option value="0">0%</option>
              <option value="15" selected>15%</option>
              <option value="20">20%</option>
            </select>
          </div>

          <!-- 9. State Income Tax Rate -->
          <Slider
            label="State Income Tax Rate"
            name="stateTaxRate"
            value={Math.round(defaultInput.stateTaxRate * 100)}
            min={0}
            max={15}
            step={0.1}
            suffix="%"
            inputId="dtd-state-tax"
            displayId="dtd-state-tax-display"
            tooltip="Your marginal state income tax rate. Dividends are taxed at the state level in most states (excludes AK, FL, NV, SD, TN, TX, WA, WY)."
          />

          <!-- 10. NIIT Toggle -->
          <div class="flex items-center justify-between rounded-lg border border-hairline p-4">
            <div class="flex items-center gap-1.5">
              <label for="dtd-niit-toggle" class="text-sm font-medium text-ink">
                Subject to NIIT (3.8% Surtax)
              </label>
              <Tooltip content="The Net Investment Income Tax (NIIT) adds a 3.8% surtax on the lesser of your net investment income or MAGI above $200k (single) / $250k (married filing jointly)." />
            </div>
            <button
              type="button"
              id="dtd-niit-toggle"
              class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full bg-hairline transition-colors"
              role="switch"
              aria-checked="false"
            >
              <span
                id="dtd-niit-knob"
                class="pointer-events-none inline-block h-4 w-4 translate-x-1 rounded-full bg-white shadow-sm ring-0 transition-transform"
              ></span>
            </button>
            <input type="hidden" name="subjectToNIIT" value="false" />
          </div>
        </form>
      </Card>
    </div>

    <!-- RIGHT PANEL: Results (7 cols) -->
    <div class="space-y-6 lg:col-span-7">
      <!-- Expense Ratio Equivalent Banner -->
      <div
        id="dtd-expense-banner"
        class="rounded-lg border border-warning/30 bg-warning/5 p-5"
      >
        <div class="flex items-start gap-3">
          <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-warning/20">
            <svg class="h-4 w-4 text-warning" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
            </svg>
          </div>
          <div>
            <h3 class="mb-1 text-sm font-semibold text-warning">Hidden Fee Alert</h3>
            <p id="dtd-expense-text" class="text-sm text-body">
              Taxes on your dividends are acting like a hidden fee of
              <strong id="dtd-expense-rate">—</strong>
              of your portfolio every year. Over your investment horizon, this
              drag silently erodes your compounding growth in the taxable account.
              The higher your dividend yield and tax rate, the more severe the impact.
            </p>
          </div>
        </div>
      </div>

      <!-- Primary metric cards (2x2 grid) -->
      <div class="grid gap-4 sm:grid-cols-2">
        <ResultCard
          label="Final Portfolio Balance (No Tax Drag)"
          valueId="dtd-result-ta"
          value="—"
          valueClass="text-success-deep text-2xl font-semibold tabular-nums"
          description="Hypothetical growth in a tax-advantaged account (Roth IRA / 401k)"
        />
        <ResultCard
          label="Final Portfolio Balance (With Tax Drag)"
          valueId="dtd-result-taxable"
          value="—"
          description="Realized value after annual dividend taxes in a taxable account"
        />
        <ResultCard
          label="Total Wealth Lost to Taxes"
          valueId="dtd-result-lost"
          value="—"
          valueClass="text-error text-2xl font-semibold tabular-nums"
          description="The gap between tax-advantaged and taxable account growth"
        />
        <ResultCard
          label="Expense Ratio Equivalent"
          valueId="dtd-result-drag"
          value="—"
          valueClass="text-warning text-2xl font-semibold tabular-nums"
          description="Annualized percentage of portfolio value lost to dividend taxes"
        />
      </div>

      <!-- Chart section -->
      <Card padding="lg">
        <h3 class="mb-4 text-sm font-semibold text-ink">
          Growth Trajectory: Tax-Advantaged vs Taxable
        </h3>
        <div class="relative h-64 sm:h-80">
          <canvas id="dtd-chart"></canvas>
        </div>
      </Card>

      <!-- Yearly breakdown table -->
      <Card padding="lg">
        <div class="mb-4 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-ink">Year-by-Year Breakdown</h3>
          <button
            id="dtd-toggle-table"
            class="cursor-pointer text-xs font-medium text-link hover:text-link-deep"
          >
            Show All Years
          </button>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline">
                <th class="pb-2 pr-4 text-xs font-medium text-mute">Year</th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">
                  Tax-Advantaged
                </th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">Taxable</th>
                <th class="hidden pb-2 pr-4 text-xs font-medium text-mute sm:table-cell">
                  Gross Dividends
                </th>
                <th class="hidden pb-2 pr-4 text-xs font-medium text-mute sm:table-cell">
                  Tax Owed
                </th>
                <th class="hidden pb-2 text-xs font-medium text-mute md:table-cell">
                  Cumulative Tax Paid
                </th>
              </tr>
            </thead>
            <tbody
              id="dtd-yearly-body"
              class="font-mono text-xs tabular-nums"
            ></tbody>
          </table>
        </div>
      </Card>
    </div>
  </div>
</div>

<script>
  import {
    calculateDividendTaxDrag,
    defaultInput,
    presets,
  } from '../../utils/dividend-tax-drag-calculations';
  import {
    formatCurrency,
    formatCurrencyShort,
  } from '../../utils/formatters';

  let chart = null;
  let showAllYears = false;
  let lastResult = null;

  // ─── Helpers ────────────────────────────────────────────────

  function formatDollar(val) {
    if (Math.abs(val) >= 1_000_000) {
      return '$' + (val / 1_000_000).toFixed(1) + 'M';
    }
    return '$' + Number(val).toLocaleString('en-US', {
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    });
  }

  function formatPct(val) {
    return Number(val).toFixed(1) + '%';
  }

  function formatDragPct(val) {
    return Number(val).toFixed(2) + '%';
  }

  // ─── DOM References ─────────────────────────────────────────

  const sliders = {
    initial: document.getElementById('dtd-initial'),
    monthly: document.getElementById('dtd-monthly'),
    horizon: document.getElementById('dtd-horizon'),
    appreciation: document.getElementById('dtd-appreciation'),
    yield: document.getElementById('dtd-yield'),
    qualified: document.getElementById('dtd-qualified'),
    stateTax: document.getElementById('dtd-state-tax'),
  };

  const displays = {
    initial: document.getElementById('dtd-initial-display'),
    monthly: document.getElementById('dtd-monthly-display'),
    horizon: document.getElementById('dtd-horizon-display'),
    appreciation: document.getElementById('dtd-appreciation-display'),
    yield: document.getElementById('dtd-yield-display'),
    qualified: document.getElementById('dtd-qualified-display'),
    stateTax: document.getElementById('dtd-state-tax-display'),
  };

  const ordinaryBracket = document.getElementById('dtd-ordinary-bracket');
  const ltcgBracket = document.getElementById('dtd-ltcg-bracket');
  const niitToggle = document.getElementById('dtd-niit-toggle');
  const niitKnob = document.getElementById('dtd-niit-knob');
  const niitHidden = document.querySelector(
    'input[name="subjectToNIIT"]',
  );

  // ─── Input / Output ─────────────────────────────────────────

  function getInputs() {
    return {
      initialInvestment:
        Number(sliders.initial?.value) || defaultInput.initialInvestment,
      monthlyContribution:
        Number(sliders.monthly?.value) || defaultInput.monthlyContribution,
      timeHorizon:
        Number(sliders.horizon?.value) || defaultInput.timeHorizon,
      priceAppreciation:
        (Number(sliders.appreciation?.value) ||
          defaultInput.priceAppreciation * 100) / 100,
      dividendYield:
        (Number(sliders.yield?.value) || defaultInput.dividendYield * 100) / 100,
      percentQualified:
        (Number(sliders.qualified?.value) ||
          defaultInput.percentQualified * 100) / 100,
      federalOrdinaryBracket:
        Number(ordinaryBracket?.value || 32) / 100,
      federalLTCGBracket:
        Number(ltcgBracket?.value || 15) / 100,
      stateTaxRate:
        (Number(sliders.stateTax?.value) ||
          defaultInput.stateTaxRate * 100) / 100,
      subjectToNIIT: niitToggle?.getAttribute('aria-checked') === 'true',
    };
  }

  function updateDisplays() {
    if (displays.initial)
      displays.initial.textContent = formatDollar(
        Number(sliders.initial?.value) || 0,
      );
    if (displays.monthly)
      displays.monthly.textContent = formatDollar(
        Number(sliders.monthly?.value) || 0,
      );
    if (displays.horizon)
      displays.horizon.textContent =
        (sliders.horizon?.value || 0) + ' years';
    if (displays.appreciation)
      displays.appreciation.textContent = formatPct(
        Number(sliders.appreciation?.value) || 0,
      );
    if (displays.yield)
      displays.yield.textContent = formatPct(
        Number(sliders.yield?.value) || 0,
      );
    if (displays.qualified)
      displays.qualified.textContent = formatPct(
        Number(sliders.qualified?.value) || 0,
      );
    if (displays.stateTax)
      displays.stateTax.textContent = formatPct(
        Number(sliders.stateTax?.value) || 0,
      );
  }

  function updateResults() {
    const input = getInputs();
    const result = calculateDividendTaxDrag(input);
    lastResult = result;

    // Metric cards
    document.getElementById('dtd-result-ta').textContent = formatCurrency(
      result.taxAdvantagedFinal,
    );
    document.getElementById('dtd-result-taxable').textContent = formatCurrency(
      result.taxableFinal,
    );
    document.getElementById('dtd-result-lost').textContent = formatCurrency(
      result.totalWealthLost,
    );
    document.getElementById('dtd-result-drag').textContent = formatDragPct(
      result.totalTaxDragPercent * 100,
    );

    // Expense ratio banner
    const dragPct = (result.totalTaxDragPercent * 100).toFixed(2);
    document.getElementById('dtd-expense-rate').textContent =
      dragPct + '% of your portfolio every year';

    // Update table
    updateTable(result.yearlyProjections);

    // Update chart
    updateChart(result);
  }

  // ─── Yearly Table ───────────────────────────────────────────

  function updateTable(data) {
    const tbody = document.getElementById('dtd-yearly-body');
    if (!tbody) return;

    const displayData = showAllYears
      ? data
      : [...data.slice(0, 5), data[data.length - 1]];

    // Deduplicate when horizon <= 6 (avoids showing same last year twice)
    const unique = showAllYears
      ? data
      : displayData.filter(
          (d, i, arr) => arr.findIndex((x) => x.year === d.year) === i,
        );

    tbody.innerHTML = unique
      .map(
        (d) => `
      <tr class="border-b border-hairline/50">
        <td class="py-2 pr-4 text-body font-sans">${d.year}</td>
        <td class="py-2 pr-4 text-success-deep font-medium">${formatCurrency(d.taxAdvantagedBalance)}</td>
        <td class="py-2 pr-4 text-ink">${formatCurrency(d.taxableBalance)}</td>
        <td class="hidden py-2 pr-4 text-body sm:table-cell">${formatCurrency(d.grossDividends)}</td>
        <td class="hidden py-2 pr-4 text-error sm:table-cell">${formatCurrency(d.taxOwed)}</td>
        <td class="hidden py-2 text-mute md:table-cell">${formatCurrency(d.cumulativeDividendsPaid)}</td>
      </tr>
    `,
      )
      .join('');
  }

  // ─── Chart ──────────────────────────────────────────────────

  function getChartColors() {
    const isDark = document.documentElement.classList.contains('dark');
    return {
      green: isDark ? '#22c55e' : '#16a34a',
      amber: isDark ? '#fbbf24' : '#d97706',
      greenBg: isDark
        ? 'rgba(34, 197, 94, 0.12)'
        : 'rgba(22, 163, 74, 0.1)',
      amberBg: isDark
        ? 'rgba(251, 191, 36, 0.12)'
        : 'rgba(217, 119, 6, 0.1)',
      grid: isDark ? '#262626' : '#ebebeb',
      text: isDark ? '#737373' : '#888888',
      tooltipBg: isDark ? '#ededed' : '#171717',
      tooltipText: isDark ? '#171717' : '#ffffff',
    };
  }

  function updateChart(result) {
    const canvas = document.getElementById('dtd-chart');
    if (!canvas || typeof Chart === 'undefined') return;

    const ctx = canvas.getContext('2d');
    const colors = getChartColors();
    const data = result.yearlyProjections;

    if (chart) chart.destroy();

    const labels = data.map((d) => `Year ${d.year}`);
    const taData = data.map((d) => d.taxAdvantagedBalance);
    const taxableData = data.map((d) => d.taxableBalance);

    chart = new Chart(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Tax-Advantaged (Roth/IRA)',
            data: taData,
            borderColor: colors.green,
            backgroundColor: colors.greenBg,
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
          {
            label: 'Taxable Account',
            data: taxableData,
            borderColor: colors.amber,
            backgroundColor: colors.amberBg,
            fill: true,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'end',
            labels: {
              boxWidth: 12,
              boxHeight: 2,
              padding: 16,
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: colors.text,
            },
          },
          tooltip: {
            backgroundColor: colors.tooltipBg,
            titleColor: colors.tooltipText,
            bodyColor: colors.tooltipText,
            borderColor: colors.tooltipBg,
            borderWidth: 1,
            padding: 12,
            titleFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
              weight: '500',
            },
            bodyFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
            },
            callbacks: {
              label: function (context) {
                return (
                  context.dataset.label +
                  ': ' +
                  formatCurrency(context.parsed.y)
                );
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: colors.text,
              maxTicksLimit: 10,
              callback: function (value, index) {
                const entry = data[index];
                return entry ? 'Y' + entry.year : '';
              },
            },
            border: { display: false },
          },
          y: {
            grid: { color: colors.grid },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: colors.text,
              callback: function (value) {
                return formatCurrencyShort(value);
              },
            },
            border: { display: false },
          },
        },
      },
    });
  }

  // ─── Initialization ─────────────────────────────────────────

  // Set slider initial values
  sliders.initial.value = String(defaultInput.initialInvestment);
  sliders.monthly.value = String(defaultInput.monthlyContribution);
  sliders.horizon.value = String(defaultInput.timeHorizon);
  sliders.appreciation.value = String(
    Math.round(defaultInput.priceAppreciation * 100),
  );
  sliders.yield.value = String(Math.round(defaultInput.dividendYield * 100));
  sliders.qualified.value = String(
    Math.round(defaultInput.percentQualified * 100),
  );
  sliders.stateTax.value = String(
    Math.round(defaultInput.stateTaxRate * 100),
  );

  // Set dropdown defaults
  ordinaryBracket.value = String(
    Math.round(defaultInput.federalOrdinaryBracket * 100),
  );
  ltcgBracket.value = String(
    Math.round(defaultInput.federalLTCGBracket * 100),
  );

  updateDisplays();

  // ─── Event Listeners ────────────────────────────────────────

  // Slider inputs
  Object.entries(sliders).forEach(([, slider]) => {
    if (!slider) return;
    slider.addEventListener('input', () => {
      updateDisplays();
      updateResults();
    });
  });

  // Dropdown changes
  ordinaryBracket?.addEventListener('change', updateResults);
  ltcgBracket?.addEventListener('change', updateResults);

  // NIIT toggle
  niitToggle?.addEventListener('click', function () {
    const isActive = this.getAttribute('aria-checked') === 'true';
    const newState = !isActive;
    this.setAttribute('aria-checked', String(newState));
    if (newState) {
      this.classList.remove('bg-hairline');
      this.classList.add('bg-ink');
      niitKnob.classList.remove('translate-x-1');
      niitKnob.classList.add('translate-x-6');
    } else {
      this.classList.remove('bg-ink');
      this.classList.add('bg-hairline');
      niitKnob.classList.remove('translate-x-6');
      niitKnob.classList.add('translate-x-1');
    }
    if (niitHidden) niitHidden.value = String(newState);
    updateResults();
  });

  // Table toggle
  document
    .getElementById('dtd-toggle-table')
    ?.addEventListener('click', function () {
      showAllYears = !showAllYears;
      this.textContent = showAllYears ? 'Show Less' : 'Show All Years';
      if (lastResult) updateTable(lastResult.yearlyProjections);
    });

  // Preset buttons
  document.querySelectorAll('.preset-btn').forEach((btn) => {
    btn.addEventListener('click', function () {
      const idx = Number(this.dataset.preset);
      const preset = presets[idx];
      if (!preset) return;

      // Update active state
      document.querySelectorAll('.preset-btn').forEach((b) => {
        b.classList.remove('bg-ink', 'text-canvas');
        b.classList.add('bg-canvas-soft-2', 'text-body', 'hover:text-ink');
      });
      this.classList.add('bg-ink', 'text-canvas');
      this.classList.remove(
        'bg-canvas-soft-2',
        'text-body',
        'hover:text-ink',
      );

      const p = preset.input;

      // Set sliders
      sliders.initial.value = String(p.initialInvestment);
      sliders.monthly.value = String(p.monthlyContribution);
      sliders.horizon.value = String(p.timeHorizon);
      sliders.appreciation.value = String(
        Math.round(p.priceAppreciation * 100),
      );
      sliders.yield.value = String(Math.round(p.dividendYield * 100));
      sliders.qualified.value = String(Math.round(p.percentQualified * 100));
      sliders.stateTax.value = String(Math.round(p.stateTaxRate * 100));

      // Set dropdowns
      ordinaryBracket.value = String(
        Math.round(p.federalOrdinaryBracket * 100),
      );
      ltcgBracket.value = String(Math.round(p.federalLTCGBracket * 100));

      // Set NIIT toggle
      const niitState = p.subjectToNIIT;
      niitToggle.setAttribute('aria-checked', String(niitState));
      if (niitState) {
        niitToggle.classList.remove('bg-hairline');
        niitToggle.classList.add('bg-ink');
        niitKnob.classList.remove('translate-x-1');
        niitKnob.classList.add('translate-x-6');
      } else {
        niitToggle.classList.remove('bg-ink');
        niitToggle.classList.add('bg-hairline');
        niitKnob.classList.remove('translate-x-6');
        niitKnob.classList.add('translate-x-1');
      }
      if (niitHidden) niitHidden.value = String(niitState);

      updateDisplays();
      updateResults();
    });
  });

  // Dark mode observer for chart re-render
  const observer = new MutationObserver(() => {
    if (lastResult) updateChart(lastResult);
  });
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });

  // Initial calculation
  updateResults();
</script>
