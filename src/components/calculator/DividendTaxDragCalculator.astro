---
import Card from '../ui/Card.astro';
---

<div
  class="mx-auto max-w-6xl px-4 py-8 sm:px-6 sm:py-12"
  id="dividend-tax-drag-calculator"
>
  <!-- Hero text -->
  <div class="mb-8 text-center">
    <p class="mb-2 font-mono text-xs uppercase tracking-wider text-mute">
      Interactive Tool
    </p>
    <h2
      class="mb-3 text-2xl font-semibold tracking-tight text-ink sm:text-3xl"
      style="letter-spacing: -0.02em;"
    >
      Dividend Tax Drag Modeler
    </h2>
    <p class="mx-auto max-w-2xl text-sm text-body">
      Compare the growth of dividend-paying investments in a Taxable Account vs
      a Tax-Advantaged Account over time.
    </p>
  </div>

  <!-- Two-column layout -->
  <div class="grid gap-6 lg:grid-cols-12">
    <!-- Left: Controls -->
    <div class="lg:col-span-5">
      <!-- Preset buttons -->
      <div class="mb-4 flex flex-wrap gap-2">
        <button
          data-preset="0"
          class="preset-btn rounded-full cursor-pointer bg-ink px-3 py-1.5 text-xs font-medium text-canvas transition-colors"
          >High-Yield Div Growth</button
        >
        <button
          data-preset="1"
          class="preset-btn rounded-full cursor-pointer bg-canvas-soft-2 px-3 py-1.5 text-xs font-medium text-body transition-colors hover:text-ink"
          >Aristocrats Conservative</button
        >
        <button
          data-preset="2"
          class="preset-btn rounded-full cursor-pointer bg-canvas-soft-2 px-3 py-1.5 text-xs font-medium text-body transition-colors hover:text-ink"
          >Indian Div Value</button
        >
        <button
          data-preset="3"
          class="preset-btn rounded-full cursor-pointer bg-canvas-soft-2 px-3 py-1.5 text-xs font-medium text-body transition-colors hover:text-ink"
          >REIT Heavy</button
        >
        <button
          data-preset="4"
          class="preset-btn rounded-full cursor-pointer bg-canvas-soft-2 px-3 py-1.5 text-xs font-medium text-body transition-colors hover:text-ink"
          >Low Tax / Roth</button
        >
      </div>

      <!-- Controls card -->
      <Card padding="lg" class="lg:sticky lg:top-24">
        <!-- Reinvest toggle -->
        <div class="mb-6 flex items-center justify-between">
          <div>
            <label class="text-sm font-medium text-ink"
              >Reinvest Dividends</label
            >
            <p class="text-xs text-mute">
              Toggle between reinvesting or taking dividends as cash
            </p>
          </div>
          <button
            id="reinvest-toggle"
            role="switch"
            aria-checked="true"
            class="relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full bg-ink transition-colors"
          >
            <span
              id="reinvest-dot"
              class="pointer-events-none inline-block h-5 w-5 translate-x-5 transform rounded-full bg-canvas shadow-sm ring-0 transition-transform"
            ></span>
          </button>
        </div>

        <!-- Sliders -->
        <!-- Initial Investment -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label for="slider-initial" class="text-sm font-medium text-ink"
              >Initial Investment</label
            >
            <span
              id="display-initial"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >$10,000</span
            >
          </div>
          <input
            id="slider-initial"
            type="range"
            value="10000"
            min="1000"
            max="1000000"
            step="1000"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>$1,000</span><span>$1,000,000</span>
          </div>
        </div>

        <!-- Annual Contribution -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label
              for="slider-contribution"
              class="text-sm font-medium text-ink"
              >Annual Contribution</label
            >
            <span
              id="display-contribution"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >$6,000</span
            >
          </div>
          <input
            id="slider-contribution"
            type="range"
            value="6000"
            min="0"
            max="100000"
            step="500"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>$0</span><span>$100,000</span>
          </div>
        </div>

        <!-- Investment Horizon -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label for="slider-horizon" class="text-sm font-medium text-ink"
              >Investment Horizon</label
            >
            <span
              id="display-horizon"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >25 yrs</span
            >
          </div>
          <input
            id="slider-horizon"
            type="range"
            value="25"
            min="1"
            max="50"
            step="1"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>1 yr</span><span>50 yrs</span>
          </div>
        </div>

        <!-- Capital Appreciation Rate -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label for="slider-gc" class="text-sm font-medium text-ink"
              >Capital Appreciation Rate</label
            >
            <span
              id="display-gc"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >5.5%</span
            >
          </div>
          <input
            id="slider-gc"
            type="range"
            value="5.5"
            min="0"
            max="15"
            step="0.1"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>0%</span><span>15%</span>
          </div>
        </div>

        <!-- Dividend Yield -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label for="slider-yield" class="text-sm font-medium text-ink"
              >Dividend Yield</label
            >
            <span
              id="display-yield"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >3.5%</span
            >
          </div>
          <input
            id="slider-yield"
            type="range"
            value="3.5"
            min="0"
            max="15"
            step="0.1"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>0%</span><span>15%</span>
          </div>
        </div>

        <!-- Dividend Growth Rate -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label for="slider-gd" class="text-sm font-medium text-ink"
              >Dividend Growth Rate</label
            >
            <span
              id="display-gd"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >5.0%</span
            >
          </div>
          <input
            id="slider-gd"
            type="range"
            value="5.0"
            min="0"
            max="10"
            step="0.1"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>0%</span><span>10%</span>
          </div>
        </div>

        <!-- Dividend Tax Rate -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label for="slider-td" class="text-sm font-medium text-ink"
              >Dividend Tax Rate</label
            >
            <span
              id="display-td"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >15%</span
            >
          </div>
          <input
            id="slider-td"
            type="range"
            value="15"
            min="0"
            max="50"
            step="0.5"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>0%</span><span>50%</span>
          </div>
        </div>

        <!-- Capital Gains Tax Rate -->
        <div class="mb-4 flex flex-col gap-2">
          <div class="flex items-center justify-between">
            <label for="slider-tcg" class="text-sm font-medium text-ink"
              >Capital Gains Tax Rate</label
            >
            <span
              id="display-tcg"
              class="font-mono text-sm font-medium text-ink tabular-nums"
              >15%</span
            >
          </div>
          <input
            id="slider-tcg"
            type="range"
            value="15"
            min="0"
            max="50"
            step="0.5"
            class="w-full accent-ink"
          />
          <div class="flex justify-between text-xs text-mute">
            <span>0%</span><span>50%</span>
          </div>
        </div>
      </Card>
    </div>

    <!-- Right: Outputs -->
    <div class="space-y-6 lg:col-span-7">
      <!-- Primary metric cards -->
      <div class="grid gap-4 sm:grid-cols-3">
        <div
          class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm"
        >
          <p class="mb-1 text-xs text-mute">Tax-Advantaged Ending</p>
          <p
            id="result-ta"
            class="font-mono text-2xl font-semibold tabular-nums"
            style="color: var(--color-success-deep);"
          >
            $0
          </p>
        </div>
        <div
          class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm"
        >
          <p class="mb-1 text-xs text-mute">Taxable Realized</p>
          <p
            id="result-taxable"
            class="font-mono text-2xl font-semibold text-ink tabular-nums"
          >
            $0
          </p>
        </div>
        <div
          class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm"
        >
          <p class="mb-1 text-xs text-mute">Opportunity Cost</p>
          <p
            id="result-cost"
            class="font-mono text-2xl font-semibold tabular-nums"
            style="color: var(--color-error);"
          >
            $0
          </p>
        </div>
      </div>

      <!-- Secondary metrics -->
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-lg bg-canvas-soft-2 p-4">
          <p class="mb-1 text-xs text-mute">Return Lost to Drag</p>
          <p
            id="result-pct"
            class="font-mono text-lg font-semibold text-ink tabular-nums"
          >
            0.0%
          </p>
        </div>
        <div class="rounded-lg bg-canvas-soft-2 p-4">
          <p class="mb-1 text-xs text-mute">Effective Annual Drag</p>
          <p
            id="result-drag"
            class="font-mono text-lg font-semibold text-ink tabular-nums"
          >
            0.00%
          </p>
        </div>
        <div class="rounded-lg bg-canvas-soft-2 p-4">
          <p class="mb-1 text-xs text-mute">Total Dividend Tax Paid</p>
          <p
            id="result-divtax"
            class="font-mono text-lg font-semibold tabular-nums"
            style="color: var(--color-error);"
          >
            $0
          </p>
        </div>
      </div>

      <!-- FIRE Alert Banner -->
      <div
        class="rounded-lg p-5"
        style="background: var(--color-warning-soft); border: 1px solid var(--color-warning);"
      >
        <div class="flex items-start gap-3">
          <div
            class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full"
            style="background: var(--color-warning);"
          >
            <svg
              class="h-4 w-4"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z"
              />
              <path
                d="M12 18a3.75 3.75 0 00.495-7.467 5.99 5.99 0 00-1.925 3.546 5.974 5.974 0 01-2.133-1A3.75 3.75 0 0012 18z"
              />
            </svg>
          </div>
          <div>
            <h3 class="mb-1 text-sm font-semibold text-ink">
              Why does this matter for FIRE?
            </h3>
            <p class="text-sm text-body">
              Asset location is critical for FIRE seekers. High-dividend assets
              like REITs and Value stocks suffer massive compounding decay in
              taxable accounts. Every dollar of dividend tax paid in Year 1
              permanently removes that cash from compound growth for the
              remaining N-1 years. Over 25+ years, this "sequence of tax drag"
              can cost tens or hundreds of thousands in lost wealth.
            </p>
          </div>
        </div>
      </div>

      <!-- Chart section -->
      <div
        class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm"
      >
        <div class="mb-4 flex items-center justify-between">
          <h3 class="text-sm font-medium text-ink">
            Growth Trajectory Comparison
          </h3>
          <div class="flex gap-2">
            <button
              id="chart-line"
              class="chart-btn rounded-md cursor-pointer bg-ink px-3 py-1.5 text-xs font-medium text-canvas"
              >Line</button
            >
            <button
              id="chart-bar"
              class="chart-btn rounded-md cursor-pointer bg-canvas-soft-2 px-3 py-1.5 text-xs font-medium text-body hover:text-ink"
              >Bar</button
            >
          </div>
        </div>
        <div class="relative h-64 sm:h-80">
          <canvas id="tax-drag-chart"></canvas>
        </div>
      </div>

      <!-- Yearly table -->
      <div
        class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm"
      >
        <div class="mb-4 flex items-center justify-between">
          <h3 class="text-sm font-medium text-ink">Yearly Breakdown</h3>
          <button
            id="toggle-table"
            class="cursor-pointer text-xs font-medium text-link hover:text-link-deep"
            >Show All Years</button
          >
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-hairline">
                <th class="pb-2 pr-4 text-xs font-medium text-mute">Year</th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">
                  Tax-Advantaged
                </th>
                <th class="pb-2 pr-4 text-xs font-medium text-mute">
                  Taxable
                </th>
                <th
                  class="hidden pb-2 pr-4 text-xs font-medium text-mute sm:table-cell"
                >
                  Gross Dividends
                </th>
                <th
                  class="hidden pb-2 text-xs font-medium text-mute sm:table-cell"
                >
                  Tax Owed
                </th>
              </tr>
            </thead>
            <tbody
              id="yearly-body"
              class="font-mono text-xs tabular-nums"
            ></tbody>
          </table>
        </div>
      </div>

      <!-- Liquidation summary -->
      <div
        class="rounded-lg border border-hairline bg-canvas p-5 shadow-sm"
      >
        <h3 class="mb-4 text-sm font-medium text-ink">
          End-of-Horizon Liquidation Tax Event
        </h3>
        <div class="grid gap-4 sm:grid-cols-2">
          <div
            class="rounded-lg p-4"
            style="background: color-mix(in srgb, var(--color-success) 5%, transparent); border: 1px solid color-mix(in srgb, var(--color-success) 30%, transparent);"
          >
            <p class="mb-1 text-xs text-mute">Tax-Advantaged Account</p>
            <p
              id="liq-ta"
              class="font-mono text-xl font-semibold tabular-nums"
              style="color: var(--color-success-deep);"
            >
              $0
            </p>
            <p class="mt-1 text-xs text-body">
              No taxes on liquidation (Roth/ISA)
            </p>
          </div>
          <div
            class="rounded-lg border border-hairline bg-canvas-soft-2 p-4"
          >
            <p class="mb-1 text-xs text-mute">Taxable Account</p>
            <p
              id="liq-taxable"
              class="font-mono text-xl font-semibold text-ink tabular-nums"
            >
              $0
            </p>
            <p class="mt-1 text-xs text-body">
              After capital gains tax of
              <span id="liq-cgtax" class="font-medium">$0</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import {
    calculateDividendTaxDrag,
    defaultInput,
    presets,
  } from '../../utils/dividend-tax-drag-calculations';
  import { formatCurrency, formatCurrencyShort } from '../../utils/formatters';

  let chart: any = null;
  let showAllYears = false;
  let reinvest = true;
  let lastResult: any = null;

  // Get all slider elements
  const sliders = {
    initial: document.getElementById('slider-initial') as HTMLInputElement,
    contribution: document.getElementById('slider-contribution') as HTMLInputElement,
    horizon: document.getElementById('slider-horizon') as HTMLInputElement,
    gc: document.getElementById('slider-gc') as HTMLInputElement,
    yield: document.getElementById('slider-yield') as HTMLInputElement,
    gd: document.getElementById('slider-gd') as HTMLInputElement,
    td: document.getElementById('slider-td') as HTMLInputElement,
    tcg: document.getElementById('slider-tcg') as HTMLInputElement,
  };

  const displays = {
    initial: document.getElementById('display-initial')!,
    contribution: document.getElementById('display-contribution')!,
    horizon: document.getElementById('display-horizon')!,
    gc: document.getElementById('display-gc')!,
    yield: document.getElementById('display-yield')!,
    gd: document.getElementById('display-gd')!,
    td: document.getElementById('display-td')!,
    tcg: document.getElementById('display-tcg')!,
  };

  function formatDollar(val: number): string {
    return '$' + Number(val).toLocaleString('en-US');
  }

  function formatPct(val: number): string {
    return val.toFixed(1) + '%';
  }

  function getInputs() {
    return {
      initialInvestment:
        Number(sliders.initial?.value) || defaultInput.initialInvestment,
      annualContribution:
        Number(sliders.contribution?.value) || defaultInput.annualContribution,
      investmentHorizon:
        Number(sliders.horizon?.value) || defaultInput.investmentHorizon,
      capitalAppreciationRate:
        (Number(sliders.gc?.value) || defaultInput.capitalAppreciationRate * 100) / 100,
      dividendYield:
        (Number(sliders.yield?.value) || defaultInput.dividendYield * 100) / 100,
      dividendGrowthRate:
        (Number(sliders.gd?.value) || defaultInput.dividendGrowthRate * 100) / 100,
      dividendTaxRate:
        (Number(sliders.td?.value) || defaultInput.dividendTaxRate * 100) / 100,
      capitalGainsTaxRate:
        (Number(sliders.tcg?.value) || defaultInput.capitalGainsTaxRate * 100) / 100,
      reinvestDividends: reinvest,
    };
  }

  function updateDisplays() {
    displays.initial.textContent = formatDollar(
      sliders.initial?.value || 0,
    );
    displays.contribution.textContent = formatDollar(
      sliders.contribution?.value || 0,
    );
    displays.horizon.textContent = sliders.horizon?.value + ' yrs';
    displays.gc.textContent = formatPct(
      Number(sliders.gc?.value) || 0,
    );
    displays.yield.textContent = formatPct(
      Number(sliders.yield?.value) || 0,
    );
    displays.gd.textContent = formatPct(
      Number(sliders.gd?.value) || 0,
    );
    displays.td.textContent = formatPct(Number(sliders.td?.value) || 0);
    displays.tcg.textContent = formatPct(
      Number(sliders.tcg?.value) || 0,
    );
  }

  function updateResults() {
    const input = getInputs();
    const result = calculateDividendTaxDrag(input);
    lastResult = result;

    // Update metric cards
    document.getElementById('result-ta')!.textContent = formatCurrency(
      result.taxAdvantagedEndingBalance,
    );
    document.getElementById('result-taxable')!.textContent = formatCurrency(
      result.taxableRealizedValue,
    );
    document.getElementById('result-cost')!.textContent = formatCurrency(
      result.absoluteOpportunityCost,
    );
    document.getElementById('result-pct')!.textContent =
      result.percentageReturnLost.toFixed(1) + '%';
    document.getElementById('result-drag')!.textContent =
      result.effectiveAnnualDrag.toFixed(2) + '%';
    document.getElementById('result-divtax')!.textContent = formatCurrency(
      result.totalDividendTaxPaid,
    );

    // Update liquidation
    document.getElementById('liq-ta')!.textContent = formatCurrency(
      result.taxAdvantagedEndingBalance,
    );
    document.getElementById('liq-taxable')!.textContent = formatCurrency(
      result.taxableRealizedValue,
    );
    document.getElementById('liq-cgtax')!.textContent = formatCurrency(
      result.capitalGainsTaxDueAtExit,
    );

    // Update table
    updateTable(result.yearlyData);

    // Update chart
    updateChart(result);
  }

  function updateTable(data: any[]) {
    const tbody = document.getElementById('yearly-body')!;
    const displayData = showAllYears
      ? data
      : [...data.slice(0, 5), data[data.length - 1]];
    // Deduplicate if horizon <= 6
    const unique = showAllYears
      ? data
      : displayData.filter(
          (d, i, arr) => arr.findIndex((x) => x.year === d.year) === i,
        );

    tbody.innerHTML = unique
      .map(
        (d) => `
      <tr class="border-b border-hairline/50">
        <td class="py-2 pr-4 text-body font-sans">${d.year}</td>
        <td class="py-2 pr-4 text-success-deep font-medium">${formatCurrency(d.taxAdvantagedBalance)}</td>
        <td class="py-2 pr-4 text-ink">${formatCurrency(d.taxableBalance)}</td>
        <td class="hidden py-2 pr-4 text-body sm:table-cell">${formatCurrency(d.grossDividends)}</td>
        <td class="hidden py-2 text-error sm:table-cell">${formatCurrency(d.taxOwed)}</td>
      </tr>
    `,
      )
      .join('');
  }

  function updateChart(result: any) {
    const ctx = document.getElementById(
      'tax-drag-chart',
    ) as HTMLCanvasElement;
    if (!ctx) return;

    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? '#262626' : '#ebebeb';
    const textColor = isDark ? '#737373' : '#888888';
    const tooltipBg = isDark ? '#ededed' : '#171717';
    const tooltipText = isDark ? '#171717' : '#ffffff';
    const greenColor = isDark ? '#50e3c2' : '#29bc9b';
    const amberColor = isDark ? '#f5a623' : '#d97706';
    const greenBg = isDark
      ? 'rgba(80, 227, 194, 0.1)'
      : 'rgba(41, 188, 155, 0.1)';
    const amberBg = isDark
      ? 'rgba(245, 166, 35, 0.1)'
      : 'rgba(217, 119, 6, 0.1)';

    const labels = result.yearlyData
      .filter(
        (_: any, i: number) =>
          i % Math.max(1, Math.floor(result.yearlyData.length / 10)) === 0 ||
          i === result.yearlyData.length - 1,
      )
      .map((d: any) => `Year ${d.year}`);
    const taData = result.yearlyData
      .filter(
        (_: any, i: number) =>
          i % Math.max(1, Math.floor(result.yearlyData.length / 10)) === 0 ||
          i === result.yearlyData.length - 1,
      )
      .map((d: any) => d.taxAdvantagedBalance);
    const taxableData = result.yearlyData
      .filter(
        (_: any, i: number) =>
          i % Math.max(1, Math.floor(result.yearlyData.length / 10)) === 0 ||
          i === result.yearlyData.length - 1,
      )
      .map((d: any) => d.taxableBalance);

    const activeBtn = document.getElementById('chart-line');
    const chartType = activeBtn?.classList.contains('bg-ink')
      ? 'line'
      : 'bar';

    if (chart) chart.destroy();

    chart = new (window as any).Chart(ctx, {
      type: chartType,
      data: {
        labels,
        datasets: [
          {
            label: 'Tax-Advantaged (Roth/ISA)',
            data: taData,
            borderColor: greenColor,
            backgroundColor:
              chartType === 'line' ? greenBg : greenColor + '80',
            fill: chartType === 'line',
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
          {
            label: 'Taxable Account',
            data: taxableData,
            borderColor: amberColor,
            backgroundColor:
              chartType === 'line' ? amberBg : amberColor + '80',
            fill: chartType === 'line',
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 4,
            borderWidth: 2,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'end',
            labels: {
              boxWidth: 12,
              boxHeight: 2,
              padding: 16,
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
            },
          },
          tooltip: {
            backgroundColor: tooltipBg,
            titleColor: tooltipText,
            bodyColor: tooltipText,
            borderColor: tooltipBg,
            borderWidth: 1,
            padding: 12,
            titleFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
              weight: '500',
            },
            bodyFont: {
              family: 'Inter, system-ui, sans-serif',
              size: 12,
            },
            callbacks: {
              label: function (context: any) {
                return (
                  context.dataset.label +
                  ': ' +
                  formatCurrency(context.parsed.y)
                );
              },
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              maxTicksLimit: 8,
            },
            border: { display: false },
          },
          y: {
            grid: { color: gridColor },
            ticks: {
              font: {
                family: 'Inter, system-ui, sans-serif',
                size: 11,
              },
              color: textColor,
              callback: function (value: any) {
                return formatCurrencyShort(value);
              },
            },
            border: { display: false },
          },
        },
      },
    });
  }

  // Initialize sliders
  Object.entries(sliders).forEach(([key, slider]) => {
    if (!slider) return;
    slider.addEventListener('input', () => {
      updateDisplays();
      updateResults();
    });
  });

  // Initialize displays with default values
  sliders.initial!.value = String(defaultInput.initialInvestment);
  sliders.contribution!.value = String(defaultInput.annualContribution);
  sliders.horizon!.value = String(defaultInput.investmentHorizon);
  sliders.gc!.value = String(defaultInput.capitalAppreciationRate * 100);
  sliders.yield!.value = String(defaultInput.dividendYield * 100);
  sliders.gd!.value = String(defaultInput.dividendGrowthRate * 100);
  sliders.td!.value = String(defaultInput.dividendTaxRate * 100);
  sliders.tcg!.value = String(defaultInput.capitalGainsTaxRate * 100);
  updateDisplays();

  // Toggle reinvest
  document
    .getElementById('reinvest-toggle')
    ?.addEventListener('click', function () {
      reinvest = !reinvest;
      this.setAttribute('aria-checked', String(reinvest));
      const dot = document.getElementById('reinvest-dot')!;
      if (reinvest) {
        this.classList.add('bg-ink');
        this.classList.remove('bg-mute');
        dot.classList.add('translate-x-5');
        dot.classList.remove('translate-x-0.5');
      } else {
        this.classList.remove('bg-ink');
        this.classList.add('bg-mute');
        dot.classList.remove('translate-x-5');
        dot.classList.add('translate-x-0.5');
      }
      updateResults();
    });

  // Toggle table
  document
    .getElementById('toggle-table')
    ?.addEventListener('click', function () {
      showAllYears = !showAllYears;
      this.textContent = showAllYears ? 'Show Less' : 'Show All Years';
      if (lastResult) updateTable(lastResult.yearlyData);
    });

  // Chart type toggle
  document
    .getElementById('chart-line')
    ?.addEventListener('click', function () {
      this.classList.add('bg-ink', 'text-canvas');
      this.classList.remove(
        'bg-canvas-soft-2',
        'text-body',
        'hover:text-ink',
      );
      const barBtn = document.getElementById('chart-bar')!;
      barBtn.classList.remove('bg-ink', 'text-canvas');
      barBtn.classList.add(
        'bg-canvas-soft-2',
        'text-body',
        'hover:text-ink',
      );
      if (lastResult) updateChart(lastResult);
    });

  document
    .getElementById('chart-bar')
    ?.addEventListener('click', function () {
      this.classList.add('bg-ink', 'text-canvas');
      this.classList.remove(
        'bg-canvas-soft-2',
        'text-body',
        'hover:text-ink',
      );
      const lineBtn = document.getElementById('chart-line')!;
      lineBtn.classList.remove('bg-ink', 'text-canvas');
      lineBtn.classList.add(
        'bg-canvas-soft-2',
        'text-body',
        'hover:text-ink',
      );
      if (lastResult) updateChart(lastResult);
    });

  // Preset buttons
  document.querySelectorAll('.preset-btn').forEach((btn) => {
    btn.addEventListener('click', function () {
      const idx = Number((this as HTMLElement).dataset.preset);
      const preset = presets[idx];
      if (!preset) return;

      // Update active state
      document.querySelectorAll('.preset-btn').forEach((b) => {
        b.classList.remove('bg-ink', 'text-canvas');
        b.classList.add(
          'bg-canvas-soft-2',
          'text-body',
          'hover:text-ink',
        );
      });
      this.classList.add('bg-ink', 'text-canvas');
      this.classList.remove(
        'bg-canvas-soft-2',
        'text-body',
        'hover:text-ink',
      );

      // Set slider values
      sliders.initial!.value = String(preset.initialInvestment);
      sliders.contribution!.value = String(preset.annualContribution);
      sliders.horizon!.value = String(preset.investmentHorizon);
      sliders.gc!.value = String(preset.capitalAppreciationRate * 100);
      sliders.yield!.value = String(preset.dividendYield * 100);
      sliders.gd!.value = String(preset.dividendGrowthRate * 100);
      sliders.td!.value = String(preset.dividendTaxRate * 100);
      sliders.tcg!.value = String(preset.capitalGainsTaxRate * 100);

      // Set reinvest toggle
      reinvest = preset.reinvestDividends;
      const toggle = document.getElementById('reinvest-toggle')!;
      const dot = document.getElementById('reinvest-dot')!;
      toggle.setAttribute('aria-checked', String(reinvest));
      if (reinvest) {
        toggle.classList.add('bg-ink');
        toggle.classList.remove('bg-mute');
        dot.classList.add('translate-x-5');
        dot.classList.remove('translate-x-0.5');
      } else {
        toggle.classList.remove('bg-ink');
        toggle.classList.add('bg-mute');
        dot.classList.remove('translate-x-5');
        dot.classList.add('translate-x-0.5');
      }

      updateDisplays();
      updateResults();
    });
  });

  // Dark mode observer for chart re-render
  const observer = new MutationObserver(() => {
    if (lastResult) updateChart(lastResult);
  });
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });

  // Initial calculation
  updateResults();
</script>
